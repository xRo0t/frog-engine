fun get_debug_collision_vert_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    buf: i64 = Memory.malloc_zeroed(2144)
    if buf == 0:
        return shader
    _frog_init_debug_collision_vert_shader(buf)
    shader.data = buf
    shader.size = 2144
