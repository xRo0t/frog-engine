fun get_textured_frag_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    buf: i64 = Memory.malloc_zeroed(16676)
    if buf == 0:
        return shader
    _frog_init_tex_frag_shader(buf)
    shader.data = buf
    shader.size = 16676
    return shader

