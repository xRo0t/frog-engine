##############################
# Frog Engine - Embedded Shaders
# SPIR-V shaders initialized at runtime via Memory.write_i32
# (Global list<u8> data is zeroed at runtime, so we use init functions)
##############################

struct EmbeddedShader:
    data: i64 = 0
    size: i64 = 0

attach EmbeddedShader:

    fun release(self):
        if self.data != 0:
            Memory.free(self.data)
        self.data = 0
        self.size = 0

