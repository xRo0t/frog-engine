fun get_textured_vert_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    buf: i64 = Memory.malloc_zeroed(6684)
    if buf == 0:
        return shader
    _frog_init_tex_vert_shader(buf)
    shader.data = buf
    shader.size = 6684
    return shader

