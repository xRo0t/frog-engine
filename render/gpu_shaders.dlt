fun get_sky_frag_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    buf: i64 = Memory.malloc_zeroed(12856)
    if buf == 0:
        return shader
    _frog_init_sky_frag_shader(buf)
    shader.data = buf
    shader.size = 12856
    return shader

