fun _frog_init_shadow_vert_shader(buf: i64) -> void:
    _frog_init_shadow_vert_shader_p0(buf)
    _frog_init_shadow_vert_shader_p1(buf)
    _frog_init_shadow_vert_shader_p2(buf)
    _frog_init_shadow_vert_shader_p3(buf)
    _frog_init_shadow_vert_shader_p4(buf)

fun get_shadow_vert_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    buf: i64 = Memory.malloc_zeroed(2004)
    if buf == 0:
        return shader
    _frog_init_shadow_vert_shader(buf)
    shader.data = buf
    shader.size = 2004
    return shader

