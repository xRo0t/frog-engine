fun get_cull_compute_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    buf: i64 = Memory.malloc_zeroed(6044)
    if buf == 0:
        return shader
    _frog_init_cull_shader(buf)
    shader.data = buf
    shader.size = 6044
    return shader
