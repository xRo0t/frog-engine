##############################
# Frog Engine — GpuRendererCore
# ECS-aware Vulkan renderer
# Queries Scene for renderable entities
##############################

struct GpuBufferUpload:
    handle: i64 = 0
    memory: i64 = 0
    capacity: i64 = 0
    ok: i32 = 0

struct GpuMeshBounds:
    center_x: f32 = 0.0
    center_y: f32 = 0.0
    center_z: f32 = 0.0
    radius: f32 = 1.0

imm FROG_POINT_LIGHT_SLOTS: i32 = 8
imm FROG_POINT_LIGHT_DATA_SIZE: i64 = 336

# Shadow caster size-cull threshold (angular: worldRadius / |clipW|).
# 0.0 disables (default = prior behavior). The engine raises it for dense
# scenes so casters that map to a sub-pixel shadow are skipped.
static g_frog_shadow_min_size: f32 = 0.0

# Cascade-0 priority cull (CSM overlap reduction). When > 0, a caster that is
# fully contained inside cascade 0's box (with this NDC safety margin) is NOT
# re-rendered into cascade 1, eliminating the double-draw in the cascade
# overlap region. 0.0 disables (default). Risky under grazing light, so it's
# opt-in; the margin keeps casters near the boundary in both cascades.
static g_frog_shadow_cascade0_margin: f32 = 0.0

# CPU recording profiler (opt-in, shares the gpu_timing flag's spirit). Counts
# wall-clock ticks spent building the shadow instance buffer vs the rest of
# command recording, to find the real CPU bottleneck. Printed every 120 frames.
static g_frog_cpu_prof_enabled: i32 = 0
static g_frog_cpu_prof_shadow_ticks: i64 = 0
static g_frog_cpu_prof_total_ticks: i64 = 0
static g_frog_cpu_prof_frames: i32 = 0

# Parallel shadow visibility precompute. The heavy per-caster test (matrix
# transform + sqrt + frustum + cascade-0 containment) is run across worker
# threads into g_shadow_vis_out[cascade*vb_count + gi] (1=visible). The serial
# compaction loop then just reads this array (cheap), instead of doing the
# math single-threaded. Identical output, ~Nx less serial CPU time.
static g_shadow_vis_out:        i64 = 0
static g_shadow_vis_cap:        i32 = 0
static g_shadow_vb_count:       i32 = 0
static g_shadow_light_vp:       i64 = 0
static g_shadow_model_matrices: i64 = 0
static g_shadow_vb_visible:     i64 = 0
static g_shadow_mesh_flags:     i64 = 0
static g_shadow_bound_xs:       i64 = 0
static g_shadow_bound_ys:       i64 = 0
static g_shadow_bound_zs:       i64 = 0
static g_shadow_bound_rs:       i64 = 0
static g_shadow_mesh_dist:      i64 = 0
static g_shadow_max_distance:   f32 = 0.0
static g_shadow_active_cascades: i32 = 1
static g_shadow_cam_x:          f32 = 0.0
static g_shadow_cam_y:          f32 = 0.0
static g_shadow_cam_z:          f32 = 0.0
static g_shadow_vis_body:       i64 = 0   # cached @heap fun(i32), created once

fun _frog_abs_f32(v: f32) -> f32:
    if v < 0.0:
        return 0.0 - v
    return v

fun _frog_pack_light(color: Color, ambient: f32) -> f32:
    r: i32 = (clamp(color.r, 0.0, 1.0) * 63.0 + 0.5) as i32
    g: i32 = (clamp(color.g, 0.0, 1.0) * 63.0 + 0.5) as i32
    b: i32 = (clamp(color.b, 0.0, 1.0) * 63.0 + 0.5) as i32
    a: i32 = (clamp(ambient, 0.0, 1.0) * 63.0 + 0.5) as i32
    return (r + g * 64 + b * 4096 + a * 262144) as f32

fun _frog_pack_material(material: Material3D) -> f32:
    r: i32 = (clamp(material.emissive.r, 0.0, 1.0) * 31.0 + 0.5) as i32
    g: i32 = (clamp(material.emissive.g, 0.0, 1.0) * 31.0 + 0.5) as i32
    b: i32 = (clamp(material.emissive.b, 0.0, 1.0) * 31.0 + 0.5) as i32
    unlit: i32 = 0
    if material.unlit != 0:
        unlit = 1
    emissive_map: i32 = 0
    if material.has_emissive_map != 0:
        emissive_map = 1
    normal_map: i32 = 0
    if material.has_normal_map != 0:
        normal_map = 1
    metallic_roughness_map: i32 = 0
    if material.has_metallic_roughness_map != 0:
        metallic_roughness_map = 1
    occlusion_map: i32 = 0
    if material.has_occlusion_map != 0:
        occlusion_map = 1
    return (r + g * 32 + b * 1024 + unlit * 32768 + emissive_map * 131072 + normal_map * 262144 + metallic_roughness_map * 524288 + occlusion_map * 1048576) as f32

fun _frog_mesh_bounds(vertices: i64, vertex_count: i32) -> GpuMeshBounds:
    if vertices == 0:
        return GpuMeshBounds()
    if vertex_count <= 0:
        return GpuMeshBounds()

    min_x: f32 = Memory.read_f32(vertices)
    min_y: f32 = Memory.read_f32(vertices + 4)
    min_z: f32 = Memory.read_f32(vertices + 8)
    max_x: f32 = min_x
    max_y: f32 = min_y
    max_z: f32 = min_z
    i: i32 = 1
    while i < vertex_count:
        off: i64 = (i as i64) * (FROG_GPU_VERTEX_STRIDE as i64)
        x: f32 = Memory.read_f32(vertices + off)
        y: f32 = Memory.read_f32(vertices + off + 4)
        z: f32 = Memory.read_f32(vertices + off + 8)
        if x < min_x:
            min_x = x
        if y < min_y:
            min_y = y
        if z < min_z:
            min_z = z
        if x > max_x:
            max_x = x
        if y > max_y:
            max_y = y
        if z > max_z:
            max_z = z
        i = i + 1

    cx: f32 = (min_x + max_x) * 0.5
    cy: f32 = (min_y + max_y) * 0.5
    cz: f32 = (min_z + max_z) * 0.5
    dx: f32 = max_x - min_x
    dy: f32 = max_y - min_y
    dz: f32 = max_z - min_z
    radius: f32 = @sqrt(dx * dx + dy * dy + dz * dz) * 0.5 + 1.0
    return GpuMeshBounds(center_x=cx, center_y=cy, center_z=cz, radius=radius)

fun _frog_instance_visible(vp: i64, model: i64, bound_x: f32, bound_y: f32, bound_z: f32, bound_radius: f32) -> i32:
    if vp == 0:
        return 1
    if model == 0:
        return 0

    x: f32 = Memory.read_f32(model + 0) * bound_x + Memory.read_f32(model + 16) * bound_y + Memory.read_f32(model + 32) * bound_z + Memory.read_f32(model + 48)
    y: f32 = Memory.read_f32(model + 4) * bound_x + Memory.read_f32(model + 20) * bound_y + Memory.read_f32(model + 36) * bound_z + Memory.read_f32(model + 52)
    z: f32 = Memory.read_f32(model + 8) * bound_x + Memory.read_f32(model + 24) * bound_y + Memory.read_f32(model + 40) * bound_z + Memory.read_f32(model + 56)

    cx: f32 = Memory.read_f32(vp + 0) * x + Memory.read_f32(vp + 16) * y + Memory.read_f32(vp + 32) * z + Memory.read_f32(vp + 48)
    cy: f32 = Memory.read_f32(vp + 4) * x + Memory.read_f32(vp + 20) * y + Memory.read_f32(vp + 36) * z + Memory.read_f32(vp + 52)
    cz: f32 = Memory.read_f32(vp + 8) * x + Memory.read_f32(vp + 24) * y + Memory.read_f32(vp + 40) * z + Memory.read_f32(vp + 56)
    cw: f32 = Memory.read_f32(vp + 12) * x + Memory.read_f32(vp + 28) * y + Memory.read_f32(vp + 44) * z + Memory.read_f32(vp + 60)

    sx: f32 = @sqrt(Memory.read_f32(model + 0) * Memory.read_f32(model + 0) + Memory.read_f32(model + 4) * Memory.read_f32(model + 4) + Memory.read_f32(model + 8) * Memory.read_f32(model + 8))
    sy: f32 = @sqrt(Memory.read_f32(model + 16) * Memory.read_f32(model + 16) + Memory.read_f32(model + 20) * Memory.read_f32(model + 20) + Memory.read_f32(model + 24) * Memory.read_f32(model + 24))
    sz: f32 = @sqrt(Memory.read_f32(model + 32) * Memory.read_f32(model + 32) + Memory.read_f32(model + 36) * Memory.read_f32(model + 36) + Memory.read_f32(model + 40) * Memory.read_f32(model + 40))
    max_scale: f32 = sx
    if sy > max_scale:
        max_scale = sy
    if sz > max_scale:
        max_scale = sz
    if max_scale < 0.001:
        max_scale = 1.0
    bounds: f32 = bound_radius * max_scale * 2.25 + 2.0
    limit: f32 = _frog_abs_f32(cw) * 1.08 + bounds

    if cw < 0.0 - bounds:
        return 0
    if cx < 0.0 - limit:
        return 0
    if cx > limit:
        return 0
    if cy < 0.0 - limit:
        return 0
    if cy > limit:
        return 0
    if cz < 0.0 - bounds:
        return 0
    if cz > _frog_abs_f32(cw) + bounds:
        return 0
    return 1

fun _frog_shadow_instance_visible(vp: i64, model: i64, bound_x: f32, bound_y: f32, bound_z: f32, bound_radius: f32, cam_x: f32, cam_y: f32, cam_z: f32, max_distance: f32) -> i32:
    if vp == 0:
        return 1
    if model == 0:
        return 0

    x: f32 = Memory.read_f32(model + 0) * bound_x + Memory.read_f32(model + 16) * bound_y + Memory.read_f32(model + 32) * bound_z + Memory.read_f32(model + 48)
    y: f32 = Memory.read_f32(model + 4) * bound_x + Memory.read_f32(model + 20) * bound_y + Memory.read_f32(model + 36) * bound_z + Memory.read_f32(model + 52)
    z: f32 = Memory.read_f32(model + 8) * bound_x + Memory.read_f32(model + 24) * bound_y + Memory.read_f32(model + 40) * bound_z + Memory.read_f32(model + 56)

    sx: f32 = @sqrt(Memory.read_f32(model + 0) * Memory.read_f32(model + 0) + Memory.read_f32(model + 4) * Memory.read_f32(model + 4) + Memory.read_f32(model + 8) * Memory.read_f32(model + 8))
    sy: f32 = @sqrt(Memory.read_f32(model + 16) * Memory.read_f32(model + 16) + Memory.read_f32(model + 20) * Memory.read_f32(model + 20) + Memory.read_f32(model + 24) * Memory.read_f32(model + 24))
    sz: f32 = @sqrt(Memory.read_f32(model + 32) * Memory.read_f32(model + 32) + Memory.read_f32(model + 36) * Memory.read_f32(model + 36) + Memory.read_f32(model + 40) * Memory.read_f32(model + 40))
    max_scale: f32 = sx
    if sy > max_scale:
        max_scale = sy
    if sz > max_scale:
        max_scale = sz
    if max_scale < 0.001:
        max_scale = 1.0

    if max_distance > 0.0:
        radius: f32 = bound_radius * max_scale + 2.0
        distance_limit: f32 = max_distance + radius
        dx: f32 = x - cam_x
        dy: f32 = y - cam_y
        dz: f32 = z - cam_z
        if dx * dx + dy * dy + dz * dz > distance_limit * distance_limit:
            return 0

    cx: f32 = Memory.read_f32(vp + 0) * x + Memory.read_f32(vp + 16) * y + Memory.read_f32(vp + 32) * z + Memory.read_f32(vp + 48)
    cy: f32 = Memory.read_f32(vp + 4) * x + Memory.read_f32(vp + 20) * y + Memory.read_f32(vp + 36) * z + Memory.read_f32(vp + 52)
    cz: f32 = Memory.read_f32(vp + 8) * x + Memory.read_f32(vp + 24) * y + Memory.read_f32(vp + 40) * z + Memory.read_f32(vp + 56)
    cw: f32 = Memory.read_f32(vp + 12) * x + Memory.read_f32(vp + 28) * y + Memory.read_f32(vp + 44) * z + Memory.read_f32(vp + 60)

    bounds: f32 = bound_radius * max_scale * 2.25 + 2.0
    limit: f32 = _frog_abs_f32(cw) * 1.08 + bounds

    if cw < 0.0 - bounds:
        return 0
    if cx < 0.0 - limit:
        return 0
    if cx > limit:
        return 0
    if cy < 0.0 - limit:
        return 0
    if cy > limit:
        return 0
    if cz < 0.0 - bounds:
        return 0
    if cz > _frog_abs_f32(cw) + bounds:
        return 0

    # Shadow caster SIZE cull (shadow LOD): a caster whose projected footprint
    # on the shadow map is only a few texels produces a sub-pixel shadow that's
    # effectively invisible but still costs a full rasterized draw. We compute
    # the caster's projected radius in NDC and reject it when it falls below a
    # threshold. This works for the directional light's ORTHOGRAPHIC projection
    # (where cw is constant) because we derive the screen-space scale from the
    # vp matrix gradient rows rather than from perspective foreshortening.
    #   ndc_dx_per_world = |(vp.m0, vp.m4, vp.m8)|   (d clipX / d world)
    #   ndc_dy_per_world = |(vp.m1, vp.m5, vp.m9)|   (d clipY / d world)
    #   projected_ndc_radius = world_radius * max(dx, dy) / |cw|
    # NDC spans [-1, 1] (width 2), so a threshold of e.g. 0.01 means "cull
    # casters whose shadow radius is under 0.5% of the shadow map dimension".
    # g_frog_shadow_min_size = 0 disables the cull (default keeps prior behavior).
    if g_frog_shadow_min_size > 0.0:
        world_radius: f32 = bound_radius * max_scale
        gx0: f32 = Memory.read_f32(vp + 0)
        gx1: f32 = Memory.read_f32(vp + 16)
        gx2: f32 = Memory.read_f32(vp + 32)
        gy0: f32 = Memory.read_f32(vp + 4)
        gy1: f32 = Memory.read_f32(vp + 20)
        gy2: f32 = Memory.read_f32(vp + 36)
        grad_x: f32 = @sqrt(gx0 * gx0 + gx1 * gx1 + gx2 * gx2)
        grad_y: f32 = @sqrt(gy0 * gy0 + gy1 * gy1 + gy2 * gy2)
        grad: f32 = grad_x
        if grad_y > grad:
            grad = grad_y
        denom: f32 = _frog_abs_f32(cw)
        if denom < 0.0001:
            denom = 0.0001
        ndc_radius: f32 = world_radius * grad / denom
        if ndc_radius < g_frog_shadow_min_size:
            return 0
    return 1

# Returns 1 if the caster's bounding sphere is fully contained inside the
# given cascade's NDC box (x,y in [-1,1], z in [0,1]) with a safety margin.
# Used to skip re-drawing a near caster into the far cascade (CSM overlap
# reduction). Conservative: any uncertainty -> 0 (keep the draw).
fun _frog_shadow_fully_in_cascade(vp: i64, model: i64, bound_x: f32, bound_y: f32, bound_z: f32, bound_radius: f32, margin: f32) -> i32:
    if vp == 0:
        return 0
    if model == 0:
        return 0

    x: f32 = Memory.read_f32(model + 0) * bound_x + Memory.read_f32(model + 16) * bound_y + Memory.read_f32(model + 32) * bound_z + Memory.read_f32(model + 48)
    y: f32 = Memory.read_f32(model + 4) * bound_x + Memory.read_f32(model + 20) * bound_y + Memory.read_f32(model + 36) * bound_z + Memory.read_f32(model + 52)
    z: f32 = Memory.read_f32(model + 8) * bound_x + Memory.read_f32(model + 24) * bound_y + Memory.read_f32(model + 40) * bound_z + Memory.read_f32(model + 56)

    sx: f32 = @sqrt(Memory.read_f32(model + 0) * Memory.read_f32(model + 0) + Memory.read_f32(model + 4) * Memory.read_f32(model + 4) + Memory.read_f32(model + 8) * Memory.read_f32(model + 8))
    sy: f32 = @sqrt(Memory.read_f32(model + 16) * Memory.read_f32(model + 16) + Memory.read_f32(model + 20) * Memory.read_f32(model + 20) + Memory.read_f32(model + 24) * Memory.read_f32(model + 24))
    sz: f32 = @sqrt(Memory.read_f32(model + 32) * Memory.read_f32(model + 32) + Memory.read_f32(model + 36) * Memory.read_f32(model + 36) + Memory.read_f32(model + 40) * Memory.read_f32(model + 40))
    max_scale: f32 = sx
    if sy > max_scale:
        max_scale = sy
    if sz > max_scale:
        max_scale = sz
    if max_scale < 0.001:
        max_scale = 1.0
    world_radius: f32 = bound_radius * max_scale

    cx: f32 = Memory.read_f32(vp + 0) * x + Memory.read_f32(vp + 16) * y + Memory.read_f32(vp + 32) * z + Memory.read_f32(vp + 48)
    cy: f32 = Memory.read_f32(vp + 4) * x + Memory.read_f32(vp + 20) * y + Memory.read_f32(vp + 36) * z + Memory.read_f32(vp + 52)
    cz: f32 = Memory.read_f32(vp + 8) * x + Memory.read_f32(vp + 24) * y + Memory.read_f32(vp + 40) * z + Memory.read_f32(vp + 56)

    # NDC half-extent the sphere projects to along x and y (ortho gradients).
    gx0: f32 = Memory.read_f32(vp + 0)
    gx1: f32 = Memory.read_f32(vp + 16)
    gx2: f32 = Memory.read_f32(vp + 32)
    gy0: f32 = Memory.read_f32(vp + 4)
    gy1: f32 = Memory.read_f32(vp + 20)
    gy2: f32 = Memory.read_f32(vp + 36)
    gz0: f32 = Memory.read_f32(vp + 8)
    gz1: f32 = Memory.read_f32(vp + 24)
    gz2: f32 = Memory.read_f32(vp + 40)
    rx: f32 = world_radius * @sqrt(gx0 * gx0 + gx1 * gx1 + gx2 * gx2)
    ry: f32 = world_radius * @sqrt(gy0 * gy0 + gy1 * gy1 + gy2 * gy2)
    rz: f32 = world_radius * @sqrt(gz0 * gz0 + gz1 * gz1 + gz2 * gz2)

    bx: f32 = 1.0 - margin
    # x within [-bx+rx, bx-rx]
    if cx - rx < 0.0 - bx:
        return 0
    if cx + rx > bx:
        return 0
    if cy - ry < 0.0 - bx:
        return 0
    if cy + ry > bx:
        return 0
    # z within [0, 1] (Vulkan depth)
    if cz - rz < 0.0:
        return 0
    if cz + rz > 1.0:
        return 0
    return 1

# Parallel shadow visibility for one caster gi: writes 1/0 into
# g_shadow_vis_out[cascade * vb_count + gi] for each active cascade. Mirrors
# the serial logic in _record_shadow_pass exactly (shadow-flag cast bit +
# per-instance frustum/distance test + cascade-0 containment cull) so the
# compaction loop produces a byte-identical instance buffer.
fun _frog_shadow_vis_one(gi: i32):
    out: i64 = g_shadow_vis_out
    vbc: i32 = g_shadow_vb_count
    light_vp: i64 = g_shadow_light_vp

    g_model: i64 = 0
    if g_shadow_model_matrices != 0:
        g_model = Memory.read_ptr(g_shadow_model_matrices + (gi as i64) * 8)

    # Base visibility (instance visible flag).
    base_vis: i32 = 1
    if g_shadow_vb_visible != 0:
        if Memory.read_i32(g_shadow_vb_visible + (gi as i64) * 4) == 0:
            base_vis = 0
    # Shadow caster flag (cast bit = flags & 1).
    cast_shadow: i32 = 1
    if g_shadow_mesh_flags != 0:
        flags: i32 = Memory.read_i32(g_shadow_mesh_flags + (gi as i64) * 4)
        cast_shadow = flags - (flags / 2) * 2

    castable: i32 = 0
    if base_vis == 1:
        if cast_shadow == 1:
            if g_model != 0:
                castable = 1

    bound_x: f32 = 0.0
    bound_y: f32 = 0.0
    bound_z: f32 = 0.0
    bound_r: f32 = 0.0
    eff_dist: f32 = g_shadow_max_distance
    if castable == 1:
        bound_x = Memory.read_f32(g_shadow_bound_xs + (gi as i64) * 4)
        bound_y = Memory.read_f32(g_shadow_bound_ys + (gi as i64) * 4)
        bound_z = Memory.read_f32(g_shadow_bound_zs + (gi as i64) * 4)
        bound_r = Memory.read_f32(g_shadow_bound_rs + (gi as i64) * 4)
        if g_shadow_mesh_dist != 0:
            obj_dist: f32 = Memory.read_f32(g_shadow_mesh_dist + (gi as i64) * 4)
            if obj_dist > 0.0:
                if eff_dist <= 0.0:
                    eff_dist = obj_dist
                elif obj_dist < eff_dist:
                    eff_dist = obj_dist

    c: i32 = 0
    while c < 2:
        vis: i32 = 0
        if c < g_shadow_active_cascades:
            if castable == 1:
                cascade_matrix: i64 = light_vp + (c as i64) * 64
                vis = _frog_shadow_instance_visible(cascade_matrix, g_model, bound_x, bound_y, bound_z, bound_r, g_shadow_cam_x, g_shadow_cam_y, g_shadow_cam_z, eff_dist)
                if vis == 1:
                    if c == 1:
                        if g_frog_shadow_cascade0_margin > 0.0:
                            if _frog_shadow_fully_in_cascade(light_vp, g_model, bound_x, bound_y, bound_z, bound_r, g_frog_shadow_cascade0_margin) == 1:
                                vis = 0
        Memory.write_i32(out + ((c * vbc + gi) as i64) * 4, vis)
        c = c + 1

fun _frog_cull_one(self_addr: i64, vp: i64, gi: i32, res: i64):
    core: GpuRendererCore = self_addr as GpuRendererCore
    visible: i32 = 1
    if core.vb_visible != 0:
        if Memory.read_i32(core.vb_visible + gi * 4) == 0:
            visible = 0
    if visible == 1:
        if core.instance_culling_enabled == 1:
            g_model: i64 = 0
            if core.model_matrices != 0:
                g_model = Memory.read_ptr(core.model_matrices + gi * 8)
            bound_x: f32 = 0.0
            bound_y: f32 = 0.0
            bound_z: f32 = 0.0
            bound_r: f32 = 8.0
            if core.mesh_bound_rs != 0:
                bound_x = Memory.read_f32(core.mesh_bound_xs + gi * 4)
                bound_y = Memory.read_f32(core.mesh_bound_ys + gi * 4)
                bound_z = Memory.read_f32(core.mesh_bound_zs + gi * 4)
                bound_r = Memory.read_f32(core.mesh_bound_rs + gi * 4)
                if bound_r <= 0.0:
                    bound_r = 8.0
            visible = _frog_instance_visible(vp, g_model, bound_x, bound_y, bound_z, bound_r)
    Memory.write_i32(res + (gi as i64) * 4, visible)

# Globals for the transform-only candidate refresh (parallel body reads
# these; set by _gpu_cull_refresh_transforms before dispatching). The body
# is a Pure_Mapping over candidate slot k -> writes only that slot's matrix.
g_refresh_cand_gi: i64 = 0   # i32[]: candidate slot -> mesh index (gi)
g_refresh_models:  i64 = 0   # ptr[]: per-mesh model matrix pointer
g_refresh_cull:    i64 = 0   # GpuCullPipeline as i64

# Refresh candidate slot k's model matrix in the GPU input buffer in place.
fun _gpu_cull_refresh_one(k: i32):
    gi: i32 = Memory.read_i32(g_refresh_cand_gi + (k as i64) * 4)
    model_ptr: i64 = Memory.read_ptr(g_refresh_models + (gi as i64) * 8)
    if model_ptr != 0:
        cull: GpuCullPipeline = g_refresh_cull as GpuCullPipeline
        cull.write_model_at(k, model_ptr)

struct GpuRendererCore:
    device:            i64 = 0
    phys_device:       i64 = 0
    gfx_queue:         i64 = 0
    present_queue:     i64 = 0
    # Vertex buffer registry
    vb_handles:        i64 = 0
    vb_memories:       i64 = 0
    vb_alloc_sizes:    i64 = 0
    vb_vert_counts:    i64 = 0
    ib_handles:        i64 = 0
    ib_memories:       i64 = 0
    ib_alloc_sizes:    i64 = 0
    ib_index_counts:   i64 = 0
    model_matrices:    i64 = 0
    mesh_bound_xs:     i64 = 0
    mesh_bound_ys:     i64 = 0
    mesh_bound_zs:     i64 = 0
    mesh_bound_rs:     i64 = 0
    vb_visible:        i64 = 0    # i32[] per instance: 1 = drawn, 0 = hidden
    vb_cull_result:    i64 = 0    # i32[] per instance: parallel cull pre-pass result (1 = visible, 0 = culled)
    instance_buffer:   i64 = 0
    instance_memory:   i64 = 0
    # Per-frame instance buffers (one per frame-in-flight) to avoid a
    # CPU/GPU race: frame N must not overwrite the buffer frame N-1 is still
    # reading. Slot 0 mirrors instance_buffer/instance_memory for back-compat.
    instance_buffers:  i64 = 0    # VkBuffer[FROG_INSTANCE_SLOTS]
    instance_memories: i64 = 0    # VkDeviceMemory[FROG_INSTANCE_SLOTS]
    instance_mapped_ptrs: i64 = 0 # Persistently mapped ptr[FROG_INSTANCE_SLOTS]
    instance_capacity: i32 = 0
    vb_count:          i32 = 0
    vb_capacity:       i32 = 0
    initialized:       i32 = 0
    current_frame:     i32 = 0
    # Borrowed Scene light registry plus double-buffered GPU uniform data.
    point_light_ptrs:  i64 = 0
    point_light_count: i32 = 0
    point_light_buffers: i64 = 0
    point_light_memories: i64 = 0
    point_light_mapped_ptrs: i64 = 0
    point_light_desc_sets: i64 = 0
    # Pre-allocated scratch buffers for render loop
    scratch_vb_arr:    i64 = 0
    scratch_off_arr:   i64 = 0
    scratch_inst_vb_arr:  i64 = 0
    scratch_inst_off_arr: i64 = 0
    scratch_desc_arr:     i64 = 0
    scratch_map_pp:       i64 = 0
    scratch_begin_info:   i64 = 0
    scratch_render_info:  i64 = 0
    scratch_clear_values: i64 = 0
    scratch_viewport:     i64 = 0
    scratch_scissor:      i64 = 0
    scratch_sky_att:      i64 = 0
    scratch_sky_rect:     i64 = 0
    scratch_vp_matrix:    i64 = 0
    scratch_push_data:    i64 = 0
    scratch_camera_view:  i64 = 0
    scratch_camera_proj:  i64 = 0
    instance_culling_enabled: i32 = 0
    # GPU-driven culling: when enabled, the main pass culls + draws each
    # group via compute + vkCmdDrawIndexedIndirect instead of CPU culling.
    # 0 = CPU path (default, safe). Set via set_gpu_culling.
    gpu_culling_enabled: i32 = 0
    gpu_cull_ptr: i64 = 0    # borrowed GpuCullPipeline (owned by runtime)
    gpu_cull_verify_enabled: i32 = 0   # debug: print GPU vs CPU visible counts
    # Phase 3 step 2: actually DRAW from the GPU-culled output (indirect).
    # Separate flag so verification (above) and drawing can be toggled apart.
    gpu_draw_enabled: i32 = 0
    # Culling mode selection (CPU vs GPU-driven). 0 = CPU (default/safe),
    # 1 = GPU forced, 2 = Auto (GPU when instance count >= threshold).
    # The mode resolves to gpu_draw_enabled at render time.
    culling_mode: i32 = 0
    culling_auto_threshold: i32 = 2000
    # Per-frame group tracking shared between the pre-cull pass and the
    # indirect draw pass. Each slot describes one drawable mesh group.
    gpu_grp_mi: i64 = 0        # i32[]: representative mesh index of the group
    gpu_grp_outbase: i64 = 0   # i32[]: first output slot for the group
    gpu_grp_count: i64 = 0     # i32[]: candidate count for the group
    gpu_grp_indexed: i64 = 0   # i32[]: 1 if the group draws indexed
    gpu_grp_cmd: i64 = 0       # i32[]: absolute indirect-command index
    gpu_grp_inbase: i64 = 0    # i32[]: first INPUT candidate index (persistent)
    gpu_grp_draw: i64 = 0      # i32[]: index/vertex count for the draw
    gpu_grp_capacity: i32 = 0
    # candidate-slot -> mesh index (gi) map, filled during _gpu_cull_rebuild.
    # Lets the transform-only fast path rewrite each candidate's model matrix
    # in place (no regroup) when instances merely moved. Sized like vb arrays.
    gpu_cand_gi: i64 = 0       # i32[vb_capacity]
    gpu_cand_n:  i32 = 0       # number of live candidate slots from last rebuild
    gpu_grp_n: i32 = 0
    gpu_slot_grpn: i64 = 0     # i32[FROG_CULL_SLOTS]: group count last written per slot
    gpu_slot_cmdbase: i64 = 0  # i32[FROG_CULL_SLOTS]: cmd base index per slot
    gpu_cull_push: i64 = 0     # 112B push-constant scratch (planes + group fields)
    gpu_cull_rec: i64 = 0      # 128B instance-record scratch (model+material+uv+texidx)
    gpu_cull_slot: i32 = 0     # frame slot the current precull wrote into
    debug_render_stats_enabled: i32 = 0
    debug_frame_count: i32 = 0
    debug_draw_calls: i32 = 0
    debug_indexed_draw_calls: i32 = 0
    debug_visible_instances: i32 = 0
    debug_collisions_enabled: i32 = 0
    debug_collision_root_ptr: i64 = 0
    debug_manual_boxes: i64 = 0
    debug_manual_box_count: i32 = 0
    debug_manual_box_capacity: i32 = 0
    # Texture registry
    tex_views:      i64 = 0    # VkImageView[]
    tex_samplers:   i64 = 0    # VkSampler[]
    tex_images:     i64 = 0    # VkImage[]
    tex_memories:   i64 = 0    # VkDeviceMemory[]
    tex_desc_sets:  i64 = 0    # VkDescriptorSet[]
    tex_bindless_slots: i64 = 0 # i32[]: bindless table slot per texture (-1 = none)
    tex_count:      i32 = 0
    tex_capacity:   i32 = 0
    mesh_tex_ids:   i64 = 0    # mesh_id -> texture_id (-1 = white fallback)
    mesh_emissive_tex_ids: i64 = 0 # mesh_id -> emissive texture_id (-1 = white fallback)
    mesh_normal_tex_ids: i64 = 0 # mesh_id -> normal texture id (-1 = white fallback)
    mesh_metallic_roughness_tex_ids: i64 = 0 # mesh_id -> glTF metallic-roughness texture id
    mesh_occlusion_tex_ids: i64 = 0 # mesh_id -> ambient-occlusion texture id
    mesh_desc_sets: i64 = 0    # mesh_id -> material descriptor set cache
    mesh_material_params: i64 = 0 # mesh_id -> material vec4 + uv transform vec4
    mesh_shadow_flags: i64 = 0 # mesh_id -> cast + receive * 2
    mesh_shadow_distances: i64 = 0 # mesh_id -> object shadow cutoff, 0 = inherit light distance
    white_desc_set: i64 = 0    # descriptor set for the 1x1 white fallback
    white_tex_id:   i32 = -1
    # --- Phase 1: Bindless texture table (R1) ---
    # One giant descriptor set holding ALL texture views, indexed per-instance
    # in the shader. Eliminates the per-group vkCmdBindDescriptorSets. All
    # fields stay 0 / disabled until _bindless_init runs AND the device
    # actually supports descriptor indexing (caps). bindless_enabled gates
    # every modern path; when 0 the classic per-mesh descriptor path runs.
    bindless_layout:   i64 = 0   # VkDescriptorSetLayout (update-after-bind)
    bindless_pool:     i64 = 0   # VkDescriptorPool (update-after-bind)
    bindless_set:      i64 = 0   # VkDescriptorSet (the big table)
    bindless_count:    i32 = 0   # number of slots written so far
    bindless_capacity: i32 = 0   # table size cap (from caps.max_descriptor_array)
    bindless_supported: i32 = 0  # device supports descriptor indexing (from caps)
    bindless_flag:     i32 = 0   # user/runtime opt-in flag
    bindless_enabled:  i32 = 0   # supported && flag && initialized
    # Phase 2: instance-SSBO descriptor sets (set 3) for the GPU-driven batched
    # draw. One per frame slot, each pointing at that slot's region of the cull
    # output buffer. Built once after the SSBO pipeline + cull buffers exist.
    ssbo_desc_pool:    i64 = 0
    ssbo_desc_sets:    i64 = 0   # VkDescriptorSet[FROG_CULL_SLOTS]
    ssbo_desc_outbuf:  i64 = 0   # out_buffer the sets were built against (realloc guard)
    ssbo_draw_enabled: i32 = 0   # ssbo pipeline ready && bindless && indirect-count
    ssbo_pipeline_ready: i32 = 0 # ssbo pipeline built (set at init; gates firstInstance)
    ssbo_layout_ref:   i64 = 0   # cached RenderPass.ssbo_set_layout
    # Offscreen render-scale target. When render_scale != 1, the scene is
    # rendered here, then blitted to the swapchain image for presentation.
    scale_color_image:  i64 = 0
    scale_color_memory: i64 = 0
    scale_color_view:   i64 = 0
    scale_sampler:      i64 = 0
    scale_desc_set:     i64 = 0
    scale_depth_image:  i64 = 0
    scale_depth_memory: i64 = 0
    scale_depth_view:   i64 = 0
    scale_framebuffer:  i64 = 0
    scale_width:        i32 = 0
    scale_height:       i32 = 0
    scale_format:       i32 = 0
    retire_buffers:     i64 = 0
    retire_memories:    i64 = 0
    retire_frames:      i64 = 0
    retire_sizes:       i64 = 0
    retire_usages:      i64 = 0
    retire_count:       i32 = 0
    retire_capacity:    i32 = 0
    pooled_buffers:     i64 = 0
    pooled_memories:    i64 = 0
    pooled_sizes:       i64 = 0
    pooled_usages:      i64 = 0
    pooled_count:       i32 = 0
    pooled_capacity:    i32 = 0
    pooled_bytes:       i64 = 0
    pooled_byte_limit:  i64 = 0
    frame_serial:       i32 = 0
    # Compact render state block:
    # 0 directional light, 8/16/24 shadow instance arrays, 32 capacity,
    # 40/48/56 global arrays, 64/68/72 camera position, 76/80 pitch/yaw.
    # Shadow globals are 176 bytes: two cascade matrices, params, splits,
    # filter controls, and fade distance.
    render_state: i64 = 0
    # GPU timing (optional, off by default). Measures shadow/main/post GPU ms.
    profiler: GpuProfiler = GpuProfiler()

attach GpuRendererCore:

    fun init(self, device: i64, phys_device: i64, gfx_queue: i64, present_queue: i64) -> void:
        self.device = device
        self.phys_device = phys_device
        self.gfx_queue = gfx_queue
        self.present_queue = present_queue
        self.vb_capacity = 1024
        self.vb_handles = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.vb_memories = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.vb_alloc_sizes = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.vb_vert_counts = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.ib_handles = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.ib_memories = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.ib_alloc_sizes = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.ib_index_counts = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.model_matrices = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.mesh_bound_xs = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_bound_ys = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_bound_zs = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_bound_rs = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.vb_visible = Memory.malloc_zeroed(self.vb_capacity * 4)
        vvi: i32 = 0
        while vvi < self.vb_capacity:
            Memory.write_i32(self.vb_visible + vvi * 4, 1)
            vvi = vvi + 1
        self.vb_cull_result = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.vb_count = 0
        # Texture registry
        self.tex_capacity = 256
        self.tex_views = Memory.malloc_zeroed(self.tex_capacity * 8)
        self.tex_samplers = Memory.malloc_zeroed(self.tex_capacity * 8)
        self.tex_images = Memory.malloc_zeroed(self.tex_capacity * 8)
        self.tex_memories = Memory.malloc_zeroed(self.tex_capacity * 8)
        self.tex_desc_sets = Memory.malloc_zeroed(self.tex_capacity * 8)
        self.tex_bindless_slots = Memory.malloc_zeroed(self.tex_capacity * 4)
        tbsi: i32 = 0
        while tbsi < self.tex_capacity:
            Memory.write_i32(self.tex_bindless_slots + tbsi * 4, 0 - 1)
            tbsi = tbsi + 1
        self.tex_count = 0
        # mesh_id -> texture_id, default -1 (white fallback)
        self.mesh_tex_ids = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_emissive_tex_ids = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_normal_tex_ids = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_metallic_roughness_tex_ids = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_occlusion_tex_ids = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_desc_sets = Memory.malloc_zeroed(self.vb_capacity * 8)
        self.mesh_material_params = Memory.malloc_zeroed(self.vb_capacity * 32)
        self.mesh_shadow_flags = Memory.malloc_zeroed(self.vb_capacity * 4)
        self.mesh_shadow_distances = Memory.malloc_zeroed(self.vb_capacity * 4)
        mti: i32 = 0
        while mti < self.vb_capacity:
            Memory.write_i32(self.mesh_tex_ids + mti * 4, 0 - 1)
            Memory.write_i32(self.mesh_emissive_tex_ids + mti * 4, 0 - 1)
            Memory.write_i32(self.mesh_normal_tex_ids + mti * 4, 0 - 1)
            Memory.write_i32(self.mesh_metallic_roughness_tex_ids + mti * 4, 0 - 1)
            Memory.write_i32(self.mesh_occlusion_tex_ids + mti * 4, 0 - 1)
            Memory.write_f32(self.mesh_material_params + mti * 32 + 4, 1.0)
            Memory.write_f32(self.mesh_material_params + mti * 32 + 16, 1.0)
            Memory.write_f32(self.mesh_material_params + mti * 32 + 20, 1.0)
            Memory.write_i32(self.mesh_shadow_flags + mti * 4, 3)
            mti = mti + 1
        self.white_desc_set = 0
        self.white_tex_id = 0 - 1
        # Pre-allocate scratch buffers (eliminates malloc/free per draw)
        self.scratch_vb_arr = Memory.malloc_zeroed(8)
        self.scratch_off_arr = Memory.malloc_zeroed(8)
        self.scratch_inst_vb_arr = Memory.malloc_zeroed(8)
        self.scratch_inst_off_arr = Memory.malloc_zeroed(8)
        self.scratch_desc_arr = Memory.malloc_zeroed(8)
        self.scratch_map_pp = Memory.malloc_zeroed(8)
        self.scratch_begin_info = Memory.malloc_zeroed(64)
        self.scratch_render_info = Memory.malloc_zeroed(96)
        self.scratch_clear_values = Memory.malloc_zeroed(32)
        self.scratch_viewport = Memory.malloc_zeroed(24)
        self.scratch_scissor = Memory.malloc_zeroed(16)
        self.scratch_sky_att = Memory.malloc_zeroed(24)
        self.scratch_sky_rect = Memory.malloc_zeroed(24)
        self.scratch_vp_matrix = Memory.malloc_zeroed(64)
        self.scratch_push_data = Memory.malloc_zeroed(256)
        self.scratch_camera_view = Memory.malloc_zeroed(64)
        self.scratch_camera_proj = Memory.malloc_zeroed(64)
        self.render_state = Memory.malloc_zeroed(88)
        Memory.write_i64(self.scratch_off_arr, 0)
        Memory.write_i64(self.scratch_inst_off_arr, 0)
        self.instance_culling_enabled = 0
        # GPU-driven draw: per-frame group tracking arrays (mi / outBase /
        # candidate count). Sized to FROG_CULL_MAX_GROUPS.
        self.gpu_grp_capacity = FROG_CULL_MAX_GROUPS
        self.gpu_grp_mi = Memory.malloc_zeroed((FROG_CULL_MAX_GROUPS as i64) * 4)
        self.gpu_grp_outbase = Memory.malloc_zeroed((FROG_CULL_MAX_GROUPS as i64) * 4)
        self.gpu_grp_count = Memory.malloc_zeroed((FROG_CULL_MAX_GROUPS as i64) * 4)
        self.gpu_grp_indexed = Memory.malloc_zeroed((FROG_CULL_MAX_GROUPS as i64) * 4)
        self.gpu_grp_cmd = Memory.malloc_zeroed((FROG_CULL_MAX_GROUPS as i64) * 4)
        self.gpu_grp_inbase = Memory.malloc_zeroed((FROG_CULL_MAX_GROUPS as i64) * 4)
        self.gpu_grp_draw = Memory.malloc_zeroed((FROG_CULL_MAX_GROUPS as i64) * 4)
        self.gpu_grp_n = 0
        # candidate-slot -> gi map, one entry per registered instance.
        self.gpu_cand_gi = Memory.malloc_zeroed((self.vb_capacity as i64) * 4)
        self.gpu_cand_n = 0
        self.gpu_cull_push = Memory.malloc_zeroed(FROG_CULL_PUSH_SIZE)
        self.gpu_cull_rec = Memory.malloc_zeroed(128)
        self.gpu_slot_grpn = Memory.malloc_zeroed((FROG_CULL_SLOTS as i64) * 4)
        self.gpu_slot_cmdbase = Memory.malloc_zeroed((FROG_CULL_SLOTS as i64) * 4)
        self.retire_capacity = 0
        self.retire_count = 0
        self.pooled_capacity = 2048
        self.pooled_count = 0
        self.pooled_bytes = 0
        self.pooled_byte_limit = 268435456
        self.pooled_buffers = Memory.malloc_zeroed(self.pooled_capacity * 8)
        self.pooled_memories = Memory.malloc_zeroed(self.pooled_capacity * 8)
        self.pooled_sizes = Memory.malloc_zeroed(self.pooled_capacity * 8)
        self.pooled_usages = Memory.malloc_zeroed(self.pooled_capacity * 4)
        self.frame_serial = 0
        prof: GpuProfiler = GpuProfiler()
        prof.init(device, phys_device)
        self.profiler = prof
        self.initialized = 1

    fun set_instance_culling(self, enabled: i32):
        if enabled == 0:
            self.instance_culling_enabled = 0
        else:
            self.instance_culling_enabled = 1

    # Phase 1 groundwork: record device bindless support (from GpuCaps) and
    # the user/runtime opt-in flag. Does NOT create any Vulkan objects and
    # does NOT change any rendering path — that lands in _bindless_init
    # (task 1.2) gated behind these flags. bindless_enabled only flips to 1
    # once _bindless_init succeeds.
    fun set_bindless_caps(self, supported: i32, max_array: i32, flag: i32):
        if supported == 0:
            self.bindless_supported = 0
        else:
            self.bindless_supported = 1
        cap: i32 = max_array
        if cap > 65536:
            cap = 65536
        if cap < 0:
            cap = 0
        self.bindless_capacity = cap
        if flag == 0:
            self.bindless_flag = 0
        else:
            self.bindless_flag = 1

    # Phase 1 task 1.2: create the bindless descriptor objects — ONE layout
    # with a single binding (binding 0) of COMBINED_IMAGE_SAMPLER whose
    # descriptorCount equals the table capacity, marked PARTIALLY_BOUND +
    # UPDATE_AFTER_BIND so slots can be written lazily even after the set is
    # bound. Allocates one pool + one set (the big table). Returns 1 on
    # success and flips bindless_enabled to 1; returns 0 (and leaves
    # bindless_enabled at 0 -> classic path) on any failure. Creates NO
    # pipeline and is NOT yet wired into any draw — that lands in tasks 1.5/1.6.
    fun _bindless_init(self) -> i32:
        if self.bindless_supported == 0:
            return 0
        if self.bindless_flag == 0:
            return 0
        if self.bindless_capacity <= 0:
            return 0
        if self.device == 0:
            return 0

        cap: i32 = self.bindless_capacity

        # VkDescriptorSetLayoutBinding (24 bytes): binding(0) type(4) count(8)
        # stage(12) pImmutable(16). One binding only.
        dsl_bind: i64 = Memory.malloc_zeroed(24)
        # Per-binding flags array: PARTIALLY_BOUND(4) | UPDATE_AFTER_BIND(1) = 5.
        bind_flags: i64 = Memory.malloc_zeroed(4)
        # VkDescriptorSetLayoutBindingFlagsCreateInfo (sType 1000161000):
        #  0 sType, 8 pNext, 16 bindingCount, 24 pBindingFlags
        flags_ci: i64 = Memory.malloc_zeroed(32)
        # VkDescriptorSetLayoutCreateInfo (sType 32):
        #  0 sType, 8 pNext, 16 flags, 20 bindingCount, 24 pBindings
        dsl_ci: i64 = Memory.malloc_zeroed(32)
        dsl_out: i64 = Memory.malloc_zeroed(8)
        if dsl_bind == 0 or bind_flags == 0 or flags_ci == 0 or dsl_ci == 0 or dsl_out == 0:
            Memory.free(dsl_bind)
            Memory.free(bind_flags)
            Memory.free(flags_ci)
            Memory.free(dsl_ci)
            Memory.free(dsl_out)
            return 0

        Memory.write_i32(dsl_bind, 0)        # binding 0
        Memory.write_i32(dsl_bind + 4, 1)    # COMBINED_IMAGE_SAMPLER
        Memory.write_i32(dsl_bind + 8, cap)  # descriptorCount = table capacity
        Memory.write_i32(dsl_bind + 12, 16)  # FRAGMENT stage

        Memory.write_i32(bind_flags, 5)      # PARTIALLY_BOUND | UPDATE_AFTER_BIND

        Memory.write_i32(flags_ci, 1000161000)   # BINDING_FLAGS_CREATE_INFO
        Memory.write_i32(flags_ci + 16, 1)       # bindingCount
        Memory.write_ptr(flags_ci + 24, bind_flags)

        Memory.write_i32(dsl_ci, 32)
        Memory.write_ptr(dsl_ci + 8, flags_ci)   # pNext = binding flags
        Memory.write_i32(dsl_ci + 16, 2)         # UPDATE_AFTER_BIND_POOL flag
        Memory.write_i32(dsl_ci + 20, 1)         # bindingCount
        Memory.write_ptr(dsl_ci + 24, dsl_bind)

        dsl_r: i32 = vkCreateDescriptorSetLayout(self.device, dsl_ci, 0, dsl_out)
        layout: i64 = Memory.read_ptr(dsl_out)
        Memory.free(dsl_out)
        Memory.free(dsl_ci)
        Memory.free(flags_ci)
        Memory.free(bind_flags)
        Memory.free(dsl_bind)
        if dsl_r != 0:
            print("[frog.bindless] layout creation failed; classic path")
            return 0
        self.bindless_layout = layout

        # Pool: one COMBINED_IMAGE_SAMPLER pool sized for the whole table, with
        # UPDATE_AFTER_BIND flag so descriptors can be written after binding.
        dps: i64 = Memory.malloc_zeroed(8)
        dp_ci: i64 = Memory.malloc_zeroed(40)
        dp_out: i64 = Memory.malloc_zeroed(8)
        if dps == 0 or dp_ci == 0 or dp_out == 0:
            Memory.free(dps)
            Memory.free(dp_ci)
            Memory.free(dp_out)
            return 0
        Memory.write_i32(dps, 1)             # COMBINED_IMAGE_SAMPLER
        Memory.write_i32(dps + 4, cap)       # descriptorCount
        Memory.write_i32(dp_ci, 33)
        Memory.write_i32(dp_ci + 16, 2)      # UPDATE_AFTER_BIND_BIT
        Memory.write_i32(dp_ci + 20, 1)      # maxSets = 1 (the table)
        Memory.write_i32(dp_ci + 24, 1)      # poolSizeCount
        Memory.write_ptr(dp_ci + 32, dps)
        dp_r: i32 = vkCreateDescriptorPool(self.device, dp_ci, 0, dp_out)
        pool: i64 = Memory.read_ptr(dp_out)
        Memory.free(dp_out)
        Memory.free(dp_ci)
        Memory.free(dps)
        if dp_r != 0:
            print("[frog.bindless] pool creation failed; classic path")
            return 0
        self.bindless_pool = pool

        # Allocate the single big set. VkDescriptorSetAllocateInfo (sType 34):
        #  0 sType, 8 pNext, 16 descriptorPool, 24 descriptorSetCount, 32 pSetLayouts
        layout_arr: i64 = Memory.malloc_zeroed(8)
        ai: i64 = Memory.malloc_zeroed(40)
        set_out: i64 = Memory.malloc_zeroed(8)
        if layout_arr == 0 or ai == 0 or set_out == 0:
            Memory.free(layout_arr)
            Memory.free(ai)
            Memory.free(set_out)
            return 0
        Memory.write_ptr(layout_arr, self.bindless_layout)
        Memory.write_i32(ai, 34)
        Memory.write_ptr(ai + 16, self.bindless_pool)
        Memory.write_i32(ai + 24, 1)
        Memory.write_ptr(ai + 32, layout_arr)
        ar: i32 = vkAllocateDescriptorSets(self.device, ai, set_out)
        bset: i64 = Memory.read_ptr(set_out)
        Memory.free(set_out)
        Memory.free(ai)
        Memory.free(layout_arr)
        if ar != 0:
            print("[frog.bindless] set allocation failed; classic path")
            return 0
        self.bindless_set = bset
        self.bindless_count = 0
        self.bindless_enabled = 1
        print(@"[frog.bindless] table ready (capacity={cap})")
        return 1

    # Phase 2: build the instance-SSBO descriptor sets (set 3) for the
    # GPU-driven batched draw. One set per frame slot, each a storage-buffer
    # descriptor over that slot's region of the cull output buffer. Must be
    # called after the cull buffers are allocated (ensure_capacity) AND the
    # SSBO pipeline layout exists. Returns 1 on success. ssbo_layout is the
    # RenderPass.ssbo_set_layout.
    fun _ssbo_desc_init(self, ssbo_layout: i64, cull: GpuCullPipeline) -> i32:
        if ssbo_layout == 0:
            return 0
        if cull.out_handle() == 0:
            return 0
        slot_stride: i64 = (cull.slot_capacity() as i64) * (FROG_CULL_OUT_STRIDE as i64)
        if slot_stride <= 0:
            return 0
        self.ssbo_layout_ref = ssbo_layout

        # Pool: FROG_CULL_SLOTS storage-buffer sets. Reset on rebuild so we can
        # re-allocate the sets to point at a reallocated output buffer.
        if self.ssbo_desc_pool == 0:
            ps: i64 = Memory.malloc_zeroed(8)
            dp_ci: i64 = Memory.malloc_zeroed(40)
            dp_out: i64 = Memory.malloc_zeroed(8)
            if ps == 0 or dp_ci == 0 or dp_out == 0:
                Memory.free(ps)
                Memory.free(dp_ci)
                Memory.free(dp_out)
                return 0
            Memory.write_i32(ps, 7)              # STORAGE_BUFFER
            Memory.write_i32(ps + 4, FROG_CULL_SLOTS)
            Memory.write_i32(dp_ci, 33)
            Memory.write_i32(dp_ci + 16, 1)      # FREE_DESCRIPTOR_SET (allow reset/realloc)
            Memory.write_i32(dp_ci + 20, FROG_CULL_SLOTS)   # maxSets
            Memory.write_i32(dp_ci + 24, 1)
            Memory.write_ptr(dp_ci + 32, ps)
            dp_r: i32 = vkCreateDescriptorPool(self.device, dp_ci, 0, dp_out)
            self.ssbo_desc_pool = Memory.read_ptr(dp_out)
            Memory.free(dp_out)
            Memory.free(dp_ci)
            Memory.free(ps)
            if dp_r != 0:
                return 0
            self.ssbo_desc_sets = Memory.malloc_zeroed((FROG_CULL_SLOTS as i64) * 8)
        else:
            vkResetDescriptorPool(self.device, self.ssbo_desc_pool, 0)

        # Allocate + write one set per slot, each over its output region.
        s: i32 = 0
        while s < FROG_CULL_SLOTS:
            layout_arr: i64 = Memory.malloc_zeroed(8)
            ai: i64 = Memory.malloc_zeroed(40)
            set_out: i64 = Memory.malloc_zeroed(8)
            Memory.write_ptr(layout_arr, ssbo_layout)
            Memory.write_i32(ai, 34)
            Memory.write_ptr(ai + 16, self.ssbo_desc_pool)
            Memory.write_i32(ai + 24, 1)
            Memory.write_ptr(ai + 32, layout_arr)
            ar: i32 = vkAllocateDescriptorSets(self.device, ai, set_out)
            dset: i64 = Memory.read_ptr(set_out)
            Memory.free(set_out)
            Memory.free(ai)
            Memory.free(layout_arr)
            if ar != 0:
                return 0
            Memory.write_ptr(self.ssbo_desc_sets + s * 8, dset)

            binfo: i64 = Memory.malloc_zeroed(24)
            wds: i64 = Memory.malloc_zeroed(64)
            Memory.write_ptr(binfo, cull.out_handle())
            Memory.write_i64(binfo + 8, (s as i64) * slot_stride)   # offset
            Memory.write_i64(binfo + 16, slot_stride)               # range
            Memory.write_i32(wds, 35)
            Memory.write_ptr(wds + 16, dset)
            Memory.write_i32(wds + 24, 0)        # binding 0
            Memory.write_i32(wds + 32, 1)        # count
            Memory.write_i32(wds + 36, 7)        # STORAGE_BUFFER
            Memory.write_ptr(wds + 48, binfo)    # pBufferInfo
            vkUpdateDescriptorSets(self.device, 1, wds, 0, 0)
            Memory.free(wds)
            Memory.free(binfo)
            s = s + 1
        self.ssbo_draw_enabled = 1
        self.ssbo_desc_outbuf = cull.out_handle()
        print("[frog.bindless] SSBO instance pipeline ready")
        return 1

    # Phase 1 task 1.3: write a (view, sampler) pair into the next free slot
    # of the bindless table and return its index. Uses dstArrayElement = slot
    # with descriptorCount = 1, COMBINED_IMAGE_SAMPLER, layout
    # SHADER_READ_ONLY_OPTIMAL. UPDATE_AFTER_BIND lets us write even while the
    # set is bound. Returns -1 if bindless is disabled, the table is full, or
    # the inputs are null — callers keep their classic descriptor as fallback.
    fun _bindless_register(self, view: i64, sampler: i64) -> i32:
        if self.bindless_enabled == 0:
            return 0 - 1
        if self.bindless_set == 0:
            return 0 - 1
        if view == 0:
            return 0 - 1
        if sampler == 0:
            return 0 - 1
        if self.bindless_count >= self.bindless_capacity:
            return 0 - 1
        slot: i32 = self.bindless_count

        # VkDescriptorImageInfo (24): sampler(0) imageView(8) imageLayout(16).
        img_info: i64 = Memory.malloc_zeroed(24)
        # VkWriteDescriptorSet (64): sType(0) pNext(8) dstSet(16) dstBinding(24)
        #  dstArrayElement(28) descriptorCount(32) descriptorType(36)
        #  pImageInfo(40) pBufferInfo(48) pTexelBufferView(56).
        wds: i64 = Memory.malloc_zeroed(64)
        if img_info == 0 or wds == 0:
            Memory.free(img_info)
            Memory.free(wds)
            return 0 - 1
        Memory.write_ptr(img_info, sampler)
        Memory.write_ptr(img_info + 8, view)
        Memory.write_i32(img_info + 16, 5)       # SHADER_READ_ONLY_OPTIMAL
        Memory.write_i32(wds, 35)                # WRITE_DESCRIPTOR_SET
        Memory.write_ptr(wds + 16, self.bindless_set)
        Memory.write_i32(wds + 24, 0)            # dstBinding = 0
        Memory.write_i32(wds + 28, slot)         # dstArrayElement = slot
        Memory.write_i32(wds + 32, 1)            # descriptorCount
        Memory.write_i32(wds + 36, 1)            # COMBINED_IMAGE_SAMPLER
        Memory.write_ptr(wds + 40, img_info)
        vkUpdateDescriptorSets(self.device, 1, wds, 0, 0)
        Memory.free(wds)
        Memory.free(img_info)
        self.bindless_count = slot + 1
        return slot

    # Enable GPU-driven culling for the main pass. cull_ptr is a borrowed
    # GpuCullPipeline (owned by the runtime). When enabled and the pipeline
    # is ready, each mesh group culls + draws on the GPU via indirect draw.
    fun set_gpu_culling(self, enabled: i32, cull_ptr: i64):
        self.gpu_cull_ptr = cull_ptr
        if enabled == 0:
            self.gpu_culling_enabled = 0
        else:
            self.gpu_culling_enabled = 1

    # Phase 3 step 2: toggle the GPU-driven indirect DRAW path for the main
    # pass. Requires set_gpu_culling to have provided the pipeline. Default
    # off; the CPU draw path stays the safe fallback.
    fun set_gpu_draw(self, enabled: i32):
        if enabled == 0:
            self.gpu_draw_enabled = 0
        else:
            self.gpu_draw_enabled = 1

    # Public culling-mode API. mode: 0 = CPU, 1 = GPU, 2 = Auto.
    # GPU/Auto require a ready GpuCullPipeline (set_gpu_culling). If the
    # pipeline is not ready, falls back to CPU with a warning.
    fun set_culling_mode(self, mode: i32):
        m: i32 = mode
        if m < 0:
            m = 0
        if m > 2:
            m = 0
        if m != 0:
            ready: i32 = 0
            if self.gpu_cull_ptr != 0:
                cull: GpuCullPipeline = self.gpu_cull_ptr as GpuCullPipeline
                ready = cull.ready
            if ready == 0:
                print("[frog.cull] GPU culling not ready; CPU fallback")
                m = 0
        self.culling_mode = m

    # Threshold (instance count) above which Auto mode uses the GPU path.
    fun set_culling_auto_threshold(self, threshold: i32):
        if threshold < 1:
            self.culling_auto_threshold = 1
        else:
            self.culling_auto_threshold = threshold

    # Resolve culling_mode to the effective gpu_draw_enabled for this frame.
    # CPU(0) -> 0; GPU(1) -> 1; Auto(2) -> 1 when vb_count >= threshold.
    fun _resolve_culling_mode(self):
        if self.culling_mode == 0:
            self.gpu_draw_enabled = 0
        elif self.culling_mode == 1:
            self.gpu_draw_enabled = 1
        else:
            if self.vb_count >= self.culling_auto_threshold:
                self.gpu_draw_enabled = 1
            else:
                self.gpu_draw_enabled = 0

    # Debug: enable per-frame GPU-vs-CPU visible-count printing (CPU mode).
    fun set_gpu_cull_verify(self, enabled: i32):
        if enabled == 0:
            self.gpu_cull_verify_enabled = 0
        else:
            self.gpu_cull_verify_enabled = 1

    # PHASE 3 STEP 1 (verification, no rendering change): run the GPU cull
    # over the whole scene in parallel with the CPU and print how many
    # instances each side considers visible. If they match on the real
    # scene, the GPU cull logic is correct and we can switch the draw.
    # cmd_pool from the render pass; vp_mat = proj*view (column-major).
    fun gpu_cull_verify(self, cmd_pool: i64, vp_mat: i64):
        if self.gpu_cull_ptr == 0:
            return
        if vp_mat == 0:
            return
        cull: GpuCullPipeline = self.gpu_cull_ptr as GpuCullPipeline
        if cull.ready == 0:
            return
        if self.vb_count <= 0:
            return
        if cull.ensure_capacity(self.vb_count) == 0:
            return

        # Upload every registered instance (model + bounds) as a candidate.
        # material/uv are irrelevant for the count, so write_instance (zeros
        # them) is fine here.
        i: i32 = 0
        cand: i32 = 0
        while i < self.vb_count:
            model_ptr: i64 = 0
            if self.model_matrices != 0:
                model_ptr = Memory.read_ptr(self.model_matrices + i * 8)
            if model_ptr != 0:
                bx: f32 = 0.0
                by: f32 = 0.0
                bz: f32 = 0.0
                br: f32 = 8.0
                if self.mesh_bound_rs != 0:
                    bx = Memory.read_f32(self.mesh_bound_xs + i * 4)
                    by = Memory.read_f32(self.mesh_bound_ys + i * 4)
                    bz = Memory.read_f32(self.mesh_bound_zs + i * 4)
                    br = Memory.read_f32(self.mesh_bound_rs + i * 4)
                    if br <= 0.0:
                        br = 8.0
                cull.write_instance(cand, model_ptr, bx, by, bz, br)
                cand = cand + 1
            i = i + 1

        # Build push constants: extract frustum planes from VP + candidate count.
        push: i64 = Memory.malloc_zeroed(FROG_CULL_PUSH_SIZE)
        frog_cull_extract_planes(vp_mat, push)
        Memory.write_i32(push + 96, cand)

        cull.prepare_group_cmd(0, 36, 0)
        cmd: i64 = gpu_tex_begin_oneshot(self.device, cmd_pool)
        if cmd == 0:
            Memory.free(push)
            return
        cull.dispatch_group(cmd, cand, 0, 0, 0, push)
        cull.barrier_after_dispatches(cmd)
        gpu_tex_end_oneshot(self.device, cmd_pool, self.gfx_queue, cmd)
        Memory.free(push)

        gpu_visible: i32 = cull.group_visible_count(0)
        print(@"[frog.cull] scene cull: candidates={cand} gpu_visible={gpu_visible}")

    # GPU-driven culling pre-pass. Persistent-input architecture:
    #   - The candidate records are uploaded to the GPU ONCE (and re-packed
    #     only when the scene is marked dirty), NOT every frame. This removes
    #     the per-frame CPU pack/copy of all instances (the real bottleneck
    #     at high instance counts).
    #   - Per frame we only: fill each group's output range, prepare its
    #     indirect command, and record the cull dispatch (reading the
    #     persistent input). Output + indirect are slot-partitioned.
    # `slot` selects the output/command partition. vp_mat is proj*view.
    fun gpu_precull_main(self, cmd: i64, vp_mat: i64, slot: i32) -> i32:
        if self.gpu_cull_ptr == 0:
            return 0
        if vp_mat == 0:
            return 0
        cull: GpuCullPipeline = self.gpu_cull_ptr as GpuCullPipeline
        if cull.ready == 0:
            return 0
        if self.vb_count <= 0:
            return 0
        if cull.ensure_capacity(self.vb_count) == 0:
            return 0

        self.gpu_cull_slot = slot

        # (Re)build the persistent candidate buffer + group metadata only when
        # the scene STRUCTURE changed (instances added/removed/visibility/
        # material). ensure_capacity sets dirty on (re)allocation. If only the
        # transforms moved (xform_dirty), take the cheap in-place refresh that
        # rewrites just the model matrices — no regroup/repack.
        if cull.is_dirty() == 1:
            self._gpu_cull_rebuild(cull)
            cull.clear_dirty(self.gpu_grp_n)
            cull.clear_xform_dirty()
        elif cull.is_xform_dirty() == 1:
            self._gpu_cull_refresh_transforms(cull)
            cull.clear_xform_dirty()

        cmd_base0: i32 = cull.slot_cmd_base(slot)   # this slot's command base
        out_base0: i32 = cull.slot_out_base(slot)   # this slot's output base

        # Frustum planes (cheap, per frame).
        push: i64 = self.gpu_cull_push
        Memory.set(push, 0, FROG_CULL_PUSH_SIZE)
        frog_cull_extract_planes(vp_mat, push)

        # Ensure the CPU's per-frame writes to the host-mapped input + indirect
        # buffers are visible to the compute pass before it dispatches (fixes
        # NVIDIA-only flicker from a host-write/compute-read race).
        cull.barrier_before_dispatches(cmd)

        # Per frame: dispatch each cached group reading the persistent input.
        out_cursor: i32 = out_base0
        g: i32 = 0
        while g < self.gpu_grp_n:
            in_base: i32 = Memory.read_i32(self.gpu_grp_inbase + g * 4)
            group_n: i32 = Memory.read_i32(self.gpu_grp_count + g * 4)
            indexed: i32 = Memory.read_i32(self.gpu_grp_indexed + g * 4)
            draw_count: i32 = Memory.read_i32(self.gpu_grp_draw + g * 4)
            cmd_index: i32 = cmd_base0 + g
            out_base: i32 = out_cursor
            cull.prepare_group_cmd(cmd_index, draw_count, indexed)
            # firstInstance stays 0 (prepare_group_cmd zeroed it). The active
            # per-group draw binds the instance buffer at out_base directly, so
            # it must be 0. (Only the disabled SSBO batched path would set it.)
            # NOTE: no full out_buffer clear here. The indirect draw reads only
            # instanceCount visible records (slots 0..count-1, written densely
            # by the compute compaction), so stale tail data is never drawn.
            # prepare_group_cmd already zeroes instanceCount. (vkCmdFillBuffer
            # of the whole output was ~9.8MB/frame at 100K — removed.)
            cull.dispatch_group(cmd, group_n, in_base, out_base, cmd_index, push)
            # Cache this slot's per-group draw bindings for gpu_draw_main.
            Memory.write_i32(self.gpu_grp_outbase + g * 4, out_base)
            Memory.write_i32(self.gpu_grp_cmd + g * 4, cmd_index)
            out_cursor = out_cursor + group_n
            g = g + 1

        cull.barrier_after_dispatches(cmd)
        Memory.write_i32(self.gpu_slot_grpn + slot * 4, self.gpu_grp_n)
        Memory.write_i32(self.gpu_slot_cmdbase + slot * 4, cmd_base0)
        return self.gpu_grp_n

    # Rebuild the persistent candidate input buffer + group metadata from the
    # current mesh registry. Runs ONLY when the scene is dirty (instances
    # added/removed/moved), NOT every frame. Mirrors the CPU grouping keys so
    # the GPU output matches the CPU draw path visually.
    fun _gpu_cull_rebuild(self, cull: GpuCullPipeline):
        # Ensure the candidate->gi map can hold every registered instance
        # (grows with the vb arrays).
        if self.gpu_cand_gi == 0:
            self.gpu_cand_gi = Memory.malloc_zeroed((self.vb_capacity as i64) * 4)
        self.gpu_grp_n = 0
        in_cursor: i32 = 0          # next slot in the persistent input buffer
        grp: i32 = 0
        mi: i32 = 0
        while mi < self.vb_count:
            vb_handle: i64 = Memory.read_ptr(self.vb_handles + mi * 8)
            vc: i32 = Memory.read_i32(self.vb_vert_counts + mi * 4)
            ib_handle: i64 = Memory.read_ptr(self.ib_handles + mi * 8)
            ic: i32 = Memory.read_i32(self.ib_index_counts + mi * 4)
            model_ptr: i64 = 0
            if self.model_matrices != 0:
                model_ptr = Memory.read_ptr(self.model_matrices + mi * 8)
            if vb_handle == 0 or vc <= 0 or model_ptr == 0:
                mi = mi + 1
            else:
                indexed: i32 = 0
                if ib_handle != 0:
                    if ic > 0:
                        indexed = 1
                group_in_base: i32 = in_cursor
                group_n: i32 = 0
                g_tex0: i32 = self._grp_tex(self.mesh_tex_ids, mi)
                g_emi0: i32 = self._grp_tex(self.mesh_emissive_tex_ids, mi)
                g_nrm0: i32 = self._grp_tex(self.mesh_normal_tex_ids, mi)
                g_mr0: i32 = self._grp_tex(self.mesh_metallic_roughness_tex_ids, mi)
                g_occ0: i32 = self._grp_tex(self.mesh_occlusion_tex_ids, mi)
                gi: i32 = mi
                group_span: i32 = 0
                while gi < self.vb_count:
                    g_vb: i64 = Memory.read_ptr(self.vb_handles + gi * 8)
                    g_vc: i32 = Memory.read_i32(self.vb_vert_counts + gi * 4)
                    g_ib: i64 = Memory.read_ptr(self.ib_handles + gi * 8)
                    g_ic: i32 = Memory.read_i32(self.ib_index_counts + gi * 4)
                    g_model: i64 = Memory.read_ptr(self.model_matrices + gi * 8)
                    if g_vb != vb_handle:
                        gi = self.vb_count
                    elif g_vc != vc:
                        gi = self.vb_count
                    elif g_ib != ib_handle:
                        gi = self.vb_count
                    elif g_ic != ic:
                        gi = self.vb_count
                    elif self._grp_tex(self.mesh_tex_ids, gi) != g_tex0:
                        gi = self.vb_count
                    elif self._grp_tex(self.mesh_emissive_tex_ids, gi) != g_emi0:
                        gi = self.vb_count
                    elif self._grp_tex(self.mesh_normal_tex_ids, gi) != g_nrm0:
                        gi = self.vb_count
                    elif self._grp_tex(self.mesh_metallic_roughness_tex_ids, gi) != g_mr0:
                        gi = self.vb_count
                    elif self._grp_tex(self.mesh_occlusion_tex_ids, gi) != g_occ0:
                        gi = self.vb_count
                    elif g_model == 0:
                        gi = self.vb_count
                    else:
                        vis: i32 = 1
                        if self.vb_visible != 0:
                            if Memory.read_i32(self.vb_visible + gi * 4) == 0:
                                vis = 0
                        if vis == 1:
                            self._cull_upload_instance(cull, in_cursor, gi, g_model)
                            Memory.write_i32(self.gpu_cand_gi + in_cursor * 4, gi)
                            in_cursor = in_cursor + 1
                            group_n = group_n + 1
                        group_span = group_span + 1
                        gi = gi + 1

                if group_n > 0:
                    if grp < FROG_CULL_MAX_GROUPS:
                        draw_count: i32 = ic
                        if indexed == 0:
                            draw_count = vc
                        Memory.write_i32(self.gpu_grp_mi + grp * 4, mi)
                        Memory.write_i32(self.gpu_grp_inbase + grp * 4, group_in_base)
                        Memory.write_i32(self.gpu_grp_count + grp * 4, group_n)
                        Memory.write_i32(self.gpu_grp_indexed + grp * 4, indexed)
                        Memory.write_i32(self.gpu_grp_draw + grp * 4, draw_count)
                        grp = grp + 1
                if group_span > 0:
                    mi = mi + group_span
                else:
                    mi = mi + 1
        self.gpu_grp_n = grp
        self.gpu_cand_n = in_cursor

    # Transform-only refresh: instances merely MOVED (structure unchanged),
    # so rewrite ONLY the 64-byte model matrix of each existing candidate
    # in place — no regroup, no material/uv/bounds recompute. This is the
    # hot path for a swarm of moving objects: O(N) tiny copies instead of
    # the full O(N x grouping) rebuild. Parallelized across the thread pool
    # (each candidate slot is independent -> race-free), so it also overlaps
    # the CPU cost across cores while the GPU culls + draws.
    fun _gpu_cull_refresh_transforms(self, cull: GpuCullPipeline):
        n: i32 = self.gpu_cand_n
        if n <= 0:
            return
        g_refresh_cand_gi = self.gpu_cand_gi
        g_refresh_models = self.model_matrices
        g_refresh_cull = cull as i64
        body: @heap fun(i32) = fun(k: i32) _gpu_cull_refresh_one(k)
        engine_parallel_for(n, body)

    # Read texture-id array `arr` at index i (returns -1 when array unset).
    fun _grp_tex(self, arr: i64, i: i32) -> i32:
        if arr == 0:
            return 0 - 1
        return Memory.read_i32(arr + i * 4)

    # Mark the persistent GPU cull input as needing only a TRANSFORM refresh
    # (an instance MOVED; structure intact). The next precull rewrites just
    # the model matrices in place — cheap. Used by set_transform / set_model_
    # matrix_raw on the movement hot path. No-op when no cull pipeline.
    fun _mark_cull_dirty(self):
        if self.gpu_cull_ptr != 0:
            cull: GpuCullPipeline = self.gpu_cull_ptr as GpuCullPipeline
            cull.mark_xform_dirty()

    # Mark the persistent GPU cull input as needing a FULL rebuild (scene
    # STRUCTURE changed: instance added/removed, visibility/material change),
    # so the next precull regroups + repacks the candidate buffer.
    fun _mark_cull_dirty_struct(self):
        if self.gpu_cull_ptr != 0:
            cull: GpuCullPipeline = self.gpu_cull_ptr as GpuCullPipeline
            cull.mark_dirty()

    # Phase 1 bindless: resolve a mesh's 5 material texture ids to bindless
    # table slots and write them into the instance record's texidx block
    # (offset 96..). A texture id of -1 (no map) resolves to the white
    # fallback's slot so the shader can always sample. When bindless is
    # disabled the block stays 0 and the classic shader ignores it.
    fun _write_record_texidx(self, rec: i64, gi: i32):
        white_slot: i32 = 0
        if self.white_tex_id >= 0:
            if self.tex_bindless_slots != 0:
                white_slot = Memory.read_i32(self.tex_bindless_slots + self.white_tex_id * 4)
                if white_slot < 0:
                    white_slot = 0
        albedo: i32 = self._mesh_bindless_slot(self.mesh_tex_ids, gi, white_slot)
        emissive: i32 = self._mesh_bindless_slot(self.mesh_emissive_tex_ids, gi, white_slot)
        normal: i32 = self._mesh_bindless_slot(self.mesh_normal_tex_ids, gi, white_slot)
        mr: i32 = self._mesh_bindless_slot(self.mesh_metallic_roughness_tex_ids, gi, white_slot)
        occ: i32 = self._mesh_bindless_slot(self.mesh_occlusion_tex_ids, gi, white_slot)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET, albedo)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET + 4, emissive)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET + 8, normal)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET + 12, mr)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET + 16, occ)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET + 20, 0)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET + 24, 0)
        Memory.write_i32(rec + FROG_GPU_INSTANCE_TEXIDX_OFFSET + 28, 0)

    # Resolve mesh gi's texture id from a mesh->tex_id array into a bindless
    # slot, falling back to `fallback_slot` when the id is missing/-1.
    fun _mesh_bindless_slot(self, id_array: i64, gi: i32, fallback_slot: i32) -> i32:
        if id_array == 0:
            return fallback_slot
        tex_id: i32 = Memory.read_i32(id_array + gi * 4)
        if tex_id < 0:
            return fallback_slot
        if self.tex_bindless_slots == 0:
            return fallback_slot
        if tex_id >= self.tex_count:
            return fallback_slot
        slot: i32 = Memory.read_i32(self.tex_bindless_slots + tex_id * 4)
        if slot < 0:
            return fallback_slot
        return slot

    # Upload mesh `gi`'s instance record (model + material + uv) and bounding
    # sphere into the cull input buffer at slot `dst_idx`.
    fun _cull_upload_instance(self, cull: GpuCullPipeline, dst_idx: i32, gi: i32, g_model: i64):
        bx: f32 = 0.0
        by: f32 = 0.0
        bz: f32 = 0.0
        br: f32 = 8.0
        if self.mesh_bound_rs != 0:
            bx = Memory.read_f32(self.mesh_bound_xs + gi * 4)
            by = Memory.read_f32(self.mesh_bound_ys + gi * 4)
            bz = Memory.read_f32(self.mesh_bound_zs + gi * 4)
            br = Memory.read_f32(self.mesh_bound_rs + gi * 4)
            if br <= 0.0:
                br = 8.0
        rec: i64 = self.gpu_cull_rec
        Memory.copy(rec, g_model, 64)
        # Material + uv: mirror the CPU path exactly.
        if self.mesh_material_params != 0:
            Memory.copy(rec + FROG_GPU_INSTANCE_MATERIAL_OFFSET, self.mesh_material_params + gi * 32, 32)
        else:
            Memory.write_f32(rec + FROG_GPU_INSTANCE_MATERIAL_OFFSET, 0.0)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 4, 1.0)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 8, 0.0)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 12, 0.0)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_UV_OFFSET, 1.0)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_UV_OFFSET + 4, 1.0)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_UV_OFFSET + 8, 0.0)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_UV_OFFSET + 12, 0.0)
        # Shadow-receive bit packed into material.w (matches CPU path).
        receive_shadow: i32 = 1
        if self.mesh_shadow_flags != 0:
            shadow_flags: i32 = Memory.read_i32(self.mesh_shadow_flags + gi * 4)
            receive_shadow = (shadow_flags / 2) - (shadow_flags / 4) * 2
        if receive_shadow == 1:
            packed_material: f32 = Memory.read_f32(rec + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 12)
            Memory.write_f32(rec + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 12, packed_material + 65536.0)
        self._write_record_texidx(rec, gi)
        cull.write_full_instance(dst_idx, rec, bx, by, bz, br)

    # In-pass indirect draw. Issues GPU-driven indirect draws from the culled
    # output. When bindless is enabled, uses the global texture table (no
    # per-group descriptor binds) and vkCmdDrawIndexedIndirectCount; groups
    # sharing the same VB/IB are batched into ONE indirect-count submission so
    # the CPU-side draw-call count is per-batch, not per-group (R2). Falls back
    # to the classic per-group vkCmdDrawIndexedIndirect loop otherwise.
    # Must run INSIDE the active render pass with the pipeline bound.
    fun gpu_draw_main(self, cmd: i64, rp: RenderPass):
        if self.gpu_cull_ptr == 0:
            return
        cull: GpuCullPipeline = self.gpu_cull_ptr as GpuCullPipeline
        out_buf: i64 = cull.out_handle()
        ind_buf: i64 = cull.indirect_handle()
        if out_buf == 0 or ind_buf == 0:
            return

        # Path selection. NOTE: the SSBO+gl_InstanceIndex batched path (below,
        # currently DISABLED) relies on firstInstance>0 indexing, which this
        # NVIDIA driver does not honor in practice (both the attribute-fetch and
        # the gl_InstanceIndex variants made non-first groups read instance 0's
        # data — the car appeared at random bot positions). Until that's root-
        # caused (likely drawIndirectFirstInstance not effectively enabled), we
        # use the proven per-group indirect-count path: the GPU still decides
        # the draw count + per-command instanceCount with no CPU round-trip.
        dc_buf: i64 = cull.draw_count_handle()
        ssbo_batch_path: i32 = 0   # disabled pending firstInstance root-cause
        if ssbo_batch_path == 1:
            if rp.ssbo_pipeline != 0:
                if self.bindless_enabled == 1:
                    if dc_buf != 0:
                        if self.ssbo_desc_outbuf != cull.out_handle():
                            self._ssbo_desc_init(rp.ssbo_set_layout, cull)
            if self.ssbo_draw_enabled == 1:
                if rp.ssbo_pipeline != 0:
                    if dc_buf != 0:
                        if self.ssbo_desc_sets != 0:
                            if self.ssbo_desc_outbuf == cull.out_handle():
                                self._gpu_draw_ssbo_batched(cmd, rp, cull, ind_buf, dc_buf)
                                return

        use_count: i32 = 0
        if self.bindless_enabled == 1:
            if rp.bindless_pipeline != 0:
                if dc_buf != 0:
                    use_count = 1

        if use_count == 1:
            self._gpu_draw_indirect_count(cmd, cull, out_buf, ind_buf, dc_buf)
            return

        last_vb: i64 = 0
        last_index_bound: i64 = 0
        last_desc: i64 = 0
        g: i32 = 0
        while g < self.gpu_grp_n:
            mi: i32 = Memory.read_i32(self.gpu_grp_mi + g * 4)
            out_base: i32 = Memory.read_i32(self.gpu_grp_outbase + g * 4)
            indexed: i32 = Memory.read_i32(self.gpu_grp_indexed + g * 4)
            cmd_index: i32 = Memory.read_i32(self.gpu_grp_cmd + g * 4)
            vb_handle: i64 = Memory.read_ptr(self.vb_handles + mi * 8)
            ib_handle: i64 = Memory.read_ptr(self.ib_handles + mi * 8)

            if vb_handle != last_vb:
                Memory.write_ptr(self.scratch_vb_arr, vb_handle)
                vkCmdBindVertexBuffers(cmd, 0, 1, self.scratch_vb_arr, self.scratch_off_arr)
                last_vb = vb_handle

            # Instance buffer = GPU-culled output. Bind at the group's byte
            # offset (out_base * stride) and keep the indirect command's
            # firstInstance=0, so we don't need drawIndirectFirstInstance.
            Memory.write_ptr(self.scratch_inst_vb_arr, out_buf)
            Memory.write_i64(self.scratch_inst_off_arr, (out_base as i64) * (FROG_CULL_OUT_STRIDE as i64))
            vkCmdBindVertexBuffers(cmd, 1, 1, self.scratch_inst_vb_arr, self.scratch_inst_off_arr)

            grp_desc: i64 = self.mesh_descriptor_set(rp, mi)
            if grp_desc != 0:
                if grp_desc != last_desc:
                    Memory.write_ptr(self.scratch_desc_arr, grp_desc)
                    vkCmdBindDescriptorSets(cmd, 0, rp.vk_pipeline_layout, 0, 1, self.scratch_desc_arr, 0, 0)
                    last_desc = grp_desc

            cmd_off: i64 = cull.group_cmd_offset(cmd_index)
            if indexed == 1:
                if ib_handle != last_index_bound:
                    vkCmdBindIndexBuffer(cmd, ib_handle, 0, 1)
                    last_index_bound = ib_handle
                vkCmdDrawIndexedIndirect(cmd, ind_buf, cmd_off, 1, 20)
            else:
                vkCmdDrawIndirect(cmd, ind_buf, cmd_off, 1, 16)
            g = g + 1

    # R2 bindless + indirect-count draw. Each group binds the culled-output
    # instance buffer at ITS OWN out_base (firstInstance stays 0, exactly like
    # the proven classic path) and issues one vkCmdDrawIndexedIndirectCount
    # with a per-group draw-count of 1. The GPU still decides how many
    # instances to draw (instanceCount, written by the cull compaction) and
    # reads the draw count from the count buffer — no CPU round-trip. The
    # texture table (set 2) + set 0 (shadow) are bound once by the caller
    # (bindless), so there are NO per-group descriptor binds. We do NOT rely on
    # firstInstance>0 (drawIndirectFirstInstance fetch offset proved unreliable
    # on this driver — it made non-first groups read instance 0's data).
    fun _gpu_draw_indirect_count(self, cmd: i64, cull: GpuCullPipeline, out_buf: i64, ind_buf: i64, dc_buf: i64):
        last_vb: i64 = 0
        last_index_bound: i64 = 0
        g: i32 = 0
        while g < self.gpu_grp_n:
            mi: i32 = Memory.read_i32(self.gpu_grp_mi + g * 4)
            indexed: i32 = Memory.read_i32(self.gpu_grp_indexed + g * 4)
            cmd_index: i32 = Memory.read_i32(self.gpu_grp_cmd + g * 4)
            out_base: i32 = Memory.read_i32(self.gpu_grp_outbase + g * 4)
            vb_handle: i64 = Memory.read_ptr(self.vb_handles + mi * 8)
            ib_handle: i64 = Memory.read_ptr(self.ib_handles + mi * 8)

            if vb_handle != last_vb:
                Memory.write_ptr(self.scratch_vb_arr, vb_handle)
                vkCmdBindVertexBuffers(cmd, 0, 1, self.scratch_vb_arr, self.scratch_off_arr)
                last_vb = vb_handle

            # Instance buffer = this group's compacted output slice. Bind at the
            # group byte offset; the command's firstInstance is 0.
            Memory.write_ptr(self.scratch_inst_vb_arr, out_buf)
            Memory.write_i64(self.scratch_inst_off_arr, (out_base as i64) * (FROG_CULL_OUT_STRIDE as i64))
            vkCmdBindVertexBuffers(cmd, 1, 1, self.scratch_inst_vb_arr, self.scratch_inst_off_arr)

            # draw-count = 1 command for this group; the GPU still decides the
            # instanceCount inside it (set by the cull compaction).
            cull.set_draw_count(g, 1)
            cmd_off: i64 = cull.group_cmd_offset(cmd_index)
            dc_off: i64 = cull.draw_count_offset(g)
            if indexed == 1:
                if ib_handle != last_index_bound:
                    vkCmdBindIndexBuffer(cmd, ib_handle, 0, 1)
                    last_index_bound = ib_handle
            vkCmdDrawIndexedIndirectCount(cmd, ind_buf, cmd_off, dc_buf, dc_off, 1, 20)
            g = g + 1

    # R2 strongest path: GPU-driven SSBO batched draw. Binds the SSBO pipeline
    # (instance data via gl_InstanceIndex from set 3) and draws all groups that
    # share VB/IB under ONE vkCmdDrawIndexedIndirectCount per batch. Each group
    # command's firstInstance (set in precull) offsets gl_InstanceIndex into
    # the slot's instance region — correct because gl_InstanceIndex includes
    # firstInstance (Vulkan spec), unlike the attribute-fetch path.
    fun _gpu_draw_ssbo_batched(self, cmd: i64, rp: RenderPass, cull: GpuCullPipeline, ind_buf: i64, dc_buf: i64):
        layout: i64 = rp.ssbo_pipeline_layout
        vkCmdBindPipeline(cmd, 0, rp.ssbo_pipeline)
        # Rebind sets under the SSBO layout: 0 (shadow sampler), 2 (texture
        # table), 3 (instance SSBO for this frame slot). Set 1 (lights) carries
        # over from the compatible bindless layout binding.
        set0: i64 = self.white_desc_set
        if set0 == 0:
            set0 = self.mesh_descriptor_set(rp, 0)
        if set0 != 0:
            Memory.write_ptr(self.scratch_desc_arr, set0)
            vkCmdBindDescriptorSets(cmd, 0, layout, 0, 1, self.scratch_desc_arr, 0, 0)
        if self.bindless_set != 0:
            Memory.write_ptr(self.scratch_desc_arr, self.bindless_set)
            vkCmdBindDescriptorSets(cmd, 0, layout, 2, 1, self.scratch_desc_arr, 0, 0)
        slot: i32 = self.gpu_cull_slot
        if slot < 0:
            slot = 0
        if slot >= FROG_CULL_SLOTS:
            slot = 0
        ssbo_set: i64 = Memory.read_ptr(self.ssbo_desc_sets + slot * 8)
        if ssbo_set != 0:
            Memory.write_ptr(self.scratch_desc_arr, ssbo_set)
            vkCmdBindDescriptorSets(cmd, 0, layout, 3, 1, self.scratch_desc_arr, 0, 0)
        # Re-bind lights (set 1) under this layout for correctness.
        light_slot: i32 = self.current_frame
        if light_slot < 0:
            light_slot = 0
        if light_slot > 1:
            light_slot = 1
        if self.point_light_desc_sets != 0:
            pl_desc: i64 = Memory.read_ptr(self.point_light_desc_sets + light_slot * 8)
            if pl_desc != 0:
                Memory.write_ptr(self.scratch_desc_arr, pl_desc)
                vkCmdBindDescriptorSets(cmd, 0, layout, 1, 1, self.scratch_desc_arr, 0, 0)
        # Re-push the constants under the SSBO layout (already filled in
        # scratch_push_data by the caller this frame).
        if self.scratch_push_data != 0:
            vkCmdPushConstants(cmd, layout, 17, 0, 128, self.scratch_push_data)

        last_vb: i64 = 0
        last_index_bound: i64 = 0
        g: i32 = 0
        batch: i32 = 0
        while g < self.gpu_grp_n:
            mi: i32 = Memory.read_i32(self.gpu_grp_mi + g * 4)
            indexed: i32 = Memory.read_i32(self.gpu_grp_indexed + g * 4)
            cmd_index: i32 = Memory.read_i32(self.gpu_grp_cmd + g * 4)
            vb_handle: i64 = Memory.read_ptr(self.vb_handles + mi * 8)
            ib_handle: i64 = Memory.read_ptr(self.ib_handles + mi * 8)

            # Extend the batch while VB/IB/indexed match and commands stay
            # contiguous (cmd_index increments by 1 per group in a slot).
            batch_end: i32 = g + 1
            while batch_end < self.gpu_grp_n:
                nmi: i32 = Memory.read_i32(self.gpu_grp_mi + batch_end * 4)
                nidx: i32 = Memory.read_i32(self.gpu_grp_indexed + batch_end * 4)
                ncmd: i32 = Memory.read_i32(self.gpu_grp_cmd + batch_end * 4)
                nvb: i64 = Memory.read_ptr(self.vb_handles + nmi * 8)
                nib: i64 = Memory.read_ptr(self.ib_handles + nmi * 8)
                if nvb != vb_handle:
                    batch_end = self.gpu_grp_n
                elif nib != ib_handle:
                    batch_end = self.gpu_grp_n
                elif nidx != indexed:
                    batch_end = self.gpu_grp_n
                elif ncmd != cmd_index + (batch_end - g):
                    batch_end = self.gpu_grp_n
                else:
                    batch_end = batch_end + 1
            group_count: i32 = batch_end - g

            if vb_handle != last_vb:
                Memory.write_ptr(self.scratch_vb_arr, vb_handle)
                vkCmdBindVertexBuffers(cmd, 0, 1, self.scratch_vb_arr, self.scratch_off_arr)
                last_vb = vb_handle

            cull.set_draw_count(batch, group_count)
            cmd_off: i64 = cull.group_cmd_offset(cmd_index)
            dc_off: i64 = cull.draw_count_offset(batch)
            if indexed == 1:
                if ib_handle != last_index_bound:
                    vkCmdBindIndexBuffer(cmd, ib_handle, 0, 1)
                    last_index_bound = ib_handle
            vkCmdDrawIndexedIndirectCount(cmd, ind_buf, cmd_off, dc_buf, dc_off, group_count, 20)
            batch = batch + 1
            g = batch_end

    fun set_directional_light(self, light_ptr: i64):
        if self.render_state == 0:
            return
        Memory.write_ptr(self.render_state, light_ptr)

    fun set_point_lights(self, light_ptrs: i64, count: i32):
        self.point_light_ptrs = light_ptrs
        self.point_light_count = count
        if self.point_light_count < 0:
            self.point_light_count = 0
        if self.point_light_count > FROG_POINT_LIGHT_SLOTS:
            self.point_light_count = FROG_POINT_LIGHT_SLOTS

    fun set_shadow_camera(self, x: f32, y: f32, z: f32, pitch: f32, yaw: f32):
        if self.render_state == 0:
            return
        Memory.write_f32(self.render_state + 64, x)
        Memory.write_f32(self.render_state + 68, y)
        Memory.write_f32(self.render_state + 72, z)
        Memory.write_f32(self.render_state + 76, pitch)
        Memory.write_f32(self.render_state + 80, yaw)

    fun set_render_stats(self, enabled: i32):
        if enabled == 0:
            self.debug_render_stats_enabled = 0
        else:
            self.debug_render_stats_enabled = 1
            self.debug_frame_count = 0
            self.debug_draw_calls = 0
            self.debug_indexed_draw_calls = 0
            self.debug_visible_instances = 0

    # Enable/disable GPU timestamp profiling (prints shadow/main/post GPU ms).
    fun set_gpu_timing(self, enabled: i32):
        self.profiler.set_enabled(enabled)

    # Shadow caster size-cull threshold (shadow LOD). Casters whose angular
    # size (worldRadius / |clipW|) falls below this are skipped in the shadow
    # pass. 0.0 disables (default). Cheap win for dense scenes.
    fun set_shadow_min_size(self, threshold: f32):
        if threshold < 0.0:
            g_frog_shadow_min_size = 0.0
        else:
            g_frog_shadow_min_size = threshold

    # CSM cascade-0 priority cull: skip re-drawing near casters into the far
    # cascade. margin is an NDC safety band (0 disables). Risky under grazing
    # light, so opt-in.
    fun set_shadow_cascade0_margin(self, margin: f32):
        if margin < 0.0:
            g_frog_shadow_cascade0_margin = 0.0
        else:
            g_frog_shadow_cascade0_margin = margin

    # Enable CPU command-recording profiler (prints shadow-build vs total
    # recording us every 120 frames). Off by default.
    fun set_cpu_record_timing(self, enabled: i32):
        if enabled == 0:
            g_frog_cpu_prof_enabled = 0
        else:
            g_frog_cpu_prof_enabled = 1
        g_frog_cpu_prof_shadow_ticks = 0
        g_frog_cpu_prof_total_ticks = 0
        g_frog_cpu_prof_frames = 0

    fun _debug_record_frame(self):
        if self.debug_render_stats_enabled == 0:
            return
        self.debug_frame_count = self.debug_frame_count + 1
        if self.debug_frame_count >= 120:
            mesh_count: i32 = self.vb_count
            instance_count: i32 = self.debug_visible_instances
            draw_count: i32 = self.debug_draw_calls
            indexed_count: i32 = self.debug_indexed_draw_calls
            print(@"[frog.render] frames=120 meshes={mesh_count} instances={instance_count} draws={draw_count} indexed={indexed_count}")
            self.debug_frame_count = 0
            self.debug_draw_calls = 0
            self.debug_indexed_draw_calls = 0
            self.debug_visible_instances = 0

    fun _grow_vb_arrays(self) -> void:
        new_cap: i32 = self.vb_capacity * 2
        new_handles: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_memories: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_alloc_sizes: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_vert_counts: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_ib_handles: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_ib_memories: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_ib_alloc_sizes: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_ib_counts: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_matrices: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_bound_xs: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_bound_ys: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_bound_zs: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_bound_rs: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_mesh_tex: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_mesh_emissive_tex: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_mesh_normal_tex: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_mesh_metallic_roughness_tex: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_mesh_occlusion_tex: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_mesh_desc_sets: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_mesh_materials: i64 = Memory.malloc_zeroed(new_cap * 32)
        new_shadow_flags: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_shadow_distances: i64 = Memory.malloc_zeroed(new_cap * 4)
        mti2: i32 = 0
        while mti2 < new_cap:
            Memory.write_i32(new_mesh_tex + mti2 * 4, 0 - 1)
            Memory.write_i32(new_mesh_emissive_tex + mti2 * 4, 0 - 1)
            Memory.write_i32(new_mesh_normal_tex + mti2 * 4, 0 - 1)
            Memory.write_i32(new_mesh_metallic_roughness_tex + mti2 * 4, 0 - 1)
            Memory.write_i32(new_mesh_occlusion_tex + mti2 * 4, 0 - 1)
            Memory.write_f32(new_mesh_materials + mti2 * 32 + 4, 1.0)
            Memory.write_f32(new_mesh_materials + mti2 * 32 + 16, 1.0)
            Memory.write_f32(new_mesh_materials + mti2 * 32 + 20, 1.0)
            Memory.write_i32(new_shadow_flags + mti2 * 4, 3)
            mti2 = mti2 + 1
        new_visible: i64 = Memory.malloc_zeroed(new_cap * 4)
        vvi2: i32 = 0
        while vvi2 < new_cap:
            Memory.write_i32(new_visible + vvi2 * 4, 1)
            vvi2 = vvi2 + 1
        new_cull_result: i64 = Memory.malloc_zeroed(new_cap * 4)
        Memory.copy(new_handles, self.vb_handles, self.vb_capacity * 8)
        Memory.copy(new_memories, self.vb_memories, self.vb_capacity * 8)
        Memory.copy(new_alloc_sizes, self.vb_alloc_sizes, self.vb_capacity * 8)
        Memory.copy(new_vert_counts, self.vb_vert_counts, self.vb_capacity * 4)
        Memory.copy(new_ib_handles, self.ib_handles, self.vb_capacity * 8)
        Memory.copy(new_ib_memories, self.ib_memories, self.vb_capacity * 8)
        Memory.copy(new_ib_alloc_sizes, self.ib_alloc_sizes, self.vb_capacity * 8)
        Memory.copy(new_ib_counts, self.ib_index_counts, self.vb_capacity * 4)
        Memory.copy(new_matrices, self.model_matrices, self.vb_capacity * 8)
        Memory.copy(new_bound_xs, self.mesh_bound_xs, self.vb_capacity * 4)
        Memory.copy(new_bound_ys, self.mesh_bound_ys, self.vb_capacity * 4)
        Memory.copy(new_bound_zs, self.mesh_bound_zs, self.vb_capacity * 4)
        Memory.copy(new_bound_rs, self.mesh_bound_rs, self.vb_capacity * 4)
        Memory.copy(new_visible, self.vb_visible, self.vb_capacity * 4)
        Memory.copy(new_cull_result, self.vb_cull_result, self.vb_capacity * 4)
        if self.mesh_tex_ids != 0:
            Memory.copy(new_mesh_tex, self.mesh_tex_ids, self.vb_capacity * 4)
        if self.mesh_emissive_tex_ids != 0:
            Memory.copy(new_mesh_emissive_tex, self.mesh_emissive_tex_ids, self.vb_capacity * 4)
        if self.mesh_normal_tex_ids != 0:
            Memory.copy(new_mesh_normal_tex, self.mesh_normal_tex_ids, self.vb_capacity * 4)
        if self.mesh_metallic_roughness_tex_ids != 0:
            Memory.copy(new_mesh_metallic_roughness_tex, self.mesh_metallic_roughness_tex_ids, self.vb_capacity * 4)
        if self.mesh_occlusion_tex_ids != 0:
            Memory.copy(new_mesh_occlusion_tex, self.mesh_occlusion_tex_ids, self.vb_capacity * 4)
        if self.mesh_desc_sets != 0:
            Memory.copy(new_mesh_desc_sets, self.mesh_desc_sets, self.vb_capacity * 8)
        if self.mesh_material_params != 0:
            Memory.copy(new_mesh_materials, self.mesh_material_params, self.vb_capacity * 32)
        if self.mesh_shadow_flags != 0:
            Memory.copy(new_shadow_flags, self.mesh_shadow_flags, self.vb_capacity * 4)
        if self.mesh_shadow_distances != 0:
            Memory.copy(new_shadow_distances, self.mesh_shadow_distances, self.vb_capacity * 4)
        Memory.free(self.vb_handles)
        Memory.free(self.vb_memories)
        Memory.free(self.vb_alloc_sizes)
        Memory.free(self.vb_vert_counts)
        Memory.free(self.ib_handles)
        Memory.free(self.ib_memories)
        Memory.free(self.ib_alloc_sizes)
        Memory.free(self.ib_index_counts)
        Memory.free(self.model_matrices)
        Memory.free(self.mesh_bound_xs)
        Memory.free(self.mesh_bound_ys)
        Memory.free(self.mesh_bound_zs)
        Memory.free(self.mesh_bound_rs)
        Memory.free(self.vb_visible)
        Memory.free(self.vb_cull_result)
        if self.mesh_tex_ids != 0:
            Memory.free(self.mesh_tex_ids)
        if self.mesh_emissive_tex_ids != 0:
            Memory.free(self.mesh_emissive_tex_ids)
        if self.mesh_normal_tex_ids != 0:
            Memory.free(self.mesh_normal_tex_ids)
        if self.mesh_metallic_roughness_tex_ids != 0:
            Memory.free(self.mesh_metallic_roughness_tex_ids)
        if self.mesh_occlusion_tex_ids != 0:
            Memory.free(self.mesh_occlusion_tex_ids)
        if self.mesh_desc_sets != 0:
            Memory.free(self.mesh_desc_sets)
        if self.mesh_material_params != 0:
            Memory.free(self.mesh_material_params)
        if self.mesh_shadow_flags != 0:
            Memory.free(self.mesh_shadow_flags)
        if self.mesh_shadow_distances != 0:
            Memory.free(self.mesh_shadow_distances)
        self.vb_handles = new_handles
        self.vb_memories = new_memories
        self.vb_alloc_sizes = new_alloc_sizes
        self.vb_vert_counts = new_vert_counts
        self.ib_handles = new_ib_handles
        self.ib_memories = new_ib_memories
        self.ib_alloc_sizes = new_ib_alloc_sizes
        self.ib_index_counts = new_ib_counts
        self.model_matrices = new_matrices
        self.mesh_bound_xs = new_bound_xs
        self.mesh_bound_ys = new_bound_ys
        self.mesh_bound_zs = new_bound_zs
        self.mesh_bound_rs = new_bound_rs
        self.vb_visible = new_visible
        self.vb_cull_result = new_cull_result
        self.mesh_tex_ids = new_mesh_tex
        self.mesh_emissive_tex_ids = new_mesh_emissive_tex
        self.mesh_normal_tex_ids = new_mesh_normal_tex
        self.mesh_metallic_roughness_tex_ids = new_mesh_metallic_roughness_tex
        self.mesh_occlusion_tex_ids = new_mesh_occlusion_tex
        self.mesh_desc_sets = new_mesh_desc_sets
        self.mesh_material_params = new_mesh_materials
        self.mesh_shadow_flags = new_shadow_flags
        self.mesh_shadow_distances = new_shadow_distances
        self.vb_capacity = new_cap
        # Grow the candidate->gi map alongside the vb arrays.
        new_cand_gi: i64 = Memory.malloc_zeroed((new_cap as i64) * 4)
        if self.gpu_cand_gi != 0:
            Memory.free(self.gpu_cand_gi)
        self.gpu_cand_gi = new_cand_gi

    fun _take_pooled_buffer(self, data_size: i64, usage: i32) -> GpuBufferUpload:
        if self.pooled_count <= 0:
            return GpuBufferUpload()
        if self.pooled_buffers == 0:
            return GpuBufferUpload()
        if self.pooled_memories == 0:
            return GpuBufferUpload()
        if self.pooled_sizes == 0:
            return GpuBufferUpload()
        if self.pooled_usages == 0:
            return GpuBufferUpload()
        best: i32 = 0 - 1
        best_size: i64 = 0
        i: i32 = 0
        while i < self.pooled_count:
            entry_usage: i32 = Memory.read_i32(self.pooled_usages + i * 4)
            entry_size: i64 = Memory.read_i64(self.pooled_sizes + i * 8)
            if entry_usage == usage:
                if entry_size >= data_size:
                    if best < 0:
                        best = i
                        best_size = entry_size
                    elif entry_size < best_size:
                        best = i
                        best_size = entry_size
            i = i + 1
        if best < 0:
            return GpuBufferUpload()

        handle: i64 = Memory.read_ptr(self.pooled_buffers + best * 8)
        memory: i64 = Memory.read_ptr(self.pooled_memories + best * 8)
        last: i32 = self.pooled_count - 1
        if best != last:
            Memory.write_ptr(self.pooled_buffers + best * 8, Memory.read_ptr(self.pooled_buffers + last * 8))
            Memory.write_ptr(self.pooled_memories + best * 8, Memory.read_ptr(self.pooled_memories + last * 8))
            Memory.write_i64(self.pooled_sizes + best * 8, Memory.read_i64(self.pooled_sizes + last * 8))
            Memory.write_i32(self.pooled_usages + best * 4, Memory.read_i32(self.pooled_usages + last * 4))
        Memory.write_ptr(self.pooled_buffers + last * 8, 0)
        Memory.write_ptr(self.pooled_memories + last * 8, 0)
        Memory.write_i64(self.pooled_sizes + last * 8, 0)
        Memory.write_i32(self.pooled_usages + last * 4, 0)
        self.pooled_count = last
        self.pooled_bytes = self.pooled_bytes - best_size
        if self.pooled_bytes < 0:
            self.pooled_bytes = 0
        return GpuBufferUpload(handle=handle, memory=memory, capacity=best_size, ok=1)

    fun _pool_buffer_pair(self, buffer: i64, memory: i64, size: i64, usage: i32):
        if buffer == 0:
            return
        if memory == 0:
            return
        if size <= 0:
            vkDestroyBuffer(self.device, buffer, 0)
            vkFreeMemory(self.device, memory, 0)
            return
        if self.pooled_buffers == 0:
            vkDestroyBuffer(self.device, buffer, 0)
            vkFreeMemory(self.device, memory, 0)
            return
        if self.pooled_count >= self.pooled_capacity:
            vkDestroyBuffer(self.device, buffer, 0)
            vkFreeMemory(self.device, memory, 0)
            return
        if self.pooled_bytes + size > self.pooled_byte_limit:
            vkDestroyBuffer(self.device, buffer, 0)
            vkFreeMemory(self.device, memory, 0)
            return
        idx: i32 = self.pooled_count
        Memory.write_ptr(self.pooled_buffers + idx * 8, buffer)
        Memory.write_ptr(self.pooled_memories + idx * 8, memory)
        Memory.write_i64(self.pooled_sizes + idx * 8, size)
        Memory.write_i32(self.pooled_usages + idx * 4, usage)
        self.pooled_count = idx + 1
        self.pooled_bytes = self.pooled_bytes + size

    fun _upload_buffer(self, data: i64, data_size: i64, usage: i32) -> GpuBufferUpload:
        if data == 0:
            return GpuBufferUpload()
        if data_size <= 0:
            return GpuBufferUpload()

        pooled: GpuBufferUpload = self._take_pooled_buffer(data_size, usage)
        if pooled.ok == 1:
            Memory.write_ptr(self.scratch_map_pp, 0)
            pool_map_r: i32 = vkMapMemory(self.device, pooled.memory, 0, data_size, 0, self.scratch_map_pp)
            pool_mapped: i64 = Memory.read_ptr(self.scratch_map_pp)
            if pool_map_r == 0:
                if pool_mapped != 0:
                    Memory.copy(pool_mapped, data, data_size)
                    vkUnmapMemory(self.device, pooled.memory)
                    return pooled
            vkDestroyBuffer(self.device, pooled.handle, 0)
            vkFreeMemory(self.device, pooled.memory, 0)

        # Create buffer (VkBufferCreateInfo = 56 bytes)
        buf_ci: i64 = Memory.malloc_zeroed(56)
        if buf_ci == 0:
            return GpuBufferUpload()
        Memory.write_i32(buf_ci, 12)
        Memory.write_ptr(buf_ci + 8, 0)
        Memory.write_i32(buf_ci + 16, 0)
        Memory.write_i64(buf_ci + 24, data_size)
        Memory.write_i32(buf_ci + 32, usage)
        Memory.write_i32(buf_ci + 36, 0)
        Memory.write_i32(buf_ci + 40, 0)
        Memory.write_ptr(buf_ci + 48, 0)
        buf_ptr: i64 = Memory.malloc_zeroed(8)
        if buf_ptr == 0:
            Memory.free(buf_ci)
            return GpuBufferUpload()
        buf_r: i32 = vkCreateBuffer(self.device, buf_ci, 0, buf_ptr)
        buf: i64 = Memory.read_ptr(buf_ptr)
        Memory.free(buf_ptr)
        Memory.free(buf_ci)
        if buf_r != 0:
            return GpuBufferUpload()

        # Get memory requirements
        mem_req: i64 = Memory.malloc_zeroed(24)
        if mem_req == 0:
            vkDestroyBuffer(self.device, buf, 0)
            return GpuBufferUpload()
        vkGetBufferMemoryRequirements(self.device, buf, mem_req)
        req_size: i64 = Memory.read_i64(mem_req)
        req_bits: i32 = Memory.read_i32(mem_req + 16)
        Memory.free(mem_req)

        # Find memory type (host visible + host coherent)
        mem_props: i64 = Memory.malloc_zeroed(520)
        if mem_props == 0:
            vkDestroyBuffer(self.device, buf, 0)
            return GpuBufferUpload()
        vkGetPhysicalDeviceMemoryProperties(self.phys_device, mem_props)
        type_count: i32 = Memory.read_i32(mem_props)
        mem_type_idx: i32 = 0 - 1
        ti: i32 = 0
        while ti < type_count:
            bit_check: i32 = 1
            shift: i32 = 0
            while shift < ti:
                bit_check = bit_check * 2
                shift = shift + 1
            if (req_bits / bit_check) - (req_bits / (bit_check * 2)) * 2 == 1:
                flags: i32 = Memory.read_i32(mem_props + 4 + ti * 8)
                if (flags / 2) - (flags / 4) * 2 == 1:
                    if (flags / 4) - (flags / 8) * 2 == 1:
                        mem_type_idx = ti
                        ti = type_count
            ti = ti + 1
        Memory.free(mem_props)
        if mem_type_idx < 0:
            vkDestroyBuffer(self.device, buf, 0)
            return GpuBufferUpload()

        # Allocate device memory
        alloc_info: i64 = Memory.malloc_zeroed(32)
        if alloc_info == 0:
            vkDestroyBuffer(self.device, buf, 0)
            return GpuBufferUpload()
        Memory.set(alloc_info, 0, 32)
        Memory.write_i32(alloc_info, 5)
        Memory.write_ptr(alloc_info + 8, 0)
        Memory.write_i64(alloc_info + 16, req_size)
        Memory.write_i32(alloc_info + 24, mem_type_idx)
        mem_ptr: i64 = Memory.malloc_zeroed(8)
        if mem_ptr == 0:
            Memory.free(alloc_info)
            vkDestroyBuffer(self.device, buf, 0)
            return GpuBufferUpload()
        alloc_r: i32 = vkAllocateMemory(self.device, alloc_info, 0, mem_ptr)
        mem: i64 = Memory.read_ptr(mem_ptr)
        Memory.free(mem_ptr)
        Memory.free(alloc_info)
        if alloc_r != 0:
            vkDestroyBuffer(self.device, buf, 0)
            return GpuBufferUpload()

        # Bind and map
        vkBindBufferMemory(self.device, buf, mem, 0)
        data_pp: i64 = Memory.malloc_zeroed(8)
        if data_pp == 0:
            vkDestroyBuffer(self.device, buf, 0)
            vkFreeMemory(self.device, mem, 0)
            return GpuBufferUpload()
        vkMapMemory(self.device, mem, 0, data_size, 0, data_pp)
        mapped: i64 = Memory.read_ptr(data_pp)
        Memory.free(data_pp)
        if mapped != 0:
            Memory.copy(mapped, data, data_size)
        vkUnmapMemory(self.device, mem)

        return GpuBufferUpload(handle=buf, memory=mem, capacity=data_size, ok=1)

    fun _ensure_instance_capacity(self, needed: i32) -> i32:
        if needed <= 0:
            return 0
        # Two instance buffers (one per frame-in-flight). Allocate the slot
        # array once.
        if self.instance_buffers == 0:
            self.instance_buffers = Memory.malloc_zeroed(2 * 8)
            self.instance_memories = Memory.malloc_zeroed(2 * 8)
            self.instance_mapped_ptrs = Memory.malloc_zeroed(2 * 8)

        if self.instance_capacity >= needed:
            if self.instance_buffers != 0:
                ok_all: i32 = 1
                si: i32 = 0
                while si < 2:
                    if Memory.read_ptr(self.instance_buffers + si * 8) == 0:
                        ok_all = 0
                    if Memory.read_ptr(self.instance_memories + si * 8) == 0:
                        ok_all = 0
                    if self.instance_mapped_ptrs == 0:
                        ok_all = 0
                    elif Memory.read_ptr(self.instance_mapped_ptrs + si * 8) == 0:
                        ok_all = 0
                    si = si + 1
                if ok_all == 1:
                    return 1

        new_cap: i32 = self.instance_capacity
        if new_cap <= 0:
            new_cap = 1024
        while new_cap < needed:
            new_cap = new_cap * 2

        size: i64 = (new_cap as i64) * (FROG_GPU_INSTANCE_STRIDE as i64)
        zeros: i64 = Memory.malloc_zeroed(size)
        if zeros == 0:
            return 0

        slot: i32 = 0
        while slot < 2:
            uploaded: GpuBufferUpload = self._upload_buffer(zeros, size, 128)
            if uploaded.ok == 0:
                Memory.free(zeros)
                return 0
            old_buf: i64 = Memory.read_ptr(self.instance_buffers + slot * 8)
            old_mem: i64 = Memory.read_ptr(self.instance_memories + slot * 8)
            old_mapped: i64 = 0
            if self.instance_mapped_ptrs != 0:
                old_mapped = Memory.read_ptr(self.instance_mapped_ptrs + slot * 8)
            if old_mem != 0:
                if old_mapped != 0:
                    vkUnmapMemory(self.device, old_mem)
            if old_mem != 0:
                old_size: i64 = (self.instance_capacity as i64) * (FROG_GPU_INSTANCE_STRIDE as i64)
                self._retire_buffer_pair(old_buf, old_mem, old_size, 128)
            elif old_buf != 0:
                vkDestroyBuffer(self.device, old_buf, 0)
            Memory.write_ptr(self.instance_buffers + slot * 8, uploaded.handle)
            Memory.write_ptr(self.instance_memories + slot * 8, uploaded.memory)
            Memory.write_ptr(self.scratch_map_pp, 0)
            map_r: i32 = vkMapMemory(self.device, uploaded.memory, 0, size, 0, self.scratch_map_pp)
            mapped: i64 = Memory.read_ptr(self.scratch_map_pp)
            if map_r != 0:
                vkDestroyBuffer(self.device, uploaded.handle, 0)
                vkFreeMemory(self.device, uploaded.memory, 0)
                Memory.write_ptr(self.instance_buffers + slot * 8, 0)
                Memory.write_ptr(self.instance_memories + slot * 8, 0)
                Memory.free(zeros)
                return 0
            if mapped == 0:
                vkDestroyBuffer(self.device, uploaded.handle, 0)
                vkFreeMemory(self.device, uploaded.memory, 0)
                Memory.write_ptr(self.instance_buffers + slot * 8, 0)
                Memory.write_ptr(self.instance_memories + slot * 8, 0)
                Memory.free(zeros)
                return 0
            Memory.write_ptr(self.instance_mapped_ptrs + slot * 8, mapped)
            slot = slot + 1
        Memory.free(zeros)

        # Keep the legacy single-buffer fields pointing at slot 0.
        self.instance_buffer = Memory.read_ptr(self.instance_buffers)
        self.instance_memory = Memory.read_ptr(self.instance_memories)
        self.instance_capacity = new_cap
        return 1

    fun _ensure_shadow_vis_capacity(self, needed: i32) -> i64:
        if needed <= 0:
            return 0
        if g_shadow_vis_cap >= needed:
            return g_shadow_vis_out
        new_cap: i32 = needed + needed / 2 + 64
        if g_shadow_vis_out != 0:
            Memory.free(g_shadow_vis_out)
        buf: i64 = Memory.malloc((new_cap as i64) * 4)
        if buf == 0:
            g_shadow_vis_out = 0
            g_shadow_vis_cap = 0
            return 0
        g_shadow_vis_out = buf
        g_shadow_vis_cap = new_cap
        return buf

    fun _ensure_shadow_instance_capacity(self, needed: i32) -> i32:
        if needed <= 0:
            return 0
        if self.render_state == 0:
            return 0
        instance_buffers: i64 = Memory.read_ptr(self.render_state + 8)
        instance_memories: i64 = Memory.read_ptr(self.render_state + 16)
        instance_mapped_ptrs: i64 = Memory.read_ptr(self.render_state + 24)
        instance_capacity: i32 = Memory.read_i32(self.render_state + 32)
        if instance_buffers == 0:
            instance_buffers = Memory.malloc_zeroed(2 * 8)
            instance_memories = Memory.malloc_zeroed(2 * 8)
            instance_mapped_ptrs = Memory.malloc_zeroed(2 * 8)
            Memory.write_ptr(self.render_state + 8, instance_buffers)
            Memory.write_ptr(self.render_state + 16, instance_memories)
            Memory.write_ptr(self.render_state + 24, instance_mapped_ptrs)

        if instance_capacity >= needed:
            ok_all: i32 = 1
            si: i32 = 0
            while si < 2:
                if Memory.read_ptr(instance_buffers + si * 8) == 0:
                    ok_all = 0
                if Memory.read_ptr(instance_memories + si * 8) == 0:
                    ok_all = 0
                if Memory.read_ptr(instance_mapped_ptrs + si * 8) == 0:
                    ok_all = 0
                si = si + 1
            if ok_all == 1:
                return 1

        new_cap: i32 = instance_capacity
        if new_cap <= 0:
            new_cap = 1024
        while new_cap < needed:
            new_cap = new_cap * 2
        size: i64 = (new_cap as i64) * 80
        zeros: i64 = Memory.malloc_zeroed(size)
        if zeros == 0:
            return 0

        slot: i32 = 0
        while slot < 2:
            uploaded: GpuBufferUpload = self._upload_buffer(zeros, size, 128)
            if uploaded.ok == 0:
                Memory.free(zeros)
                return 0
            old_buf: i64 = Memory.read_ptr(instance_buffers + slot * 8)
            old_mem: i64 = Memory.read_ptr(instance_memories + slot * 8)
            old_mapped: i64 = Memory.read_ptr(instance_mapped_ptrs + slot * 8)
            if old_mem != 0:
                if old_mapped != 0:
                    vkUnmapMemory(self.device, old_mem)
                self._retire_buffer_pair(old_buf, old_mem, (instance_capacity as i64) * 80, 128)
            elif old_buf != 0:
                vkDestroyBuffer(self.device, old_buf, 0)

            Memory.write_ptr(instance_buffers + slot * 8, uploaded.handle)
            Memory.write_ptr(instance_memories + slot * 8, uploaded.memory)
            Memory.write_ptr(self.scratch_map_pp, 0)
            map_result: i32 = vkMapMemory(self.device, uploaded.memory, 0, size, 0, self.scratch_map_pp)
            mapped: i64 = Memory.read_ptr(self.scratch_map_pp)
            if map_result != 0 or mapped == 0:
                vkDestroyBuffer(self.device, uploaded.handle, 0)
                vkFreeMemory(self.device, uploaded.memory, 0)
                Memory.free(zeros)
                return 0
            Memory.write_ptr(instance_mapped_ptrs + slot * 8, mapped)
            slot = slot + 1
        Memory.free(zeros)
        Memory.write_i32(self.render_state + 32, new_cap)
        return 1

    fun _ensure_shadow_globals(self) -> i32:
        if self.render_state == 0:
            return 0
        global_buffers: i64 = Memory.read_ptr(self.render_state + 40)
        global_memories: i64 = Memory.read_ptr(self.render_state + 48)
        global_mapped_ptrs: i64 = Memory.read_ptr(self.render_state + 56)
        if global_buffers == 0:
            global_buffers = Memory.malloc_zeroed(2 * 8)
            global_memories = Memory.malloc_zeroed(2 * 8)
            global_mapped_ptrs = Memory.malloc_zeroed(2 * 8)
            Memory.write_ptr(self.render_state + 40, global_buffers)
            Memory.write_ptr(self.render_state + 48, global_memories)
            Memory.write_ptr(self.render_state + 56, global_mapped_ptrs)
        ok_all: i32 = 1
        check: i32 = 0
        while check < 2:
            if Memory.read_ptr(global_buffers + check * 8) == 0:
                ok_all = 0
            if Memory.read_ptr(global_memories + check * 8) == 0:
                ok_all = 0
            if Memory.read_ptr(global_mapped_ptrs + check * 8) == 0:
                ok_all = 0
            check = check + 1
        if ok_all == 1:
            return 1

        zeros: i64 = Memory.malloc_zeroed(176)
        if zeros == 0:
            return 0
        slot: i32 = 0
        while slot < 2:
            uploaded: GpuBufferUpload = self._upload_buffer(zeros, 176, 128)
            if uploaded.ok == 0:
                Memory.free(zeros)
                return 0
            Memory.write_ptr(global_buffers + slot * 8, uploaded.handle)
            Memory.write_ptr(global_memories + slot * 8, uploaded.memory)
            Memory.write_ptr(self.scratch_map_pp, 0)
            map_result: i32 = vkMapMemory(self.device, uploaded.memory, 0, 176, 0, self.scratch_map_pp)
            mapped: i64 = Memory.read_ptr(self.scratch_map_pp)
            if map_result != 0 or mapped == 0:
                vkDestroyBuffer(self.device, uploaded.handle, 0)
                vkFreeMemory(self.device, uploaded.memory, 0)
                Memory.free(zeros)
                return 0
            Memory.write_ptr(global_mapped_ptrs + slot * 8, mapped)
            slot = slot + 1
        Memory.free(zeros)
        return 1

    fun _ensure_point_light_globals(self, rp: RenderPass) -> i32:
        if self.point_light_buffers == 0:
            self.point_light_buffers = Memory.malloc_zeroed(16)
            self.point_light_memories = Memory.malloc_zeroed(16)
            self.point_light_mapped_ptrs = Memory.malloc_zeroed(16)
            self.point_light_desc_sets = Memory.malloc_zeroed(16)
        if self.point_light_buffers == 0 or self.point_light_memories == 0 or self.point_light_mapped_ptrs == 0 or self.point_light_desc_sets == 0:
            return 0

        zero_data: i64 = Memory.malloc_zeroed(FROG_POINT_LIGHT_DATA_SIZE)
        if zero_data == 0:
            return 0
        slot: i32 = 0
        while slot < 2:
            buffer: i64 = Memory.read_ptr(self.point_light_buffers + slot * 8)
            memory: i64 = Memory.read_ptr(self.point_light_memories + slot * 8)
            mapped: i64 = Memory.read_ptr(self.point_light_mapped_ptrs + slot * 8)
            if buffer == 0 or memory == 0 or mapped == 0:
                uploaded: GpuBufferUpload = self._upload_buffer(zero_data, FROG_POINT_LIGHT_DATA_SIZE, 16)
                if uploaded.ok == 0:
                    Memory.free(zero_data)
                    return 0
                Memory.write_ptr(self.point_light_buffers + slot * 8, uploaded.handle)
                Memory.write_ptr(self.point_light_memories + slot * 8, uploaded.memory)
                Memory.write_ptr(self.scratch_map_pp, 0)
                map_result: i32 = vkMapMemory(self.device, uploaded.memory, 0, FROG_POINT_LIGHT_DATA_SIZE, 0, self.scratch_map_pp)
                mapped = Memory.read_ptr(self.scratch_map_pp)
                if map_result != 0 or mapped == 0:
                    vkDestroyBuffer(self.device, uploaded.handle, 0)
                    vkFreeMemory(self.device, uploaded.memory, 0)
                    Memory.free(zero_data)
                    return 0
                Memory.write_ptr(self.point_light_mapped_ptrs + slot * 8, mapped)
                buffer = uploaded.handle
            desc: i64 = Memory.read_ptr(self.point_light_desc_sets + slot * 8)
            if desc == 0:
                desc = rp.make_lighting_descriptor(self.device, buffer, FROG_POINT_LIGHT_DATA_SIZE)
                if desc == 0:
                    Memory.free(zero_data)
                    return 0
                Memory.write_ptr(self.point_light_desc_sets + slot * 8, desc)
            slot = slot + 1
        Memory.free(zero_data)
        return 1

    fun rebuild_point_light_descriptors(self, rp: RenderPass) -> i32:
        if self.point_light_desc_sets == 0:
            return 1
        slot: i32 = 0
        while slot < 2:
            Memory.write_ptr(self.point_light_desc_sets + slot * 8, 0)
            buffer: i64 = 0
            if self.point_light_buffers != 0:
                buffer = Memory.read_ptr(self.point_light_buffers + slot * 8)
            if buffer != 0:
                desc: i64 = rp.make_lighting_descriptor(self.device, buffer, FROG_POINT_LIGHT_DATA_SIZE)
                if desc == 0:
                    return 0
                Memory.write_ptr(self.point_light_desc_sets + slot * 8, desc)
            slot = slot + 1
        return 1

    fun _write_point_light_data(self, out: i64, env: Environment):
        if out == 0:
            return
        Memory.set(out, 0, FROG_POINT_LIGHT_DATA_SIZE)
        if env.lighting.enabled == 1:
            if env.sky.enabled() == 1:
                Memory.write_f32(out + 272, env.sky.zenith_color.r)
                Memory.write_f32(out + 276, env.sky.zenith_color.g)
                Memory.write_f32(out + 280, env.sky.zenith_color.b)
                Memory.write_f32(out + 288, env.sky.horizon_color.r)
                Memory.write_f32(out + 292, env.sky.horizon_color.g)
                Memory.write_f32(out + 296, env.sky.horizon_color.b)
                Memory.write_f32(out + 304, env.sky.lower_color.r)
                Memory.write_f32(out + 308, env.sky.lower_color.g)
                Memory.write_f32(out + 312, env.sky.lower_color.b)
                Memory.write_f32(out + 320, env.lighting.diffuse_strength)
                Memory.write_f32(out + 324, env.lighting.reflection_strength)
                Memory.write_f32(out + 328, 1.0)
        if self.point_light_ptrs == 0:
            return
        source_count: i32 = self.point_light_count
        if source_count > FROG_POINT_LIGHT_SLOTS:
            source_count = FROG_POINT_LIGHT_SLOTS
        write_index: i32 = 0
        source_index: i32 = 0
        while source_index < source_count:
            ptr: i64 = Memory.read_ptr(self.point_light_ptrs + source_index * 8)
            if ptr != 0:
                light: PointLight3D = ptr as PointLight3D
                if light.active == 1:
                    if light.energy > 0.0001:
                        if light.range > 0.0001:
                            pos_offset: i64 = 16 + write_index * 16
                            color_offset: i64 = 144 + write_index * 16
                            Memory.write_f32(out + pos_offset, light.pos_x)
                            Memory.write_f32(out + pos_offset + 4, light.pos_y)
                            Memory.write_f32(out + pos_offset + 8, light.pos_z)
                            Memory.write_f32(out + pos_offset + 12, light.range)
                            Memory.write_f32(out + color_offset, light.color.r)
                            Memory.write_f32(out + color_offset + 4, light.color.g)
                            Memory.write_f32(out + color_offset + 8, light.color.b)
                            Memory.write_f32(out + color_offset + 12, light.energy)
                            write_index = write_index + 1
            source_index = source_index + 1
        active_count: f32 = write_index as f32
        Memory.write_f32(out, active_count)

    fun _refresh_shadow_descriptors(self, rp: RenderPass):
        if self.tex_desc_sets == 0:
            return
        ti: i32 = 0
        while ti < self.tex_count:
            dset: i64 = Memory.read_ptr(self.tex_desc_sets + ti * 8)
            if dset != 0:
                rp.update_shadow_descriptor(self.device, dset)
            ti = ti + 1

    fun _ensure_shadow_target(self, rp: RenderPass):
        requested: i32 = 1
        light_ptr: i64 = 0
        if self.render_state != 0:
            light_ptr = Memory.read_ptr(self.render_state)
        if light_ptr != 0:
            light: DirectionalLight3D = light_ptr as DirectionalLight3D
            if light.active == 1:
                if light.shadow.enabled == 1:
                    requested = light.shadow.map_size
                    if light.shadow.cascades > 1:
                        if requested < 8192:
                            requested = requested * 2
                            if requested > 8192:
                                requested = 8192
        if requested < 1:
            requested = 1
        if requested == rp.shadow.map_size:
            return
        vkDeviceWaitIdle(self.device)
        if rp.shadow.ensure_target(self.device, self.phys_device, requested) == 1:
            self._refresh_shadow_descriptors(rp)

    fun _write_shadow_data(self, out: i64) -> i32:
        if out == 0:
            return 0
        Memory.set(out, 0, 176)
        identity: Mat4 = Mat4.identity()
        identity.write_to_ptr(out)
        identity.write_to_ptr(out + 64)
        if self.render_state == 0:
            return 0
        light_ptr: i64 = Memory.read_ptr(self.render_state)
        if light_ptr == 0:
            return 0
        light: DirectionalLight3D = light_ptr as DirectionalLight3D
        if light.active == 0:
            return 0
        if light.intensity <= 0.001:
            return 0
        if light.shadow.enabled == 0:
            return 0

        distance: f32 = light.shadow.distance
        if distance < 10.0:
            distance = 10.0
        if distance > 1000.0:
            distance = 1000.0

        pitch: f32 = Memory.read_f32(self.render_state + 76) * 3.14159265 / 180.0
        yaw: f32 = Memory.read_f32(self.render_state + 80) * 3.14159265 / 180.0
        cp: f32 = @cos(pitch)
        forward_x: f32 = (0.0 - @sin(yaw)) * cp
        forward_y: f32 = @sin(pitch)
        forward_z: f32 = (0.0 - @cos(yaw)) * cp
        cascade_count: i32 = light.shadow.cascades
        if cascade_count < 1:
            cascade_count = 1
        if cascade_count > 2:
            cascade_count = 2

        cam_x: f32 = Memory.read_f32(self.render_state + 64)
        cam_y: f32 = Memory.read_f32(self.render_state + 68)
        cam_z: f32 = Memory.read_f32(self.render_state + 72)
        up_x: f32 = 0.0
        up_y: f32 = 1.0
        up_z: f32 = 0.0
        if light.dir_y > 0.95 or light.dir_y < -0.95:
            up_y = 0.0
            up_z = 1.0

        shadow_near: f32 = 1.0
        shadow_map_size: i32 = light.shadow.map_size
        if shadow_map_size < 1:
            shadow_map_size = 1
        atlas_map_size: i32 = shadow_map_size
        if cascade_count > 1:
            if atlas_map_size < 8192:
                atlas_map_size = atlas_map_size * 2
                if atlas_map_size > 8192:
                    atlas_map_size = 8192
        tile_map_size: i32 = atlas_map_size
        if cascade_count > 1:
            tile_map_size = atlas_map_size / 2
            if tile_map_size < 1:
                tile_map_size = 1
        half_map: f32 = (tile_map_size as f32) * 0.5

        split0: f32 = distance
        if cascade_count > 1:
            cascade_split: f32 = light.shadow.cascade_split
            if cascade_split < 0.10:
                cascade_split = 0.10
            if cascade_split > 0.75:
                cascade_split = 0.75
            split0 = distance * cascade_split
            if split0 < 12.0:
                split0 = 12.0
            if split0 > distance * 0.60:
                split0 = distance * 0.60

        focus0: f32 = distance * 0.28
        extent0: f32 = distance * 0.68
        far0: f32 = distance * 2.15
        if cascade_count > 1:
            focus0 = split0 * 0.55
            extent0 = split0 * 0.85
            far0 = split0 * 3.0

        center0_x: f32 = cam_x + forward_x * focus0
        center0_y: f32 = cam_y + forward_y * focus0
        center0_z: f32 = cam_z + forward_z * focus0
        half_depth0: f32 = far0 * 0.5
        eye0_x: f32 = center0_x - light.dir_x * half_depth0
        eye0_y: f32 = center0_y - light.dir_y * half_depth0
        eye0_z: f32 = center0_z - light.dir_z * half_depth0
        view0: Mat4 = Mat4.look_at(eye0_x, eye0_y, eye0_z, center0_x, center0_y, center0_z, up_x, up_y, up_z)
        projection0: Mat4 = Mat4.orthographic(0.0 - extent0, extent0, 0.0 - extent0, extent0, shadow_near, far0)
        light_vp0: Mat4 = projection0.mul(view0)

        # Stabilize each directional projection on the shadow-map texel grid.
        origin_texel_x: f32 = light_vp0.m12 * half_map
        origin_texel_y: f32 = light_vp0.m13 * half_map
        rounded_texel_x: i32 = 0
        rounded_texel_y: i32 = 0
        if origin_texel_x >= 0.0:
            rounded_texel_x = (origin_texel_x + 0.5) as i32
        else:
            rounded_texel_x = (origin_texel_x - 0.5) as i32
        if origin_texel_y >= 0.0:
            rounded_texel_y = (origin_texel_y + 0.5) as i32
        else:
            rounded_texel_y = (origin_texel_y - 0.5) as i32
        projection0.m12 = projection0.m12 + (((rounded_texel_x as f32) - origin_texel_x) / half_map)
        projection0.m13 = projection0.m13 + (((rounded_texel_y as f32) - origin_texel_y) / half_map)
        light_vp0 = projection0.mul(view0)
        light_vp0.write_to_ptr(out)

        focus1: f32 = distance * 0.40
        extent1: f32 = distance * 0.70
        far1: f32 = distance * 2.15
        if cascade_count <= 1:
            focus1 = focus0
            extent1 = extent0
            far1 = far0
        center1_x: f32 = cam_x + forward_x * focus1
        center1_y: f32 = cam_y + forward_y * focus1
        center1_z: f32 = cam_z + forward_z * focus1
        half_depth1: f32 = far1 * 0.5
        eye1_x: f32 = center1_x - light.dir_x * half_depth1
        eye1_y: f32 = center1_y - light.dir_y * half_depth1
        eye1_z: f32 = center1_z - light.dir_z * half_depth1
        view1: Mat4 = Mat4.look_at(eye1_x, eye1_y, eye1_z, center1_x, center1_y, center1_z, up_x, up_y, up_z)
        projection1: Mat4 = Mat4.orthographic(0.0 - extent1, extent1, 0.0 - extent1, extent1, shadow_near, far1)
        light_vp1: Mat4 = projection1.mul(view1)
        origin_texel_x = light_vp1.m12 * half_map
        origin_texel_y = light_vp1.m13 * half_map
        rounded_texel_x = 0
        rounded_texel_y = 0
        if origin_texel_x >= 0.0:
            rounded_texel_x = (origin_texel_x + 0.5) as i32
        else:
            rounded_texel_x = (origin_texel_x - 0.5) as i32
        if origin_texel_y >= 0.0:
            rounded_texel_y = (origin_texel_y + 0.5) as i32
        else:
            rounded_texel_y = (origin_texel_y - 0.5) as i32
        projection1.m12 = projection1.m12 + (((rounded_texel_x as f32) - origin_texel_x) / half_map)
        projection1.m13 = projection1.m13 + (((rounded_texel_y as f32) - origin_texel_y) / half_map)
        light_vp1 = projection1.mul(view1)
        light_vp1.write_to_ptr(out + 64)

        Memory.write_f32(out + 128, 1.0)
        # Public bias values use world units. The comparison shader works in
        # normalized depth, so convert both using the light depth range.
        # Applying either world value directly erases nearby shadows when the
        # directional shadow camera covers a large distance.
        shadow_depth_range0: f32 = far0 - shadow_near
        shadow_depth_range1: f32 = far1 - shadow_near
        normalized_bias0: f32 = light.shadow.bias / shadow_depth_range0
        normalized_normal_bias0: f32 = light.shadow.normal_bias / shadow_depth_range0
        normalized_bias1: f32 = light.shadow.bias / shadow_depth_range1
        normalized_normal_bias1: f32 = light.shadow.normal_bias / shadow_depth_range1
        fade_distance: f32 = light.shadow.fade_distance
        if fade_distance < 0.0:
            fade_distance = 0.0
        if fade_distance > distance:
            fade_distance = distance
        Memory.write_f32(out + 132, normalized_bias0)
        Memory.write_f32(out + 136, normalized_normal_bias0)
        Memory.write_f32(out + 140, light.shadow.softness)
        Memory.write_f32(out + 144, cascade_count as f32)
        Memory.write_f32(out + 148, split0)
        Memory.write_f32(out + 152, normalized_bias1)
        Memory.write_f32(out + 156, normalized_normal_bias1)
        Memory.write_f32(out + 160, light.shadow.filter_quality as f32)
        Memory.write_f32(out + 164, light.shadow.filter_samples as f32)
        Memory.write_f32(out + 168, light.shadow.filter_radius)
        Memory.write_f32(out + 172, fade_distance)
        return 1

    fun _init_retire_queue(self):
        if self.retire_capacity > 0:
            return
        self.retire_capacity = 1024
        self.retire_count = 0
        self.retire_buffers = Memory.malloc_zeroed(self.retire_capacity * 8)
        self.retire_memories = Memory.malloc_zeroed(self.retire_capacity * 8)
        self.retire_frames = Memory.malloc_zeroed(self.retire_capacity * 4)
        self.retire_sizes = Memory.malloc_zeroed(self.retire_capacity * 8)
        self.retire_usages = Memory.malloc_zeroed(self.retire_capacity * 4)

    fun _grow_retire_queue(self):
        if self.retire_capacity <= 0:
            self._init_retire_queue()
            return
        new_cap: i32 = self.retire_capacity * 2
        new_buffers: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_memories: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_frames: i64 = Memory.malloc_zeroed(new_cap * 4)
        new_sizes: i64 = Memory.malloc_zeroed(new_cap * 8)
        new_usages: i64 = Memory.malloc_zeroed(new_cap * 4)
        if new_buffers == 0:
            return
        if new_memories == 0:
            Memory.free(new_buffers)
            return
        if new_frames == 0:
            Memory.free(new_buffers)
            Memory.free(new_memories)
            return
        if new_sizes == 0:
            Memory.free(new_buffers)
            Memory.free(new_memories)
            Memory.free(new_frames)
            return
        if new_usages == 0:
            Memory.free(new_buffers)
            Memory.free(new_memories)
            Memory.free(new_frames)
            Memory.free(new_sizes)
            return
        Memory.copy(new_buffers, self.retire_buffers, self.retire_capacity * 8)
        Memory.copy(new_memories, self.retire_memories, self.retire_capacity * 8)
        Memory.copy(new_frames, self.retire_frames, self.retire_capacity * 4)
        Memory.copy(new_sizes, self.retire_sizes, self.retire_capacity * 8)
        Memory.copy(new_usages, self.retire_usages, self.retire_capacity * 4)
        Memory.free(self.retire_buffers)
        Memory.free(self.retire_memories)
        Memory.free(self.retire_frames)
        Memory.free(self.retire_sizes)
        Memory.free(self.retire_usages)
        self.retire_buffers = new_buffers
        self.retire_memories = new_memories
        self.retire_frames = new_frames
        self.retire_sizes = new_sizes
        self.retire_usages = new_usages
        self.retire_capacity = new_cap

    fun _retire_buffer_pair(self, buffer: i64, memory: i64, size: i64, usage: i32):
        if buffer == 0:
            return
        if memory == 0:
            return
        self._init_retire_queue()
        if self.retire_count >= self.retire_capacity:
            self._grow_retire_queue()
        if self.retire_count >= self.retire_capacity:
            return
        idx: i32 = self.retire_count
        Memory.write_ptr(self.retire_buffers + idx * 8, buffer)
        Memory.write_ptr(self.retire_memories + idx * 8, memory)
        Memory.write_i32(self.retire_frames + idx * 4, self.frame_serial)
        Memory.write_i64(self.retire_sizes + idx * 8, size)
        Memory.write_i32(self.retire_usages + idx * 4, usage)
        self.retire_count = idx + 1

    fun _release_retired_buffers(self):
        if self.retire_buffers == 0:
            return
        write_idx: i32 = 0
        i: i32 = 0
        while i < self.retire_count:
            queued_frame: i32 = Memory.read_i32(self.retire_frames + i * 4)
            age: i32 = self.frame_serial - queued_frame
            buffer: i64 = Memory.read_ptr(self.retire_buffers + i * 8)
            memory: i64 = Memory.read_ptr(self.retire_memories + i * 8)
            size: i64 = Memory.read_i64(self.retire_sizes + i * 8)
            usage: i32 = Memory.read_i32(self.retire_usages + i * 4)
            if age > 8:
                self._pool_buffer_pair(buffer, memory, size, usage)
            else:
                if write_idx != i:
                    Memory.write_ptr(self.retire_buffers + write_idx * 8, buffer)
                    Memory.write_ptr(self.retire_memories + write_idx * 8, memory)
                    Memory.write_i32(self.retire_frames + write_idx * 4, queued_frame)
                    Memory.write_i64(self.retire_sizes + write_idx * 8, size)
                    Memory.write_i32(self.retire_usages + write_idx * 4, usage)
                write_idx = write_idx + 1
            i = i + 1
        self.retire_count = write_idx

    fun _write_mesh_bounds(self, mesh_id: i32, vertices: i64, vertex_count: i32):
        if mesh_id < 0:
            return
        if mesh_id >= self.vb_capacity:
            return
        if self.mesh_bound_rs == 0:
            return
        bounds: GpuMeshBounds = _frog_mesh_bounds(vertices, vertex_count)
        Memory.write_f32(self.mesh_bound_xs + mesh_id * 4, bounds.center_x)
        Memory.write_f32(self.mesh_bound_ys + mesh_id * 4, bounds.center_y)
        Memory.write_f32(self.mesh_bound_zs + mesh_id * 4, bounds.center_z)
        Memory.write_f32(self.mesh_bound_rs + mesh_id * 4, bounds.radius)

    fun _copy_mesh_bounds(self, dst: i32, src: i32):
        if dst < 0:
            return
        if src < 0:
            return
        if dst >= self.vb_capacity:
            return
        if src >= self.vb_capacity:
            return
        if self.mesh_bound_rs == 0:
            return
        Memory.write_f32(self.mesh_bound_xs + dst * 4, Memory.read_f32(self.mesh_bound_xs + src * 4))
        Memory.write_f32(self.mesh_bound_ys + dst * 4, Memory.read_f32(self.mesh_bound_ys + src * 4))
        Memory.write_f32(self.mesh_bound_zs + dst * 4, Memory.read_f32(self.mesh_bound_zs + src * 4))
        Memory.write_f32(self.mesh_bound_rs + dst * 4, Memory.read_f32(self.mesh_bound_rs + src * 4))

    fun upload_mesh(self, vertices: i64, vertex_count: i32) -> i32:
        if self.initialized == 0:
            return 0 - 1
        if self.vb_count >= self.vb_capacity:
            self._grow_vb_arrays()
        data_size: i64 = (vertex_count as i64) * (FROG_GPU_VERTEX_STRIDE as i64)
        uploaded: GpuBufferUpload = self._upload_buffer(vertices, data_size, 128)
        if uploaded.ok == 0:
            return 0 - 1
        # Store
        idx: i32 = self.vb_count
        Memory.write_ptr(self.vb_handles + idx * 8, uploaded.handle)
        Memory.write_ptr(self.vb_memories + idx * 8, uploaded.memory)
        Memory.write_i64(self.vb_alloc_sizes + idx * 8, uploaded.capacity)
        Memory.write_i32(self.vb_vert_counts + idx * 4, vertex_count)
        Memory.write_ptr(self.ib_handles + idx * 8, 0)
        Memory.write_ptr(self.ib_memories + idx * 8, 0)
        Memory.write_i64(self.ib_alloc_sizes + idx * 8, 0)
        Memory.write_i32(self.ib_index_counts + idx * 4, 0)
        Memory.write_ptr(self.model_matrices + idx * 8, 0)
        self._write_mesh_bounds(idx, vertices, vertex_count)
        self.vb_count = idx + 1
        return idx

    fun upload_indexed_mesh(self, vertices: i64, vertex_count: i32, indices: i64, index_count: i32) -> i32:
        if self.initialized == 0:
            return 0 - 1
        if vertex_count <= 0:
            return 0 - 1
        if index_count <= 0:
            return 0 - 1
        if self.vb_count >= self.vb_capacity:
            self._grow_vb_arrays()
        vb_size: i64 = (vertex_count as i64) * (FROG_GPU_VERTEX_STRIDE as i64)
        ib_size: i64 = (index_count as i64) * 4
        uploaded_vb: GpuBufferUpload = self._upload_buffer(vertices, vb_size, 128)
        if uploaded_vb.ok == 0:
            return 0 - 1
        uploaded_ib: GpuBufferUpload = self._upload_buffer(indices, ib_size, 64)
        if uploaded_ib.ok == 0:
            vkDestroyBuffer(self.device, uploaded_vb.handle, 0)
            vkFreeMemory(self.device, uploaded_vb.memory, 0)
            return 0 - 1

        idx: i32 = self.vb_count
        Memory.write_ptr(self.vb_handles + idx * 8, uploaded_vb.handle)
        Memory.write_ptr(self.vb_memories + idx * 8, uploaded_vb.memory)
        Memory.write_i64(self.vb_alloc_sizes + idx * 8, uploaded_vb.capacity)
        Memory.write_i32(self.vb_vert_counts + idx * 4, vertex_count)
        Memory.write_ptr(self.ib_handles + idx * 8, uploaded_ib.handle)
        Memory.write_ptr(self.ib_memories + idx * 8, uploaded_ib.memory)
        Memory.write_i64(self.ib_alloc_sizes + idx * 8, uploaded_ib.capacity)
        Memory.write_i32(self.ib_index_counts + idx * 4, index_count)
        Memory.write_ptr(self.model_matrices + idx * 8, 0)
        self._write_mesh_bounds(idx, vertices, vertex_count)
        self.vb_count = idx + 1
        return idx

    fun replace_mesh_data(self, mesh_id: i32, mesh: GpuMeshData) -> i32:
        if self.initialized == 0:
            return 0 - 1
        if mesh_id < 0:
            return 0 - 1
        if mesh_id >= self.vb_count:
            return 0 - 1
        if mesh.vertices == 0:
            return 0 - 1
        if mesh.vertex_count <= 0:
            return 0 - 1

        old_shared_vb: i64 = Memory.read_ptr(self.vb_handles + mesh_id * 8)
        old_shared_ib: i64 = Memory.read_ptr(self.ib_handles + mesh_id * 8)
        si: i32 = 0
        while si < self.vb_count:
            if si != mesh_id:
                sm: i64 = Memory.read_ptr(self.vb_memories + si * 8)
                if sm == 0:
                    svb: i64 = Memory.read_ptr(self.vb_handles + si * 8)
                    sib: i64 = Memory.read_ptr(self.ib_handles + si * 8)
                    if svb == old_shared_vb:
                        return 0 - 1
                    if old_shared_ib != 0:
                        if sib == old_shared_ib:
                            return 0 - 1
            si = si + 1

        vb_size: i64 = (mesh.vertex_count as i64) * (FROG_GPU_VERTEX_STRIDE as i64)
        uploaded_vb: GpuBufferUpload = self._upload_buffer(mesh.vertices, vb_size, 128)
        if uploaded_vb.ok == 0:
            return 0 - 1

        uploaded_ib: GpuBufferUpload = GpuBufferUpload()
        if mesh.indices != 0:
            if mesh.index_count > 0:
                ib_size: i64 = (mesh.index_count as i64) * 4
                uploaded_ib = self._upload_buffer(mesh.indices, ib_size, 64)
                if uploaded_ib.ok == 0:
                    vkDestroyBuffer(self.device, uploaded_vb.handle, 0)
                    vkFreeMemory(self.device, uploaded_vb.memory, 0)
                    return 0 - 1

        old_vb: i64 = Memory.read_ptr(self.vb_handles + mesh_id * 8)
        old_vm: i64 = Memory.read_ptr(self.vb_memories + mesh_id * 8)
        if old_vm != 0:
            old_vb_size: i64 = Memory.read_i64(self.vb_alloc_sizes + mesh_id * 8)
            self._retire_buffer_pair(old_vb, old_vm, old_vb_size, 128)

        old_ib: i64 = Memory.read_ptr(self.ib_handles + mesh_id * 8)
        old_im: i64 = Memory.read_ptr(self.ib_memories + mesh_id * 8)
        if old_im != 0:
            old_ib_size: i64 = Memory.read_i64(self.ib_alloc_sizes + mesh_id * 8)
            self._retire_buffer_pair(old_ib, old_im, old_ib_size, 64)

        Memory.write_ptr(self.vb_handles + mesh_id * 8, uploaded_vb.handle)
        Memory.write_ptr(self.vb_memories + mesh_id * 8, uploaded_vb.memory)
        Memory.write_i64(self.vb_alloc_sizes + mesh_id * 8, uploaded_vb.capacity)
        Memory.write_i32(self.vb_vert_counts + mesh_id * 4, mesh.vertex_count)
        Memory.write_ptr(self.ib_handles + mesh_id * 8, uploaded_ib.handle)
        Memory.write_ptr(self.ib_memories + mesh_id * 8, uploaded_ib.memory)
        Memory.write_i64(self.ib_alloc_sizes + mesh_id * 8, uploaded_ib.capacity)
        Memory.write_i32(self.ib_index_counts + mesh_id * 4, mesh.index_count)
        self._write_mesh_bounds(mesh_id, mesh.vertices, mesh.vertex_count)
        return mesh_id

    # Register an instance that shares VkBuffer with source but gets own model matrix
    fun register_instance(self, src_vb_idx: i32) -> i32:
        if self.initialized == 0:
            return 0 - 1
        if src_vb_idx < 0:
            return 0 - 1
        if src_vb_idx >= self.vb_count:
            return 0 - 1
        if self.vb_count >= self.vb_capacity:
            self._grow_vb_arrays()
        idx: i32 = self.vb_count
        # Copy VkBuffer handle (shared), set memory to 0 (don't free on cleanup)
        src_handle: i64 = Memory.read_ptr(self.vb_handles + src_vb_idx * 8)
        src_vc: i32 = Memory.read_i32(self.vb_vert_counts + src_vb_idx * 4)
        src_ib_handle: i64 = Memory.read_ptr(self.ib_handles + src_vb_idx * 8)
        src_ic: i32 = Memory.read_i32(self.ib_index_counts + src_vb_idx * 4)
        Memory.write_ptr(self.vb_handles + idx * 8, src_handle)
        Memory.write_ptr(self.vb_memories + idx * 8, 0)
        Memory.write_i64(self.vb_alloc_sizes + idx * 8, 0)
        Memory.write_i32(self.vb_vert_counts + idx * 4, src_vc)
        Memory.write_ptr(self.ib_handles + idx * 8, src_ib_handle)
        Memory.write_ptr(self.ib_memories + idx * 8, 0)
        Memory.write_i64(self.ib_alloc_sizes + idx * 8, 0)
        Memory.write_i32(self.ib_index_counts + idx * 4, src_ic)
        Memory.write_ptr(self.model_matrices + idx * 8, 0)
        if self.mesh_tex_ids != 0:
            Memory.write_i32(self.mesh_tex_ids + idx * 4, Memory.read_i32(self.mesh_tex_ids + src_vb_idx * 4))
        if self.mesh_emissive_tex_ids != 0:
            Memory.write_i32(self.mesh_emissive_tex_ids + idx * 4, Memory.read_i32(self.mesh_emissive_tex_ids + src_vb_idx * 4))
        if self.mesh_desc_sets != 0:
            Memory.write_ptr(self.mesh_desc_sets + idx * 8, Memory.read_ptr(self.mesh_desc_sets + src_vb_idx * 8))
        if self.mesh_material_params != 0:
            Memory.copy(self.mesh_material_params + idx * 32, self.mesh_material_params + src_vb_idx * 32, 32)
        if self.mesh_shadow_flags != 0:
            Memory.write_i32(self.mesh_shadow_flags + idx * 4, Memory.read_i32(self.mesh_shadow_flags + src_vb_idx * 4))
        if self.mesh_shadow_distances != 0:
            Memory.write_f32(self.mesh_shadow_distances + idx * 4, Memory.read_f32(self.mesh_shadow_distances + src_vb_idx * 4))
        self._copy_mesh_bounds(idx, src_vb_idx)
        self.vb_count = idx + 1
        self._mark_cull_dirty_struct()
        return idx

    fun set_instance_visible(self, mesh_id: i32, on: i32):
        if self.vb_visible == 0:
            return
        if mesh_id < 0:
            return
        if mesh_id >= self.vb_count:
            return
        v: i32 = 1
        if on == 0:
            v = 0
        Memory.write_i32(self.vb_visible + mesh_id * 4, v)
        self._mark_cull_dirty_struct()

    fun set_model_matrix(self, vb_idx: i32, mat_ptr: i64) -> void:
        if vb_idx < 0:
            return
        if vb_idx >= self.vb_count:
            return
        if self.model_matrices == 0:
            return
        old_ptr: i64 = Memory.read_ptr(self.model_matrices + vb_idx * 8)
        if old_ptr != 0:
            if old_ptr != mat_ptr:
                Memory.free(old_ptr)
        Memory.write_ptr(self.model_matrices + vb_idx * 8, mat_ptr)
        # If this instance had NO model before, it was skipped by the cull
        # grouping (model_ptr==0) — now it participates, so the structure
        # changed: full rebuild. If it already had one, only the transform
        # binding changed: the cheap refresh suffices.
        if old_ptr == 0:
            self._mark_cull_dirty_struct()
        else:
            self._mark_cull_dirty()

    # Register an uploaded GpuTexture, creating its descriptor set via the render
    # pass. Returns the texture id (index into the registry) or -1 on failure.
    fun register_texture(self, rp: RenderPass, tex: GpuTexture) -> i32:
        if tex.ok == 0:
            return 0 - 1
        if self.tex_count >= self.tex_capacity:
            return 0 - 1
        dset: i64 = rp.make_texture_descriptor(self.device, tex.view, tex.sampler)
        if dset == 0:
            return 0 - 1
        idx: i32 = self.tex_count
        Memory.write_ptr(self.tex_views + idx * 8, tex.view)
        Memory.write_ptr(self.tex_samplers + idx * 8, tex.sampler)
        Memory.write_ptr(self.tex_images + idx * 8, tex.image)
        Memory.write_ptr(self.tex_memories + idx * 8, tex.memory)
        Memory.write_ptr(self.tex_desc_sets + idx * 8, dset)
        # Phase 1 task 1.3: ALSO register the texture in the bindless table
        # (in parallel with the classic per-texture descriptor set above). The
        # classic dset stays the active draw path until tasks 1.5/1.6; this
        # just populates the table so the slot index is ready. No-op (-1) when
        # bindless is disabled.
        if self.tex_bindless_slots != 0:
            bslot: i32 = self._bindless_register(tex.view, tex.sampler)
            Memory.write_i32(self.tex_bindless_slots + idx * 4, bslot)
            if self.bindless_enabled == 1:
                if idx == 0:
                    print(@"[frog.bindless] first texture -> slot {bslot}")
        self.tex_count = idx + 1
        return idx

    # Ensure the 1x1 white fallback texture exists (lazy init). Returns its id.
    fun ensure_white_texture(self, rp: RenderPass, cmd_pool: i64) -> i32:
        if self.white_tex_id >= 0:
            return self.white_tex_id
        wtex: GpuTexture = gpu_texture_make_white(self.device, self.phys_device, self.gfx_queue, cmd_pool)
        if wtex.ok == 0:
            return 0 - 1
        tid: i32 = self.register_texture(rp, wtex)
        if tid < 0:
            gpu_texture_destroy(self.device, wtex)
            return 0 - 1
        self.white_tex_id = tid
        self.white_desc_set = Memory.read_ptr(self.tex_desc_sets + tid * 8)
        return tid

    fun rebuild_texture_descriptors(self, rp: RenderPass) -> i32:
        if self.tex_desc_sets == 0:
            return self.rebuild_point_light_descriptors(rp)
        index: i32 = 0
        while index < self.tex_count:
            view: i64 = Memory.read_ptr(self.tex_views + index * 8)
            sampler: i64 = Memory.read_ptr(self.tex_samplers + index * 8)
            dset: i64 = rp.make_texture_descriptor(self.device, view, sampler)
            if dset == 0:
                return 0
            Memory.write_ptr(self.tex_desc_sets + index * 8, dset)
            index = index + 1
        self.white_desc_set = 0
        if self.white_tex_id >= 0:
            if self.white_tex_id < self.tex_count:
                self.white_desc_set = Memory.read_ptr(self.tex_desc_sets + self.white_tex_id * 8)
        if self.mesh_desc_sets != 0:
            Memory.zero(self.mesh_desc_sets, self.vb_capacity * 8)
        return self.rebuild_point_light_descriptors(rp)

    # Assign a texture id to a mesh/instance.
    fun bind_texture(self, mesh_id: i32, tex_id: i32):
        if mesh_id < 0:
            return
        if mesh_id >= self.vb_count:
            return
        if self.mesh_tex_ids == 0:
            return
        Memory.write_i32(self.mesh_tex_ids + mesh_id * 4, tex_id)
        if self.mesh_desc_sets != 0:
            Memory.write_ptr(self.mesh_desc_sets + mesh_id * 8, 0)

    fun bind_material(self, mesh_id: i32, material: Material3D):
        if mesh_id < 0:
            return
        if mesh_id >= self.vb_count:
            return
        if self.mesh_material_params == 0:
            return
        off: i64 = (mesh_id as i64) * 32
        Memory.write_f32(self.mesh_material_params + off, material.metallic)
        Memory.write_f32(self.mesh_material_params + off + 4, material.roughness)
        Memory.write_f32(self.mesh_material_params + off + 8, material.emissive_strength)
        Memory.write_f32(self.mesh_material_params + off + 12, _frog_pack_material(material))
        Memory.write_f32(self.mesh_material_params + off + 16, material.uv_scale_x)
        Memory.write_f32(self.mesh_material_params + off + 20, material.uv_scale_y)
        Memory.write_f32(self.mesh_material_params + off + 24, material.uv_offset_x)
        Memory.write_f32(self.mesh_material_params + off + 28, material.uv_offset_y)
        if self.mesh_emissive_tex_ids != 0:
            emissive_tex_id: i32 = 0 - 1
            if material.has_emissive_map == 1:
                emissive_tex_id = material.emissive_map.texture_id
            Memory.write_i32(self.mesh_emissive_tex_ids + mesh_id * 4, emissive_tex_id)
        if self.mesh_normal_tex_ids != 0:
            normal_tex_id: i32 = 0 - 1
            if material.has_normal_map == 1:
                normal_tex_id = material.normal_map.texture_id
            Memory.write_i32(self.mesh_normal_tex_ids + mesh_id * 4, normal_tex_id)
        if self.mesh_metallic_roughness_tex_ids != 0:
            metallic_roughness_tex_id: i32 = 0 - 1
            if material.has_metallic_roughness_map == 1:
                metallic_roughness_tex_id = material.metallic_roughness_map.texture_id
            Memory.write_i32(self.mesh_metallic_roughness_tex_ids + mesh_id * 4, metallic_roughness_tex_id)
        if self.mesh_occlusion_tex_ids != 0:
            occlusion_tex_id: i32 = 0 - 1
            if material.has_occlusion_map == 1:
                occlusion_tex_id = material.occlusion_map.texture_id
            Memory.write_i32(self.mesh_occlusion_tex_ids + mesh_id * 4, occlusion_tex_id)
        if self.mesh_desc_sets != 0:
            Memory.write_ptr(self.mesh_desc_sets + mesh_id * 8, 0)

    fun set_shadow_flags(self, mesh_id: i32, cast_shadows: i32, receive_shadows: i32):
        if mesh_id < 0:
            return
        if mesh_id >= self.vb_count:
            return
        if self.mesh_shadow_flags == 0:
            return
        cast_value: i32 = 1
        receive_value: i32 = 1
        if cast_shadows == 0:
            cast_value = 0
        if receive_shadows == 0:
            receive_value = 0
        Memory.write_i32(self.mesh_shadow_flags + mesh_id * 4, cast_value + receive_value * 2)

    fun set_shadow_distance(self, mesh_id: i32, distance: f32):
        if mesh_id < 0:
            return
        if mesh_id >= self.vb_count:
            return
        if self.mesh_shadow_distances == 0:
            return
        value: f32 = distance
        if value < 0.0:
            value = 0.0
        Memory.write_f32(self.mesh_shadow_distances + mesh_id * 4, value)

    fun mesh_descriptor_set(self, rp: RenderPass, mesh_id: i32) -> i64:
        if self.mesh_tex_ids == 0:
            return self.white_desc_set
        if self.mesh_desc_sets != 0:
            cached: i64 = Memory.read_ptr(self.mesh_desc_sets + mesh_id * 8)
            if cached != 0:
                return cached
        tid: i32 = Memory.read_i32(self.mesh_tex_ids + mesh_id * 4)
        if tid < 0 or tid >= self.tex_count:
            tid = self.white_tex_id
        emissive_tid: i32 = 0 - 1
        if self.mesh_emissive_tex_ids != 0:
            emissive_tid = Memory.read_i32(self.mesh_emissive_tex_ids + mesh_id * 4)
        normal_tid: i32 = 0 - 1
        if self.mesh_normal_tex_ids != 0:
            normal_tid = Memory.read_i32(self.mesh_normal_tex_ids + mesh_id * 4)
        metallic_roughness_tid: i32 = 0 - 1
        if self.mesh_metallic_roughness_tex_ids != 0:
            metallic_roughness_tid = Memory.read_i32(self.mesh_metallic_roughness_tex_ids + mesh_id * 4)
        occlusion_tid: i32 = 0 - 1
        if self.mesh_occlusion_tex_ids != 0:
            occlusion_tid = Memory.read_i32(self.mesh_occlusion_tex_ids + mesh_id * 4)
        if emissive_tid < 0 or emissive_tid >= self.tex_count:
            emissive_tid = self.white_tex_id
        if normal_tid < 0 or normal_tid >= self.tex_count:
            normal_tid = self.white_tex_id
        if metallic_roughness_tid < 0 or metallic_roughness_tid >= self.tex_count:
            metallic_roughness_tid = self.white_tex_id
        if occlusion_tid < 0 or occlusion_tid >= self.tex_count:
            occlusion_tid = self.white_tex_id
        if tid < 0:
            return self.white_desc_set
        if emissive_tid < 0:
            return self.white_desc_set
        if normal_tid < 0:
            return self.white_desc_set
        if metallic_roughness_tid < 0:
            return self.white_desc_set
        if occlusion_tid < 0:
            return self.white_desc_set
        albedo_view: i64 = Memory.read_ptr(self.tex_views + tid * 8)
        albedo_sampler: i64 = Memory.read_ptr(self.tex_samplers + tid * 8)
        emissive_view: i64 = Memory.read_ptr(self.tex_views + emissive_tid * 8)
        emissive_sampler: i64 = Memory.read_ptr(self.tex_samplers + emissive_tid * 8)
        normal_view: i64 = Memory.read_ptr(self.tex_views + normal_tid * 8)
        normal_sampler: i64 = Memory.read_ptr(self.tex_samplers + normal_tid * 8)
        metallic_roughness_view: i64 = Memory.read_ptr(self.tex_views + metallic_roughness_tid * 8)
        metallic_roughness_sampler: i64 = Memory.read_ptr(self.tex_samplers + metallic_roughness_tid * 8)
        occlusion_view: i64 = Memory.read_ptr(self.tex_views + occlusion_tid * 8)
        occlusion_sampler: i64 = Memory.read_ptr(self.tex_samplers + occlusion_tid * 8)
        images: MaterialDescriptorImages = MaterialDescriptorImages(albedo_view=albedo_view, albedo_sampler=albedo_sampler, emissive_view=emissive_view, emissive_sampler=emissive_sampler, normal_view=normal_view, normal_sampler=normal_sampler, metallic_roughness_view=metallic_roughness_view, metallic_roughness_sampler=metallic_roughness_sampler, occlusion_view=occlusion_view, occlusion_sampler=occlusion_sampler)
        dset: i64 = rp.make_material_descriptor(self.device, images)
        if dset == 0:
            return self.white_desc_set
        if self.mesh_desc_sets != 0:
            Memory.write_ptr(self.mesh_desc_sets + mesh_id * 8, dset)
        return dset

    fun texture_descriptor_set(self, tex_id: i32) -> i64:
        if self.tex_desc_sets == 0:
            return self.white_desc_set
        if tex_id < 0:
            return self.white_desc_set
        if tex_id >= self.tex_count:
            return self.white_desc_set
        return Memory.read_ptr(self.tex_desc_sets + tex_id * 8)

    fun scale_descriptor_set(self, rp: RenderPass) -> i64:
        if self.scale_desc_set != 0:
            return self.scale_desc_set
        if self.scale_color_view == 0:
            return self.white_desc_set
        if self.scale_sampler == 0:
            return self.white_desc_set
        dset: i64 = rp.make_texture_descriptor(self.device, self.scale_color_view, self.scale_sampler)
        if dset == 0:
            return self.white_desc_set
        self.scale_desc_set = dset
        return dset

    fun destroy_render_scale_target(self):
        self.scale_desc_set = 0
        if self.scale_framebuffer != 0:
            vkDestroyFramebuffer(self.device, self.scale_framebuffer, 0)
            self.scale_framebuffer = 0
        if self.scale_sampler != 0:
            vkDestroySampler(self.device, self.scale_sampler, 0)
            self.scale_sampler = 0
        if self.scale_color_view != 0:
            vkDestroyImageView(self.device, self.scale_color_view, 0)
            self.scale_color_view = 0
        if self.scale_color_image != 0:
            vkDestroyImage(self.device, self.scale_color_image, 0)
            self.scale_color_image = 0
        if self.scale_color_memory != 0:
            vkFreeMemory(self.device, self.scale_color_memory, 0)
            self.scale_color_memory = 0
        if self.scale_depth_view != 0:
            vkDestroyImageView(self.device, self.scale_depth_view, 0)
            self.scale_depth_view = 0
        if self.scale_depth_image != 0:
            vkDestroyImage(self.device, self.scale_depth_image, 0)
            self.scale_depth_image = 0
        if self.scale_depth_memory != 0:
            vkFreeMemory(self.device, self.scale_depth_memory, 0)
            self.scale_depth_memory = 0
        self.scale_width = 0
        self.scale_height = 0
        self.scale_format = 0

    fun ensure_render_scale_target(self, rp: RenderPass, color_format: i32, width: i32, height: i32) -> i32:
        if width <= 0:
            return 0
        if height <= 0:
            return 0
        if self.scale_framebuffer != 0:
            if self.scale_width == width:
                if self.scale_height == height:
                    if self.scale_format == color_format:
                        return 1

        if self.scale_framebuffer != 0:
            vkDeviceWaitIdle(self.device)
            self.destroy_render_scale_target()

        color_out: i64 = Memory.malloc_zeroed(8)
        color_mem_out: i64 = Memory.malloc_zeroed(8)
        if color_out == 0:
            return 0
        if color_mem_out == 0:
            Memory.free(color_out)
            return 0
        # TRANSFER_SRC(1) | SAMPLED(4) | COLOR_ATTACHMENT(16)
        if gpu_make_image_usage(self.device, self.phys_device, width, height, color_format, 21, color_out, color_mem_out) == 0:
            Memory.free(color_out)
            Memory.free(color_mem_out)
            return 0
        self.scale_color_image = Memory.read_ptr(color_out)
        self.scale_color_memory = Memory.read_ptr(color_mem_out)
        Memory.free(color_out)
        Memory.free(color_mem_out)

        self.scale_color_view = gpu_make_image_view_aspect(self.device, self.scale_color_image, color_format, 1)
        if self.scale_color_view == 0:
            self.destroy_render_scale_target()
            return 0
        scale_spec: TextureSpec = TextureSpec.smooth()
        scale_spec = scale_spec.wrap(2)
        self.scale_sampler = gpu_tex_make_sampler(self.device, scale_spec)
        if self.scale_sampler == 0:
            self.destroy_render_scale_target()
            return 0

        depth_out: i64 = Memory.malloc_zeroed(8)
        depth_mem_out: i64 = Memory.malloc_zeroed(8)
        if depth_out == 0:
            self.destroy_render_scale_target()
            return 0
        if depth_mem_out == 0:
            Memory.free(depth_out)
            self.destroy_render_scale_target()
            return 0
        # DEPTH_STENCIL_ATTACHMENT(32), VK_FORMAT_D32_SFLOAT(126)
        if gpu_make_image_usage(self.device, self.phys_device, width, height, 126, 32, depth_out, depth_mem_out) == 0:
            Memory.free(depth_out)
            Memory.free(depth_mem_out)
            self.destroy_render_scale_target()
            return 0
        self.scale_depth_image = Memory.read_ptr(depth_out)
        self.scale_depth_memory = Memory.read_ptr(depth_mem_out)
        Memory.free(depth_out)
        Memory.free(depth_mem_out)

        self.scale_depth_view = gpu_make_image_view_aspect(self.device, self.scale_depth_image, 126, 2)
        if self.scale_depth_view == 0:
            self.destroy_render_scale_target()
            return 0

        att_arr: i64 = Memory.malloc_zeroed(16)
        if att_arr == 0:
            self.destroy_render_scale_target()
            return 0
        Memory.write_ptr(att_arr, self.scale_color_view)
        Memory.write_ptr(att_arr + 8, self.scale_depth_view)

        fb_ci: i64 = Memory.malloc_zeroed(64)
        if fb_ci == 0:
            Memory.free(att_arr)
            self.destroy_render_scale_target()
            return 0
        Memory.set(fb_ci, 0, 64)
        Memory.write_i32(fb_ci, 37)
        Memory.write_ptr(fb_ci + 24, rp.vk_render_pass)
        Memory.write_i32(fb_ci + 32, 2)
        Memory.write_ptr(fb_ci + 40, att_arr)
        Memory.write_i32(fb_ci + 48, width)
        Memory.write_i32(fb_ci + 52, height)
        Memory.write_i32(fb_ci + 56, 1)
        fb_ptr: i64 = Memory.malloc_zeroed(8)
        if fb_ptr == 0:
            Memory.free(att_arr)
            Memory.free(fb_ci)
            self.destroy_render_scale_target()
            return 0
        fb_r: i32 = vkCreateFramebuffer(self.device, fb_ci, 0, fb_ptr)
        self.scale_framebuffer = Memory.read_ptr(fb_ptr)
        Memory.free(fb_ptr)
        Memory.free(att_arr)
        Memory.free(fb_ci)
        if fb_r != 0:
            self.destroy_render_scale_target()
            return 0

        self.scale_width = width
        self.scale_height = height
        self.scale_format = color_format
        return 1

    fun _record_render_scale_blit(self, cmd: i64, src_image: i64, dst_image: i64, dst_old_layout: i32, src_width: i32, src_height: i32, dst_width: i32, dst_height: i32):
        if src_image == 0:
            return
        if dst_image == 0:
            return

        # Color attachment -> transfer source.
        gpu_tex_barrier(cmd, src_image, 2, 6, 256, 2048, 1024, 4096)
        # Swapchain image -> transfer destination.
        gpu_tex_barrier(cmd, dst_image, dst_old_layout, 7, 0, 4096, 1, 4096)

        # VkImageBlit = srcSubresource + srcOffsets[2] + dstSubresource + dstOffsets[2].
        blit: i64 = Memory.malloc_zeroed(80)
        if blit != 0:
            Memory.write_i32(blit, 1)          # src aspect color
            Memory.write_i32(blit + 12, 1)     # src layerCount
            Memory.write_i32(blit + 28, src_width)
            Memory.write_i32(blit + 32, src_height)
            Memory.write_i32(blit + 36, 1)
            Memory.write_i32(blit + 40, 1)     # dst aspect color
            Memory.write_i32(blit + 52, 1)     # dst layerCount
            Memory.write_i32(blit + 68, dst_width)
            Memory.write_i32(blit + 72, dst_height)
            Memory.write_i32(blit + 76, 1)
            vkCmdBlitImage(cmd, src_image, 6, dst_image, 7, 1, blit, 1)
            Memory.free(blit)

        # Return images to reusable/presentable layouts.
        gpu_tex_barrier(cmd, src_image, 6, 2, 2048, 256, 4096, 1024)
        gpu_tex_barrier(cmd, dst_image, 7, 1000001002, 4096, 0, 4096, 8192)

    fun _sky_lerp_color(self, a: Color, b: Color, t_in: f32) -> Color:
        t: f32 = t_in
        if t < 0.0:
            t = 0.0
        if t > 1.0:
            t = 1.0
        inv: f32 = 1.0 - t
        return Color.rgba(a.r * inv + b.r * t, a.g * inv + b.g * t, a.b * inv + b.b * t, 1.0)

    fun _sky_world_color(self, sky: Sky, world_y_in: f32) -> Color:
        world_y: f32 = world_y_in
        if world_y < 0.0 - 1.0:
            world_y = 0.0 - 1.0
        if world_y > 1.0:
            world_y = 1.0
        if world_y >= 0.0:
            return self._sky_lerp_color(sky.horizon_color, sky.zenith_color, world_y)
        t: f32 = 0.0 - world_y
        return self._sky_lerp_color(sky.horizon_color, sky.lower_color, t)

    fun _sky_draw_clear_rect(self, cmd: i64, att: i64, rect: i64, x: i32, y: i32, w: i32, h: i32, color: Color):
        if w <= 0:
            return
        if h <= 0:
            return
        if att == 0:
            return
        if rect == 0:
            return
        Memory.write_i32(att, 1)
        Memory.write_i32(att + 4, 0)
        Memory.write_f32(att + 8, color.r)
        Memory.write_f32(att + 12, color.g)
        Memory.write_f32(att + 16, color.b)
        Memory.write_f32(att + 20, color.a)
        Memory.write_i32(rect, x)
        Memory.write_i32(rect + 4, y)
        Memory.write_i32(rect + 8, w)
        Memory.write_i32(rect + 12, h)
        Memory.write_i32(rect + 16, 0)
        Memory.write_i32(rect + 20, 1)
        vkCmdClearAttachments(cmd, 1, att, 1, rect)

    fun _sky_star_hash(self, index: i32, salt: i32) -> f32:
        # Two rounds of modular squaring decorrelate nearby indices and salts.
        # The previous linear hash made altitude and azimuth advance together,
        # which projected the stars as a visible arc.
        value: i64 = (index as i64) * 1103515245 + (salt as i64) * 123457 + 1013904223
        if value < 0:
            value = 0 - value
        value = value % 2147483647
        value = (value * value + (salt as i64) * 265443 + 97) % 2147483647
        value = (value * value + (index as i64) * 224737 + 193) % 2147483647
        return ((value % 1000000) as f32) / 1000000.0

    fun _sky_draw_stars(self, cmd: i64, att: i64, rect: i64, width: i32, height: i32, sky: Sky, cam_view: i64, cam_proj: i64):
        if sky.star_strength <= 0.0:
            return
        if cam_view == 0 or cam_proj == 0:
            return
        max_stars: i32 = sky.star_count
        if max_stars > 180:
            max_stars = 180
        si: i32 = 0
        while si < max_stars:
            azimuth: f32 = self._sky_star_hash(si + 1, 3) * 6.28318530
            world_y: f32 = self._sky_star_hash(si + 1, 11) * 2.0 - 1.0
            radial_sq: f32 = 1.0 - world_y * world_y
            if radial_sq < 0.0:
                radial_sq = 0.0
            radial: f32 = @sqrt(radial_sq)
            world_x: f32 = @cos(azimuth) * radial
            world_z: f32 = @sin(azimuth) * radial

            view_x: f32 = Memory.read_f32(cam_view) * world_x + Memory.read_f32(cam_view + 16) * world_y + Memory.read_f32(cam_view + 32) * world_z
            view_y: f32 = Memory.read_f32(cam_view + 4) * world_x + Memory.read_f32(cam_view + 20) * world_y + Memory.read_f32(cam_view + 36) * world_z
            view_z: f32 = Memory.read_f32(cam_view + 8) * world_x + Memory.read_f32(cam_view + 24) * world_y + Memory.read_f32(cam_view + 40) * world_z
            if view_z < -0.0001:
                clip_w: f32 = 0.0 - view_z
                ndc_x: f32 = Memory.read_f32(cam_proj) * view_x / clip_w
                ndc_y: f32 = Memory.read_f32(cam_proj + 20) * view_y / clip_w
                if ndc_x >= -1.0:
                    if ndc_x <= 1.0:
                        if ndc_y >= -1.0:
                            if ndc_y <= 1.0:
                                sx: i32 = ((ndc_x * 0.5 + 0.5) * (width as f32)) as i32
                                sy: i32 = ((ndc_y * 0.5 + 0.5) * (height as f32)) as i32
                                size: i32 = 1
                                if self._sky_star_hash(si + 1, 23) > 0.92:
                                    size = 2
                                base: Color = self._sky_world_color(sky, world_y)
                                star: Color = self._sky_lerp_color(base, sky.star_color, sky.star_strength)
                                self._sky_draw_clear_rect(cmd, att, rect, sx, sy, size, size, star)
            si = si + 1

    fun _sky_draw_circle(self, cmd: i64, att: i64, rect: i64, width: i32, height: i32, center_x: i32, center_y: i32, radius: i32, color: Color):
        if radius <= 0:
            return
        slices: i32 = 24
        diameter: i32 = radius * 2
        slice_index: i32 = 0
        while slice_index < slices:
            y0: i32 = center_y - radius + (diameter * slice_index) / slices
            y1: i32 = center_y - radius + (diameter * (slice_index + 1)) / slices
            if y1 <= y0:
                y1 = y0 + 1
            middle_y: f32 = ((y0 + y1) as f32) * 0.5 - (center_y as f32)
            radius_f: f32 = radius as f32
            width_sq: f32 = radius_f * radius_f - middle_y * middle_y
            if width_sq > 0.0:
                half_width: i32 = @sqrt(width_sq) as i32
                x0: i32 = center_x - half_width
                x1: i32 = center_x + half_width
                clipped_y0: i32 = y0
                clipped_y1: i32 = y1
                if x0 < 0:
                    x0 = 0
                if x1 > width:
                    x1 = width
                if clipped_y0 < 0:
                    clipped_y0 = 0
                if clipped_y1 > height:
                    clipped_y1 = height
                if x1 > x0:
                    if clipped_y1 > clipped_y0:
                        self._sky_draw_clear_rect(cmd, att, rect, x0, clipped_y0, x1 - x0, clipped_y1 - clipped_y0, color)
            slice_index = slice_index + 1

    fun _sky_draw_light_disc(self, cmd: i64, att: i64, rect: i64, width: i32, height: i32, sky: Sky, cam_view: i64, cam_proj: i64, light_ptr: i64, enabled: i32, disc_color: Color, disc_size: f32, disc_glow: f32, disc_softness: f32):
        if enabled == 0:
            return
        if light_ptr == 0:
            return
        if cam_view == 0 or cam_proj == 0:
            return
        light: DirectionalLight3D = light_ptr as DirectionalLight3D
        if light.active == 0:
            return

        # A directional light stores the direction travelled by its rays.
        # The visible sky body is located in the opposite world direction.
        world_x: f32 = 0.0 - light.dir_x
        world_y: f32 = 0.0 - light.dir_y
        world_z: f32 = 0.0 - light.dir_z

        view_x: f32 = Memory.read_f32(cam_view) * world_x + Memory.read_f32(cam_view + 16) * world_y + Memory.read_f32(cam_view + 32) * world_z
        view_y: f32 = Memory.read_f32(cam_view + 4) * world_x + Memory.read_f32(cam_view + 20) * world_y + Memory.read_f32(cam_view + 36) * world_z
        view_z: f32 = Memory.read_f32(cam_view + 8) * world_x + Memory.read_f32(cam_view + 24) * world_y + Memory.read_f32(cam_view + 40) * world_z
        if view_z >= -0.0001:
            return

        clip_w: f32 = 0.0 - view_z
        ndc_x: f32 = Memory.read_f32(cam_proj) * view_x / clip_w
        ndc_y: f32 = Memory.read_f32(cam_proj + 20) * view_y / clip_w
        center_x: i32 = ((ndc_x * 0.5 + 0.5) * (width as f32)) as i32
        center_y: i32 = ((ndc_y * 0.5 + 0.5) * (height as f32)) as i32

        short_side: i32 = width
        if height < short_side:
            short_side = height
        # disc_size is an angular sky size, not a fixed screen-space sprite.
        # Match the camera projection and increase the projected size toward
        # screen edges, just like world geometry under perspective projection.
        projection_scale: f32 = Memory.read_f32(cam_proj + 20)
        if projection_scale < 0.0:
            projection_scale = 0.0 - projection_scale
        projection_scale = projection_scale / 0.96569
        edge_scale: f32 = 1.0 / clip_w
        if edge_scale > 2.5:
            edge_scale = 2.5
        radius: i32 = ((short_side as f32) * disc_size * projection_scale * edge_scale) as i32
        if radius < 2:
            radius = 2
        outer_radius: i32 = (radius as f32 * (2.2 + disc_glow * 2.0)) as i32
        if center_x + outer_radius < 0 or center_x - outer_radius >= width:
            return
        if center_y + outer_radius < 0 or center_y - outer_radius >= height:
            return

        base: Color = self._sky_world_color(sky, world_y)
        if disc_glow > 0.0:
            if disc_softness <= 0.0:
                outer: Color = self._sky_lerp_color(base, disc_color, disc_glow * 0.08)
                middle: Color = self._sky_lerp_color(base, disc_color, disc_glow * 0.16)
                inner: Color = self._sky_lerp_color(base, disc_color, disc_glow * 0.32)
                middle_radius: i32 = (radius as f32 * (1.55 + disc_glow)) as i32
                inner_radius: i32 = (radius as f32 * (1.15 + disc_glow * 0.45)) as i32
                self._sky_draw_circle(cmd, att, rect, width, height, center_x, center_y, outer_radius, outer)
                self._sky_draw_circle(cmd, att, rect, width, height, center_x, center_y, middle_radius, middle)
                self._sky_draw_circle(cmd, att, rect, width, height, center_x, center_y, inner_radius, inner)
            else:
                ring_count: i32 = 5 + (disc_softness * 7.0) as i32
                if ring_count < 5:
                    ring_count = 5
                if ring_count > 12:
                    ring_count = 12
                ring: i32 = ring_count
                outer_f: f32 = outer_radius as f32
                core_f: f32 = radius as f32 * (1.0 - disc_softness * 0.22)
                if core_f < 2.0:
                    core_f = 2.0
                while ring > 0:
                    t: f32 = (ring as f32) / (ring_count as f32)
                    inv: f32 = 1.0 - t
                    rr: i32 = (core_f + (outer_f - core_f) * t) as i32
                    strength: f32 = disc_glow * (0.055 + inv * inv * 0.42)
                    col: Color = self._sky_lerp_color(base, disc_color, strength)
                    self._sky_draw_circle(cmd, att, rect, width, height, center_x, center_y, rr, col)
                    ring = ring - 1
                core_halo_radius: i32 = (radius as f32 * (1.0 + disc_softness * 0.28)) as i32
                core_halo: Color = self._sky_lerp_color(base, disc_color, 0.62 + disc_softness * 0.18)
                self._sky_draw_circle(cmd, att, rect, width, height, center_x, center_y, core_halo_radius, core_halo)
        core_radius: i32 = radius
        if disc_softness > 0.0:
            core_radius = (radius as f32 * (1.0 - disc_softness * 0.18)) as i32
            if core_radius < 2:
                core_radius = 2
        self._sky_draw_circle(cmd, att, rect, width, height, center_x, center_y, core_radius, disc_color)

    fun _sky_draw_sun(self, cmd: i64, att: i64, rect: i64, width: i32, height: i32, sky: Sky, cam_view: i64, cam_proj: i64):
        self._sky_draw_light_disc(cmd, att, rect, width, height, sky, cam_view, cam_proj, sky.sun_light_ptr, sky.sun_enabled, sky.sun_color, sky.sun_size, sky.sun_glow, sky.sun_softness)

    fun _sky_draw_moon(self, cmd: i64, att: i64, rect: i64, width: i32, height: i32, sky: Sky, cam_view: i64, cam_proj: i64):
        self._sky_draw_light_disc(cmd, att, rect, width, height, sky, cam_view, cam_proj, sky.moon_light_ptr, sky.moon_enabled, sky.moon_color, sky.moon_size, sky.moon_glow, sky.moon_softness)

    fun _record_sky_texture_object(self, cmd: i64, width: i32, height: i32, sky: Sky, cam_view: i64, cam_proj: i64, light_ptr: i64, has_direction: i32, dir_x: f32, dir_y: f32, dir_z: f32, enabled: i32, texture_id: i32, color: Color, size: f32):
        if enabled == 0:
            return
        if frog_sky_pass_ready() == 0:
            return
        sky_pipeline: i64 = frog_sky_pass_pipeline()
        sky_layout: i64 = frog_sky_pass_layout()
        if sky_pipeline == 0 or sky_layout == 0:
            return
        if cam_view == 0 or cam_proj == 0:
            return

        world_x: f32 = dir_x
        world_y: f32 = dir_y
        world_z: f32 = dir_z
        active: i32 = 0
        if light_ptr != 0:
            light: DirectionalLight3D = light_ptr as DirectionalLight3D
            if light.active != 0:
                active = 1
                world_x = 0.0 - light.dir_x
                world_y = 0.0 - light.dir_y
                world_z = 0.0 - light.dir_z
        else:
            if has_direction != 0:
                active = 1
        if active == 0:
            return

        object_glow: f32 = sky.sun_glow
        object_softness: f32 = sky.sun_softness
        if light_ptr == sky.moon_light_ptr:
            object_glow = sky.moon_glow
            object_softness = sky.moon_softness

        object_mode: f32 = 2.0
        desc: i64 = 0
        if texture_id >= 0:
            desc = self.texture_descriptor_set(texture_id)
        else:
            object_mode = 3.0
            desc = self.texture_descriptor_set(-1)
        if desc == 0:
            return
        viewport: i64 = self.scratch_viewport
        scissor: i64 = self.scratch_scissor
        push_data: i64 = self.scratch_push_data
        if viewport == 0 or scissor == 0 or push_data == 0:
            return

        vkCmdBindPipeline(cmd, 0, sky_pipeline)
        Memory.write_ptr(self.scratch_desc_arr, desc)
        vkCmdBindDescriptorSets(cmd, 0, sky_layout, 0, 1, self.scratch_desc_arr, 0, 0)

        Memory.set(viewport, 0, 24)
        Memory.write_f32(viewport + 8, width as f32)
        Memory.write_f32(viewport + 12, height as f32)
        Memory.write_f32(viewport + 20, 1.0)
        vkCmdSetViewport(cmd, 0, 1, viewport)

        Memory.set(scissor, 0, 16)
        Memory.write_i32(scissor + 8, width)
        Memory.write_i32(scissor + 12, height)
        vkCmdSetScissor(cmd, 0, 1, scissor)

        Memory.set(push_data, 0, 128)
        Memory.copy(push_data, cam_view, 64)
        Memory.write_f32(push_data + 12, world_x)
        Memory.write_f32(push_data + 28, world_y)
        Memory.write_f32(push_data + 44, world_z)
        Memory.write_f32(push_data + 48, color.r)
        Memory.write_f32(push_data + 52, color.g)
        Memory.write_f32(push_data + 56, color.b)
        Memory.write_f32(push_data + 60, object_mode)
        Memory.write_f32(push_data + 64, sky.zenith_color.r)
        Memory.write_f32(push_data + 68, sky.zenith_color.g)
        Memory.write_f32(push_data + 72, sky.zenith_color.b)
        Memory.write_f32(push_data + 76, size)
        Memory.write_f32(push_data + 80, sky.horizon_color.r)
        Memory.write_f32(push_data + 84, sky.horizon_color.g)
        Memory.write_f32(push_data + 88, sky.horizon_color.b)
        if texture_id >= 0:
            Memory.write_f32(push_data + 92, frog_sky_texture_size(texture_id))
        else:
            Memory.write_f32(push_data + 92, object_glow)
        Memory.write_f32(push_data + 96, sky.lower_color.r)
        Memory.write_f32(push_data + 100, sky.lower_color.g)
        Memory.write_f32(push_data + 104, sky.lower_color.b)
        if texture_id >= 0:
            Memory.write_f32(push_data + 108, 0.0)
        else:
            Memory.write_f32(push_data + 108, object_softness)
        Memory.write_f32(push_data + 112, Memory.read_f32(cam_proj))
        Memory.write_f32(push_data + 116, Memory.read_f32(cam_proj + 20))
        Memory.write_f32(push_data + 120, width as f32)
        Memory.write_f32(push_data + 124, height as f32)
        vkCmdPushConstants(cmd, sky_layout, 16, 0, 128, push_data)
        vkCmdDraw(cmd, 3, 1, 0, 0)

    fun _record_sky(self, cmd: i64, width: i32, height: i32, sky: Sky, cam_view: i64, cam_proj: i64):
        if sky.enabled() == 0:
            return
        if width <= 0:
            return
        if height <= 0:
            return
        if cam_view == 0 or cam_proj == 0:
            return

        if frog_sky_pass_ready() != 0:
            sky_pipeline: i64 = frog_sky_pass_pipeline()
            sky_layout: i64 = frog_sky_pass_layout()
            if sky_pipeline != 0 and sky_layout != 0:
                vkCmdBindPipeline(cmd, 0, sky_pipeline)
                base_desc: i64 = self.texture_descriptor_set(-1)
                if base_desc != 0:
                    Memory.write_ptr(self.scratch_desc_arr, base_desc)
                    vkCmdBindDescriptorSets(cmd, 0, sky_layout, 0, 1, self.scratch_desc_arr, 0, 0)
                viewport: i64 = self.scratch_viewport
                scissor: i64 = self.scratch_scissor
                push_data: i64 = self.scratch_push_data
                if viewport != 0 and scissor != 0 and push_data != 0:
                    Memory.set(viewport, 0, 24)
                    Memory.write_f32(viewport + 8, width as f32)
                    Memory.write_f32(viewport + 12, height as f32)
                    Memory.write_f32(viewport + 20, 1.0)
                    vkCmdSetViewport(cmd, 0, 1, viewport)

                    Memory.set(scissor, 0, 16)
                    Memory.write_i32(scissor + 8, width)
                    Memory.write_i32(scissor + 12, height)
                    vkCmdSetScissor(cmd, 0, 1, scissor)

                    Memory.set(push_data, 0, 128)
                    Memory.copy(push_data, cam_view, 64)
                    sun_enabled: i32 = 0
                    sun_dir_x: f32 = 0.0
                    sun_dir_y: f32 = 1.0
                    sun_dir_z: f32 = 0.0
                    if sky.sun_enabled == 1:
                        if sky.sun_light_ptr != 0:
                            sun_light: DirectionalLight3D = sky.sun_light_ptr as DirectionalLight3D
                            if sun_light.active != 0:
                                sun_enabled = 1
                                sun_dir_x = 0.0 - sun_light.dir_x
                                sun_dir_y = 0.0 - sun_light.dir_y
                                sun_dir_z = 0.0 - sun_light.dir_z
                        else:
                            if sky.sun_has_direction != 0:
                                sun_enabled = 1
                                sun_dir_x = sky.sun_dir_x
                                sun_dir_y = sky.sun_dir_y
                                sun_dir_z = sky.sun_dir_z
                    # The sky shader only needs the top-left 3x3 of the view
                    # matrix. Pack the primary sky object into unused matrix
                    # slots to keep
                    # the sky push constants within Vulkan's 128-byte minimum.
                    Memory.write_f32(push_data + 12, sun_dir_x)
                    Memory.write_f32(push_data + 28, sun_dir_y)
                    Memory.write_f32(push_data + 44, sun_dir_z)
                    Memory.write_f32(push_data + 48, sky.sun_color.r)
                    Memory.write_f32(push_data + 52, sky.sun_color.g)
                    Memory.write_f32(push_data + 56, sky.sun_color.b)
                    Memory.write_f32(push_data + 60, 0.0)
                    Memory.write_f32(push_data + 64, sky.zenith_color.r)
                    Memory.write_f32(push_data + 68, sky.zenith_color.g)
                    Memory.write_f32(push_data + 72, sky.zenith_color.b)
                    Memory.write_f32(push_data + 76, sky.sun_size)
                    Memory.write_f32(push_data + 80, sky.horizon_color.r)
                    Memory.write_f32(push_data + 84, sky.horizon_color.g)
                    Memory.write_f32(push_data + 88, sky.horizon_color.b)
                    Memory.write_f32(push_data + 92, sky.sun_glow)
                    Memory.write_f32(push_data + 96, sky.lower_color.r)
                    Memory.write_f32(push_data + 100, sky.lower_color.g)
                    Memory.write_f32(push_data + 104, sky.lower_color.b)
                    Memory.write_f32(push_data + 108, sky.sun_softness)
                    Memory.write_f32(push_data + 112, Memory.read_f32(cam_proj))
                    Memory.write_f32(push_data + 116, Memory.read_f32(cam_proj + 20))
                    Memory.write_f32(push_data + 120, width as f32)
                    Memory.write_f32(push_data + 124, height as f32)
                    vkCmdPushConstants(cmd, sky_layout, 16, 0, 128, push_data)
                    vkCmdDraw(cmd, 3, 1, 0, 0)

        att: i64 = self.scratch_sky_att
        rect: i64 = self.scratch_sky_rect
        if att == 0:
            return
        if rect == 0:
            return
        Memory.set(att, 0, 24)
        Memory.set(rect, 0, 24)

        self._sky_draw_stars(cmd, att, rect, width, height, sky, cam_view, cam_proj)
        self._record_sky_texture_object(cmd, width, height, sky, cam_view, cam_proj, sky.sun_light_ptr, sky.sun_has_direction, sky.sun_dir_x, sky.sun_dir_y, sky.sun_dir_z, sky.sun_enabled, sky.sun_texture_id, sky.sun_color, sky.sun_size)
        self._record_sky_texture_object(cmd, width, height, sky, cam_view, cam_proj, sky.moon_light_ptr, sky.moon_has_direction, sky.moon_dir_x, sky.moon_dir_y, sky.moon_dir_z, sky.moon_enabled, sky.moon_texture_id, sky.moon_color, sky.moon_size)
    fun render_frame(self, rp: RenderPass, sc: Swapchain, device: i64, gfx_queue: i64, present_queue: i64, cam_view: i64, cam_proj: i64, width: i32, height: i32) -> void:
        self.render_frame_scaled_with_environment(rp, sc, device, gfx_queue, present_queue, cam_view, cam_proj, width, height, width, height, Environment.create())

    fun render_frame_with_environment(self, rp: RenderPass, sc: Swapchain, device: i64, gfx_queue: i64, present_queue: i64, cam_view: i64, cam_proj: i64, width: i32, height: i32, env: Environment) -> void:
        self.render_frame_scaled_with_environment(rp, sc, device, gfx_queue, present_queue, cam_view, cam_proj, width, height, width, height, env)

    fun render_frame_scaled(self, rp: RenderPass, sc: Swapchain, device: i64, gfx_queue: i64, present_queue: i64, cam_view: i64, cam_proj: i64, width: i32, height: i32, render_width: i32, render_height: i32) -> void:
        self.render_frame_scaled_with_environment(rp, sc, device, gfx_queue, present_queue, cam_view, cam_proj, width, height, render_width, render_height, Environment.create())

    fun render_frame_scaled_with_environment(self, rp: RenderPass, sc: Swapchain, device: i64, gfx_queue: i64, present_queue: i64, cam_view: i64, cam_proj: i64, width: i32, height: i32, render_width: i32, render_height: i32, env: Environment) -> void:
        if rp.frame_initialized == 0:
            return
        if rp.vk_command_buffers == 0:
            return
        if rp.in_flight_fences == 0:
            return
        self._ensure_shadow_target(rp)

        # Resolve CPU vs GPU-driven culling for this frame (mode-driven).
        self._resolve_culling_mode()

        current_fence: i64 = Memory.read_ptr(rp.in_flight_fences + self.current_frame * 8)
        Memory.write_ptr(rp.frame_fence_arr, current_fence)
        vkWaitForFences(device, 1, rp.frame_fence_arr, 1, 0 - 1)

        # GPU cull verification path (no render change): prints visible
        # counts for comparison with the CPU. Off by default; opt-in only via
        # set_gpu_cull_verify(1) for debugging.
        if self.gpu_cull_verify_enabled == 1:
            if self.gpu_draw_enabled == 0:
                verify_vp: i64 = self.scratch_vp_matrix
                if verify_vp != 0:
                    if cam_view != 0:
                        if cam_proj != 0:
                            _frog_multiply_4x4_into(cam_proj, cam_view, verify_vp)
                            self.gpu_cull_verify(rp.vk_command_pool, verify_vp)

        # Acquire next image (reset fence AFTER successful acquire to avoid deadlock)
        Memory.write_i32(rp.frame_img_idx_ptr, 0)
        img_sem: i64 = Memory.read_ptr(rp.image_available_sems + self.current_frame * 8)
        acq_r: i32 = vkAcquireNextImageKHR(device, sc.vk_swapchain, 0 - 1, img_sem, 0, rp.frame_img_idx_ptr)
        img_idx: i32 = Memory.read_i32(rp.frame_img_idx_ptr)
        if acq_r != 0:
            if acq_r != 1000001003:
                return
        vkResetFences(device, 1, rp.frame_fence_arr)

        # Reset + record command buffer
        cmd_buf: i64 = Memory.read_ptr(rp.vk_command_buffers + self.current_frame * 8)
        vkResetCommandBuffer(cmd_buf, 0)
        fb: i64 = Memory.read_ptr(rp.framebuffers + img_idx * 8)
        present_fb: i64 = fb
        rw: i32 = render_width
        rh: i32 = render_height
        # A floating-point scene target preserves bright values until the
        # final presentation stage. ToneMapping.none() remains neutral.
        use_scaled: i32 = 1
        if self.ensure_render_scale_target(rp, FROG_HDR_COLOR_FORMAT, rw, rh) == 1:
            fb = self.scale_framebuffer
        else:
            return
        self.ensure_white_texture(rp, rp.vk_command_pool)
        swap_img: i64 = 0
        swap_old_layout: i32 = 0
        if sc.images != 0:
            swap_img = Memory.read_ptr(sc.images + img_idx * 8)
        swap_old_layout = sc.image_layout(img_idx)
        self._record_commands(cmd_buf, fb, present_fb, rp, cam_view, cam_proj, rw, rh, env, use_scaled, self.scale_color_image, swap_img, swap_old_layout, width, height)
        if use_scaled == 1:
            sc.set_image_layout(img_idx, 1000001002)

        # Submit
        render_sem: i64 = Memory.read_ptr(rp.render_finished_sems + self.current_frame * 8)
        Memory.write_ptr(rp.frame_wait_sems, img_sem)
        Memory.write_i32(rp.frame_wait_stages, 1024)
        Memory.write_ptr(rp.frame_signal_sems, render_sem)
        Memory.write_ptr(rp.frame_cmd_bufs_arr, cmd_buf)

        si: i64 = rp.frame_submit_info
        Memory.set(si, 0, 72)
        Memory.write_i32(si, 4)
        Memory.write_ptr(si + 8, 0)
        Memory.write_i32(si + 16, 1)
        Memory.write_ptr(si + 24, rp.frame_wait_sems)
        Memory.write_ptr(si + 32, rp.frame_wait_stages)
        Memory.write_i32(si + 40, 1)
        Memory.write_ptr(si + 48, rp.frame_cmd_bufs_arr)
        Memory.write_i32(si + 56, 1)
        Memory.write_ptr(si + 64, rp.frame_signal_sems)

        vkQueueSubmit(gfx_queue, 1, si, current_fence)

        # Present
        pi: i64 = rp.frame_present_info
        Memory.set(pi, 0, 64)
        Memory.write_ptr(rp.frame_wait_sems_p, render_sem)
        Memory.write_ptr(rp.frame_swapchains_arr, sc.vk_swapchain)
        Memory.write_i32(rp.frame_img_idxs_arr, img_idx)

        Memory.write_i32(pi, 1000001001)
        Memory.write_ptr(pi + 8, 0)
        Memory.write_i32(pi + 16, 1)
        Memory.write_ptr(pi + 24, rp.frame_wait_sems_p)
        Memory.write_i32(pi + 32, 1)
        Memory.write_ptr(pi + 40, rp.frame_swapchains_arr)
        Memory.write_ptr(pi + 48, rp.frame_img_idxs_arr)
        Memory.write_ptr(pi + 56, 0)

        vkQueuePresentKHR(present_queue, pi)

        self.profiler.end_frame()
        self.current_frame = (self.current_frame + 1) % rp.max_frames
        self.frame_serial = self.frame_serial + 1
        self._release_retired_buffers()
        self._debug_record_frame()

    fun _apply_adaptive_shadow_filter(self, shadow_global_mapped: i64, caster_count: i32):
        if shadow_global_mapped == 0:
            return
        if caster_count <= 0:
            return
        if self.render_state == 0:
            return
        light_ptr: i64 = Memory.read_ptr(self.render_state)
        if light_ptr == 0:
            return
        light: DirectionalLight3D = light_ptr as DirectionalLight3D
        if light.shadow.adaptive == 0:
            return
        if light.shadow.filter_samples > 0:
            return

        quality: i32 = light.shadow.filter_quality
        if quality <= 0:
            return
        samples: i32 = 0
        if caster_count <= 2:
            if quality > 1:
                quality = 1
            samples = 8
        elif caster_count <= 8:
            if quality > 1:
                quality = 1
            samples = 12
        elif caster_count <= 32:
            if quality > 2:
                quality = 2
            samples = 16

        if samples > 0:
            Memory.write_f32(shadow_global_mapped + 160, quality as f32)
            Memory.write_f32(shadow_global_mapped + 164, samples as f32)

    fun _record_shadow_pass(self, cmd: i64, rp: RenderPass, frame_slot: i32, light_vp: i64, cascade_count: i32) -> i32:
        if rp.shadow.initialized == 0:
            return 0
        if rp.shadow.framebuffer == 0:
            return 0
        if rp.shadow.vk_pipeline == 0:
            return 0
        if light_vp == 0:
            return 0
        active_cascade_count: i32 = cascade_count
        if active_cascade_count < 1:
            active_cascade_count = 1
        if active_cascade_count > 2:
            active_cascade_count = 2
        if self.render_state == 0:
            return 0
        shadow_instance_mapped_ptrs: i64 = Memory.read_ptr(self.render_state + 24)
        shadow_instance_buffers: i64 = Memory.read_ptr(self.render_state + 8)
        if shadow_instance_mapped_ptrs == 0 or shadow_instance_buffers == 0:
            return 0
        mapped: i64 = Memory.read_ptr(shadow_instance_mapped_ptrs + frame_slot * 8)
        shadow_instance_buffer: i64 = Memory.read_ptr(shadow_instance_buffers + frame_slot * 8)
        if mapped == 0 or shadow_instance_buffer == 0:
            return 0

        cam_x: f32 = 0.0
        cam_y: f32 = 0.0
        cam_z: f32 = 0.0
        shadow_max_distance: f32 = 0.0
        if self.render_state != 0:
            cam_x = Memory.read_f32(self.render_state + 64)
            cam_y = Memory.read_f32(self.render_state + 68)
            cam_z = Memory.read_f32(self.render_state + 72)
            light_ptr: i64 = Memory.read_ptr(self.render_state)
            if light_ptr != 0:
                light: DirectionalLight3D = light_ptr as DirectionalLight3D
                shadow_max_distance = light.shadow.distance
                if shadow_max_distance < 10.0:
                    shadow_max_distance = 10.0
                if shadow_max_distance > 1000.0:
                    shadow_max_distance = 1000.0

        # Parallel visibility precompute: run the heavy per-caster test across
        # worker threads into g_shadow_vis_out, so the serial compaction below
        # is a cheap array read instead of matrix math on a single thread.
        shadow_vis: i64 = self._ensure_shadow_vis_capacity(self.vb_count * active_cascade_count)
        if shadow_vis != 0:
            if self.vb_count > 0:
                g_shadow_vis_out = shadow_vis
                g_shadow_vb_count = self.vb_count
                g_shadow_active_cascades = active_cascade_count
                g_shadow_light_vp = light_vp
                g_shadow_model_matrices = self.model_matrices
                g_shadow_vb_visible = self.vb_visible
                g_shadow_mesh_flags = self.mesh_shadow_flags
                g_shadow_bound_xs = self.mesh_bound_xs
                g_shadow_bound_ys = self.mesh_bound_ys
                g_shadow_bound_zs = self.mesh_bound_zs
                g_shadow_bound_rs = self.mesh_bound_rs
                g_shadow_mesh_dist = self.mesh_shadow_distances
                g_shadow_max_distance = shadow_max_distance
                g_shadow_cam_x = cam_x
                g_shadow_cam_y = cam_y
                g_shadow_cam_z = cam_z
                if g_shadow_vis_body == 0:
                    vis_body: @heap fun(i32) = fun(gi: i32) _frog_shadow_vis_one(gi)
                    g_shadow_vis_body = vis_body as i64
                vis_body2: @heap fun(i32) = g_shadow_vis_body as @heap fun(i32)
                engine_parallel_for(self.vb_count, vis_body2)

        rpi: i64 = self.scratch_render_info
        clear_value: i64 = self.scratch_clear_values
        if rpi == 0 or clear_value == 0:
            return 0

        Memory.set(rpi, 0, 96)
        Memory.set(clear_value, 0, 8)
        Memory.write_i32(rpi, 43)
        Memory.write_ptr(rpi + 16, rp.shadow.vk_render_pass)
        Memory.write_ptr(rpi + 24, rp.shadow.framebuffer)
        Memory.write_i32(rpi + 40, rp.shadow.map_size)
        Memory.write_i32(rpi + 44, rp.shadow.map_size)
        Memory.write_f32(clear_value, 1.0)
        Memory.write_i32(rpi + 48, 1)
        Memory.write_ptr(rpi + 56, clear_value)

        viewport: i64 = self.scratch_viewport
        scissor: i64 = self.scratch_scissor
        render_begun: i32 = 0
        shadow_instance_total: i32 = 0
        cascade_index: i32 = 0
        while cascade_index < active_cascade_count:
            cascade_matrix: i64 = light_vp + (cascade_index as i64) * 64
            tile_size: i32 = rp.shadow.map_size
            tile_x: i32 = 0
            tile_y: i32 = 0
            if active_cascade_count > 1:
                tile_size = rp.shadow.map_size / 2
                if tile_size < 1:
                    tile_size = 1
                if cascade_index == 1:
                    tile_x = tile_size

            instance_base: i32 = cascade_index * self.vb_count
            instance_write: i32 = 0
            last_bound: i64 = 0
            last_index_bound: i64 = 0
            cascade_bound: i32 = 0
            mi: i32 = 0
            while mi < self.vb_count:
                vb_handle: i64 = Memory.read_ptr(self.vb_handles + mi * 8)
                vc: i32 = Memory.read_i32(self.vb_vert_counts + mi * 4)
                ib_handle: i64 = Memory.read_ptr(self.ib_handles + mi * 8)
                ic: i32 = Memory.read_i32(self.ib_index_counts + mi * 4)
                model_ptr: i64 = Memory.read_ptr(self.model_matrices + mi * 8)
                if vb_handle == 0 or vc <= 0 or model_ptr == 0:
                    mi = mi + 1
                else:
                    group_start: i32 = instance_write
                    group_count: i32 = 0
                    gi: i32 = mi
                    while gi < self.vb_count:
                        g_vb: i64 = Memory.read_ptr(self.vb_handles + gi * 8)
                        g_vc: i32 = Memory.read_i32(self.vb_vert_counts + gi * 4)
                        g_ib: i64 = Memory.read_ptr(self.ib_handles + gi * 8)
                        g_ic: i32 = Memory.read_i32(self.ib_index_counts + gi * 4)
                        g_model: i64 = Memory.read_ptr(self.model_matrices + gi * 8)
                        if g_vb != vb_handle:
                            break
                        elif g_vc != vc:
                            break
                        elif g_ib != ib_handle:
                            break
                        elif g_ic != ic:
                            break
                        elif g_model == 0:
                            break
                        else:
                            visible: i32 = 0
                            if shadow_vis != 0:
                                visible = Memory.read_i32(shadow_vis + ((cascade_index * self.vb_count + gi) as i64) * 4)
                            if visible == 1:
                                dst: i64 = mapped + ((instance_base + instance_write) as i64) * 80
                                Memory.copy(dst, g_model, 64)
                                Memory.set(dst + 64, 0, 16)
                                instance_write = instance_write + 1
                                group_count = group_count + 1
                            gi = gi + 1

                    if group_count > 0:
                        shadow_instance_total = shadow_instance_total + group_count
                        if render_begun == 0:
                            vkCmdBeginRenderPass(cmd, rpi, 0)
                            vkCmdBindPipeline(cmd, 0, rp.shadow.vk_pipeline)
                            render_begun = 1
                        if cascade_bound == 0:
                            if viewport != 0:
                                map_size_f: f32 = tile_size
                                Memory.set(viewport, 0, 24)
                                Memory.write_f32(viewport, tile_x as f32)
                                Memory.write_f32(viewport + 4, tile_y as f32)
                                Memory.write_f32(viewport + 8, map_size_f)
                                Memory.write_f32(viewport + 12, map_size_f)
                                Memory.write_f32(viewport + 20, 1.0)
                                vkCmdSetViewport(cmd, 0, 1, viewport)
                            if scissor != 0:
                                Memory.set(scissor, 0, 16)
                                Memory.write_i32(scissor, tile_x)
                                Memory.write_i32(scissor + 4, tile_y)
                                Memory.write_i32(scissor + 8, tile_size)
                                Memory.write_i32(scissor + 12, tile_size)
                                vkCmdSetScissor(cmd, 0, 1, scissor)
                            vkCmdPushConstants(cmd, rp.shadow.vk_pipeline_layout, 1, 0, 64, cascade_matrix)
                            cascade_bound = 1
                        if vb_handle != last_bound:
                            Memory.write_ptr(self.scratch_vb_arr, vb_handle)
                            vkCmdBindVertexBuffers(cmd, 0, 1, self.scratch_vb_arr, self.scratch_off_arr)
                            last_bound = vb_handle
                        Memory.write_ptr(self.scratch_inst_vb_arr, shadow_instance_buffer)
                        Memory.write_i64(self.scratch_inst_off_arr, ((instance_base + group_start) as i64) * 80)
                        vkCmdBindVertexBuffers(cmd, 1, 1, self.scratch_inst_vb_arr, self.scratch_inst_off_arr)
                        if ib_handle != 0:
                            if ic > 0:
                                if ib_handle != last_index_bound:
                                    vkCmdBindIndexBuffer(cmd, ib_handle, 0, 1)
                                    last_index_bound = ib_handle
                                vkCmdDrawIndexed(cmd, ic, group_count, 0, 0, 0)
                            else:
                                vkCmdDraw(cmd, vc, group_count, 0, 0)
                        else:
                            vkCmdDraw(cmd, vc, group_count, 0, 0)
                    mi = gi
            cascade_index = cascade_index + 1
        if render_begun == 1:
            vkCmdEndRenderPass(cmd)
        return shadow_instance_total

    fun _record_bloom_present(self, cmd: i64, framebuffer: i64, rp: RenderPass, src_image: i64, dst_image: i64, dst_width: i32, dst_height: i32, bloom: Bloom, tone_mapping: ToneMapping):
        if frog_bloom_pass_ready() == 0:
            return
        if framebuffer == 0:
            return
        if src_image == 0 or dst_image == 0:
            return
        if dst_width <= 0 or dst_height <= 0:
            return

        # HDR scene color -> sampled texture for post processing.
        gpu_tex_barrier(cmd, src_image, 2, 5, 256, 32, 1024, 128)

        rpi: i64 = self.scratch_render_info
        clear_vals: i64 = self.scratch_clear_values
        if rpi == 0 or clear_vals == 0:
            return
        Memory.set(rpi, 0, 96)
        Memory.write_i32(rpi, 43)
        Memory.write_ptr(rpi + 16, rp.vk_present_render_pass)
        Memory.write_ptr(rpi + 24, framebuffer)
        Memory.write_i32(rpi + 40, dst_width)
        Memory.write_i32(rpi + 44, dst_height)
        Memory.set(clear_vals, 0, 32)
        Memory.write_f32(clear_vals + 16, 1.0)
        Memory.write_i32(rpi + 48, 2)
        Memory.write_ptr(rpi + 56, clear_vals)

        vkCmdBeginRenderPass(cmd, rpi, 0)

        bloom_pipeline: i64 = frog_bloom_pass_pipeline()
        bloom_layout: i64 = frog_bloom_pass_layout()
        if bloom_pipeline != 0 and bloom_layout != 0:
            vkCmdBindPipeline(cmd, 0, bloom_pipeline)

            desc: i64 = self.scale_descriptor_set(rp)
            if desc != 0:
                Memory.write_ptr(self.scratch_desc_arr, desc)
                vkCmdBindDescriptorSets(cmd, 0, bloom_layout, 0, 1, self.scratch_desc_arr, 0, 0)

            vp: i64 = self.scratch_viewport
            if vp != 0:
                Memory.set(vp, 0, 24)
                dst_wf: f32 = dst_width
                dst_hf: f32 = dst_height
                Memory.write_f32(vp + 8, dst_wf)
                Memory.write_f32(vp + 12, dst_hf)
                Memory.write_f32(vp + 20, 1.0)
                vkCmdSetViewport(cmd, 0, 1, vp)

            sc2: i64 = self.scratch_scissor
            if sc2 != 0:
                Memory.set(sc2, 0, 16)
                Memory.write_i32(sc2 + 8, dst_width)
                Memory.write_i32(sc2 + 12, dst_height)
                vkCmdSetScissor(cmd, 0, 1, sc2)

            push_data: i64 = self.scratch_push_data
            if push_data != 0:
                out_w: f32 = dst_width
                out_h: f32 = dst_height
                inv_w: f32 = 1.0 / out_w
                inv_h: f32 = 1.0 / out_h
                Memory.set(push_data, 0, 48)
                Memory.write_f32(push_data, bloom.threshold)
                Memory.write_f32(push_data + 4, bloom.intensity)
                Memory.write_f32(push_data + 8, bloom.radius)
                Memory.write_f32(push_data + 12, bloom.scatter)
                Memory.write_f32(push_data + 16, inv_w)
                Memory.write_f32(push_data + 20, inv_h)
                Memory.write_f32(push_data + 24, out_w)
                Memory.write_f32(push_data + 28, out_h)
                Memory.write_f32(push_data + 32, tone_mapping.exposure)
                tone_mode: f32 = tone_mapping.mode as f32
                Memory.write_f32(push_data + 36, tone_mode)
                vkCmdPushConstants(cmd, bloom_layout, 16, 0, 48, push_data)
                vkCmdDraw(cmd, 3, 1, 0, 0)

        vkCmdEndRenderPass(cmd)

        # Restore the offscreen target for the next frame and present the swapchain image.
        gpu_tex_barrier(cmd, src_image, 5, 2, 32, 256, 128, 1024)
        gpu_tex_barrier(cmd, dst_image, 2, 1000001002, 256, 0, 1024, 8192)

    fun _record_commands(self, cmd: i64, framebuffer: i64, present_framebuffer: i64, rp: RenderPass, cam_view: i64, cam_proj: i64, width: i32, height: i32, env: Environment, use_scaled: i32, scale_color_image: i64, swap_image: i64, swap_old_layout: i32, swap_width: i32, swap_height: i32) -> void:
        if self._ensure_shadow_globals() == 0:
            return
        if self._ensure_point_light_globals(rp) == 0:
            return
        shadow_data: i64 = self.scratch_push_data
        shadow_enabled: i32 = self._write_shadow_data(shadow_data)
        frame_slot: i32 = self.current_frame
        if frame_slot < 0:
            frame_slot = 0
        if frame_slot > 1:
            frame_slot = 1
        shadow_global_mapped_ptrs: i64 = Memory.read_ptr(self.render_state + 56)
        shadow_global_buffers: i64 = Memory.read_ptr(self.render_state + 40)
        if shadow_global_mapped_ptrs == 0 or shadow_global_buffers == 0:
            return
        shadow_global_mapped: i64 = Memory.read_ptr(shadow_global_mapped_ptrs + frame_slot * 8)
        if shadow_global_mapped == 0:
            return
        Memory.copy(shadow_global_mapped, shadow_data, 176)
        point_light_mapped: i64 = Memory.read_ptr(self.point_light_mapped_ptrs + frame_slot * 8)
        point_light_desc: i64 = Memory.read_ptr(self.point_light_desc_sets + frame_slot * 8)
        if point_light_mapped == 0 or point_light_desc == 0:
            return
        self._write_point_light_data(point_light_mapped, env)
        if rp.shadow.map_size <= 1:
            shadow_enabled = 0
            Memory.write_f32(shadow_global_mapped + 128, 0.0)
        shadow_instances_ready: i32 = 0
        if shadow_enabled == 1:
            cascade_count_for_instances: i32 = Memory.read_f32(shadow_data + 144) as i32
            if cascade_count_for_instances < 1:
                cascade_count_for_instances = 1
            if cascade_count_for_instances > 2:
                cascade_count_for_instances = 2
            shadow_instances_ready = self._ensure_shadow_instance_capacity(self.vb_count * cascade_count_for_instances)

        # Begin command buffer
        begin_info: i64 = self.scratch_begin_info
        if begin_info == 0:
            return
        Memory.set(begin_info, 0, 64)
        Memory.write_i32(begin_info, 42)
        Memory.write_ptr(begin_info + 8, 0)
        Memory.write_i32(begin_info + 16, 0)
        Memory.write_ptr(begin_info + 24, 0)
        br: i32 = vkBeginCommandBuffer(cmd, begin_info)
        if br != 0:
            return
        self.profiler.begin_frame(cmd)

        cpu_prof_frame_start: i64 = 0
        if g_frog_cpu_prof_enabled == 1:
            cpu_prof_frame_start = frog_time_now_ticks()

        if shadow_enabled == 1:
            if shadow_instances_ready == 1:
                cascade_count_for_pass: i32 = Memory.read_f32(shadow_data + 144) as i32
                if cascade_count_for_pass < 1:
                    cascade_count_for_pass = 1
                if cascade_count_for_pass > 2:
                    cascade_count_for_pass = 2
                shadow_t0: i64 = 0
                if g_frog_cpu_prof_enabled == 1:
                    shadow_t0 = frog_time_now_ticks()
                shadow_casters: i32 = self._record_shadow_pass(cmd, rp, frame_slot, shadow_data, cascade_count_for_pass)
                if g_frog_cpu_prof_enabled == 1:
                    g_frog_cpu_prof_shadow_ticks = g_frog_cpu_prof_shadow_ticks + (frog_time_now_ticks() - shadow_t0)
                if shadow_casters == 0:
                    shadow_enabled = 0
                    Memory.write_f32(shadow_global_mapped + 128, 0.0)
                else:
                    self._apply_adaptive_shadow_filter(shadow_global_mapped, shadow_casters)
            else:
                shadow_enabled = 0
                Memory.write_f32(shadow_global_mapped + 128, 0.0)

        # GPU-driven culling pre-pass: record the cull compute dispatches
        # into THIS frame command buffer, before the render pass begins. The
        # compute writes a compacted instance buffer + indirect commands that
        # the in-pass draw consumes. Slot-partitioned for frames-in-flight.
        if self.gpu_draw_enabled == 1:
            if self.vb_count > 0:
                if cam_view != 0:
                    if cam_proj != 0:
                        precull_vp: i64 = self.scratch_vp_matrix
                        if precull_vp != 0:
                            _frog_multiply_4x4_into(cam_proj, cam_view, precull_vp)
                            self.gpu_precull_main(cmd, precull_vp, frame_slot)

        # GPU-timer: boundary after shadow pass + GPU cull pre-pass.
        self.profiler.mark(cmd, 1)

        # Begin render pass
        rpi: i64 = self.scratch_render_info
        if rpi == 0:
            return
        Memory.set(rpi, 0, 96)
        Memory.write_i32(rpi, 43)
        Memory.write_ptr(rpi + 8, 0)
        Memory.write_ptr(rpi + 16, rp.vk_render_pass)
        Memory.write_ptr(rpi + 24, framebuffer)
        Memory.write_i32(rpi + 32, 0)
        Memory.write_i32(rpi + 36, 0)
        Memory.write_i32(rpi + 40, width)
        Memory.write_i32(rpi + 44, height)

        # Two clear values: color (RGBA float) + depth (float + uint)
        clear_vals: i64 = self.scratch_clear_values
        if clear_vals != 0:
            Memory.set(clear_vals, 0, 32)
            Memory.write_f32(clear_vals, env.clear_color.r)
            Memory.write_f32(clear_vals + 4, env.clear_color.g)
            Memory.write_f32(clear_vals + 8, env.clear_color.b)
            Memory.write_f32(clear_vals + 12, env.clear_color.a)
            Memory.write_f32(clear_vals + 16, 1.0)
            Memory.write_i32(clear_vals + 20, 0)
            Memory.write_i32(rpi + 48, 2)
            Memory.write_ptr(rpi + 56, clear_vals)

        vkCmdBeginRenderPass(cmd, rpi, 0)
        self._record_sky(cmd, width, height, env.sky, cam_view, cam_proj)

        if rp.vk_pipeline != 0:
            # Phase 1 bindless: when enabled, draw with the bindless pipeline
            # (set 2 = global texture table) instead of the classic per-mesh
            # descriptor path. Sets 0 (material/shadow sampler) and 1 (lights)
            # have the same shape in both layouts, so the lighting/shadow binds
            # below are identical. The table set is bound ONCE here; per-group
            # material descriptor binds are skipped in the draw loop.
            use_bindless: i32 = 0
            active_pipeline: i64 = rp.vk_pipeline
            active_layout: i64 = rp.vk_pipeline_layout
            if self.bindless_enabled == 1:
                if rp.bindless_pipeline != 0:
                    if self.bindless_set != 0:
                        use_bindless = 1
                        active_pipeline = rp.bindless_pipeline
                        active_layout = rp.bindless_pipeline_layout
            vkCmdBindPipeline(cmd, 0, active_pipeline)

            Memory.write_ptr(self.scratch_desc_arr, point_light_desc)
            vkCmdBindDescriptorSets(cmd, 0, active_layout, 1, 1, self.scratch_desc_arr, 0, 0)

            # Bind the bindless texture table (set 2) once for the whole pass.
            if use_bindless == 1:
                Memory.write_ptr(self.scratch_desc_arr, self.bindless_set)
                vkCmdBindDescriptorSets(cmd, 0, active_layout, 2, 1, self.scratch_desc_arr, 0, 0)
                # Set 0 supplies the shadow sampler (binding 1), identical in
                # every material set. The bindless shader only reads binding 1
                # from set 0, so we bind one material set (white fallback) once
                # and skip all per-group set-0 binds in the draw loop.
                set0: i64 = self.white_desc_set
                if set0 == 0:
                    set0 = self.mesh_descriptor_set(rp, 0)
                if set0 != 0:
                    Memory.write_ptr(self.scratch_desc_arr, set0)
                    vkCmdBindDescriptorSets(cmd, 0, active_layout, 0, 1, self.scratch_desc_arr, 0, 0)

            shadow_global_buffer: i64 = Memory.read_ptr(shadow_global_buffers + frame_slot * 8)
            if shadow_global_buffer != 0:
                Memory.write_ptr(self.scratch_inst_vb_arr, shadow_global_buffer)
                Memory.write_i64(self.scratch_inst_off_arr, 0)
                vkCmdBindVertexBuffers(cmd, 2, 1, self.scratch_inst_vb_arr, self.scratch_inst_off_arr)

            # Dynamic viewport
            vp: i64 = self.scratch_viewport
            if vp != 0:
                Memory.set(vp, 0, 24)
                w_f: f32 = width
                h_f: f32 = height
                Memory.write_f32(vp, 0.0)
                Memory.write_f32(vp + 4, 0.0)
                Memory.write_f32(vp + 8, w_f)
                Memory.write_f32(vp + 12, h_f)
                Memory.write_f32(vp + 16, 0.0)
                Memory.write_f32(vp + 20, 1.0)
                vkCmdSetViewport(cmd, 0, 1, vp)

            # Dynamic scissor
            sc2: i64 = self.scratch_scissor
            if sc2 != 0:
                Memory.set(sc2, 0, 16)
                Memory.write_i32(sc2, 0)
                Memory.write_i32(sc2 + 4, 0)
                Memory.write_i32(sc2 + 8, width)
                Memory.write_i32(sc2 + 12, height)
                vkCmdSetScissor(cmd, 0, 1, sc2)

            # Draw meshes
            if self.vb_count > 0:
                # Compute VP = proj * view (pointer-based multiply)
                vp_mat: i64 = 0
                if cam_view != 0:
                    if cam_proj != 0:
                        vp_mat = self.scratch_vp_matrix
                        if vp_mat != 0:
                            _frog_multiply_4x4_into(cam_proj, cam_view, vp_mat)
                pc_data: i64 = 0

                instance_ready: i32 = self._ensure_instance_capacity(self.vb_count)
                # Select this frame's instance buffer slot (double-buffered to
                # avoid overwriting the buffer a previous in-flight frame is
                # still reading).
                inst_slot: i32 = self.current_frame
                if inst_slot < 0:
                    inst_slot = 0
                if inst_slot > 1:
                    inst_slot = 1
                frame_inst_buf: i64 = 0
                frame_inst_mem: i64 = 0
                if self.instance_buffers != 0:
                    frame_inst_buf = Memory.read_ptr(self.instance_buffers + inst_slot * 8)
                    frame_inst_mem = Memory.read_ptr(self.instance_memories + inst_slot * 8)
                mapped_instances: i64 = 0
                if instance_ready == 1:
                    if self.instance_mapped_ptrs != 0:
                        mapped_instances = Memory.read_ptr(self.instance_mapped_ptrs + inst_slot * 8)

                if vp_mat != 0:
                    pc_data = self.scratch_push_data
                    if pc_data != 0:
                        Memory.set(pc_data, 0, 128)
                        Memory.copy(pc_data, vp_mat, 64)
                        Memory.write_f32(pc_data + 64, env.fog.color.r)
                        Memory.write_f32(pc_data + 68, env.fog.color.g)
                        Memory.write_f32(pc_data + 72, env.fog.color.b)
                        Memory.write_f32(pc_data + 76, 0.0)
                        Memory.write_f32(pc_data + 80, env.fog.mode as f32)
                        Memory.write_f32(pc_data + 84, env.fog.start_distance)
                        Memory.write_f32(pc_data + 88, env.fog.end_distance)
                        Memory.write_f32(pc_data + 92, env.fog.density)
                        Memory.write_f32(pc_data + 96, env.fog.shape as f32)
                        if self.render_state != 0:
                            Memory.write_f32(pc_data + 100, Memory.read_f32(self.render_state + 64))
                            Memory.write_f32(pc_data + 104, Memory.read_f32(self.render_state + 68))
                            Memory.write_f32(pc_data + 108, Memory.read_f32(self.render_state + 72))
                        else:
                            Memory.write_f32(pc_data + 100, 0.0)
                            Memory.write_f32(pc_data + 104, 0.0)
                            Memory.write_f32(pc_data + 108, 0.0)

                        light_ptr: i64 = 0
                        if self.render_state != 0:
                            light_ptr = Memory.read_ptr(self.render_state)
                        if light_ptr != 0:
                            light: DirectionalLight3D = light_ptr as DirectionalLight3D
                            if light.active == 1:
                                dx: f32 = light.dir_x
                                dy: f32 = light.dir_y
                                dz: f32 = light.dir_z
                                Memory.write_f32(pc_data + 76, _frog_pack_light(light.color, light.ambient))
                                Memory.write_f32(pc_data + 112, dx)
                                Memory.write_f32(pc_data + 116, dy)
                                Memory.write_f32(pc_data + 120, dz)
                                Memory.write_f32(pc_data + 124, light.intensity)

                        vkCmdPushConstants(cmd, active_layout, 17, 0, 128, pc_data)

                last_bound: i64 = 0
                last_index_bound: i64 = 0
                last_desc: i64 = 0
                instance_write: i32 = 0
                frame_draw_calls: i32 = 0
                frame_indexed_draw_calls: i32 = 0
                frame_visible_instances: i32 = 0

                if self.vb_cull_result != 0:
                    if self.gpu_draw_enabled == 0:
                        cull_self_addr: i64 = self as i64
                        cull_vp: i64 = vp_mat
                        cull_res: i64 = self.vb_cull_result
                        cull_body: @heap fun(i32) = fun(gi: i32) _frog_cull_one(cull_self_addr, cull_vp, gi, cull_res)
                        engine_parallel_for(self.vb_count, cull_body)

                mi: i32 = 0
                if self.gpu_draw_enabled == 1:
                    # GPU-driven path: the pre-cull pass already compacted
                    # visible instances + filled indirect commands. Draw them
                    # and skip the CPU per-instance loop entirely.
                    self.gpu_draw_main(cmd, rp)
                    mi = self.vb_count
                while mi < self.vb_count:
                    vb_handle: i64 = Memory.read_ptr(self.vb_handles + mi * 8)
                    vc: i32 = Memory.read_i32(self.vb_vert_counts + mi * 4)
                    ib_handle: i64 = Memory.read_ptr(self.ib_handles + mi * 8)
                    ic: i32 = Memory.read_i32(self.ib_index_counts + mi * 4)
                    model_ptr: i64 = 0
                    if self.model_matrices != 0:
                        model_ptr = Memory.read_ptr(self.model_matrices + mi * 8)

                    if mapped_instances == 0:
                        mi = mi + 1
                    elif vb_handle == 0:
                        mi = mi + 1
                    elif vc <= 0:
                        mi = mi + 1
                    elif model_ptr == 0:
                        mi = mi + 1
                    else:
                        group_start: i32 = instance_write
                        group_count: i32 = 0
                        group_tex_id: i32 = 0 - 1
                        if self.mesh_tex_ids != 0:
                            group_tex_id = Memory.read_i32(self.mesh_tex_ids + mi * 4)
                        group_emissive_tex_id: i32 = 0 - 1
                        if self.mesh_emissive_tex_ids != 0:
                            group_emissive_tex_id = Memory.read_i32(self.mesh_emissive_tex_ids + mi * 4)
                        group_normal_tex_id: i32 = 0 - 1
                        if self.mesh_normal_tex_ids != 0:
                            group_normal_tex_id = Memory.read_i32(self.mesh_normal_tex_ids + mi * 4)
                        group_metallic_roughness_tex_id: i32 = 0 - 1
                        if self.mesh_metallic_roughness_tex_ids != 0:
                            group_metallic_roughness_tex_id = Memory.read_i32(self.mesh_metallic_roughness_tex_ids + mi * 4)
                        group_occlusion_tex_id: i32 = 0 - 1
                        if self.mesh_occlusion_tex_ids != 0:
                            group_occlusion_tex_id = Memory.read_i32(self.mesh_occlusion_tex_ids + mi * 4)
                        gi: i32 = mi
                        while gi < self.vb_count:
                            g_vb: i64 = Memory.read_ptr(self.vb_handles + gi * 8)
                            g_vc: i32 = Memory.read_i32(self.vb_vert_counts + gi * 4)
                            g_ib: i64 = Memory.read_ptr(self.ib_handles + gi * 8)
                            g_ic: i32 = Memory.read_i32(self.ib_index_counts + gi * 4)
                            g_tex: i32 = 0 - 1
                            if self.mesh_tex_ids != 0:
                                g_tex = Memory.read_i32(self.mesh_tex_ids + gi * 4)
                            g_emissive_tex: i32 = 0 - 1
                            if self.mesh_emissive_tex_ids != 0:
                                g_emissive_tex = Memory.read_i32(self.mesh_emissive_tex_ids + gi * 4)
                            g_normal_tex: i32 = 0 - 1
                            if self.mesh_normal_tex_ids != 0:
                                g_normal_tex = Memory.read_i32(self.mesh_normal_tex_ids + gi * 4)
                            g_metallic_roughness_tex: i32 = 0 - 1
                            if self.mesh_metallic_roughness_tex_ids != 0:
                                g_metallic_roughness_tex = Memory.read_i32(self.mesh_metallic_roughness_tex_ids + gi * 4)
                            g_occlusion_tex: i32 = 0 - 1
                            if self.mesh_occlusion_tex_ids != 0:
                                g_occlusion_tex = Memory.read_i32(self.mesh_occlusion_tex_ids + gi * 4)
                            g_model: i64 = 0
                            if self.model_matrices != 0:
                                g_model = Memory.read_ptr(self.model_matrices + gi * 8)
                            if g_vb != vb_handle:
                                break
                            elif g_vc != vc:
                                break
                            elif g_ib != ib_handle:
                                break
                            elif g_ic != ic:
                                break
                            elif g_tex != group_tex_id:
                                break
                            elif g_emissive_tex != group_emissive_tex_id:
                                break
                            elif g_normal_tex != group_normal_tex_id:
                                break
                            elif g_metallic_roughness_tex != group_metallic_roughness_tex_id:
                                break
                            elif g_occlusion_tex != group_occlusion_tex_id:
                                break
                            elif g_model == 0:
                                break
                            else:
                                visible: i32 = 1
                                if self.vb_cull_result != 0:
                                    if Memory.read_i32(self.vb_cull_result + gi * 4) == 0:
                                        visible = 0
                                if visible == 1:
                                    instance_dst: i64 = mapped_instances + ((instance_write as i64) * (FROG_GPU_INSTANCE_STRIDE as i64))
                                    Memory.copy(instance_dst, g_model, 64)
                                    if self.mesh_material_params != 0:
                                        Memory.copy(instance_dst + FROG_GPU_INSTANCE_MATERIAL_OFFSET, self.mesh_material_params + gi * 32, 32)
                                    else:
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_MATERIAL_OFFSET, 0.0)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 4, 1.0)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 8, 0.0)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 12, 0.0)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_UV_OFFSET, 1.0)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_UV_OFFSET + 4, 1.0)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_UV_OFFSET + 8, 0.0)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_UV_OFFSET + 12, 0.0)
                                    receive_shadow: i32 = 1
                                    if self.mesh_shadow_flags != 0:
                                        shadow_flags: i32 = Memory.read_i32(self.mesh_shadow_flags + gi * 4)
                                        receive_shadow = (shadow_flags / 2) - (shadow_flags / 4) * 2
                                    if receive_shadow == 1:
                                        packed_material: f32 = Memory.read_f32(instance_dst + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 12)
                                        Memory.write_f32(instance_dst + FROG_GPU_INSTANCE_MATERIAL_OFFSET + 12, packed_material + 65536.0)
                                    self._write_record_texidx(instance_dst, gi)
                                    instance_write = instance_write + 1
                                    group_count = group_count + 1
                                gi = gi + 1

                        if group_count > 0:
                            if vb_handle != last_bound:
                                Memory.write_ptr(self.scratch_vb_arr, vb_handle)
                                vkCmdBindVertexBuffers(cmd, 0, 1, self.scratch_vb_arr, self.scratch_off_arr)
                                last_bound = vb_handle

                            Memory.write_ptr(self.scratch_inst_vb_arr, frame_inst_buf)
                            Memory.write_i64(self.scratch_inst_off_arr, (group_start as i64) * (FROG_GPU_INSTANCE_STRIDE as i64))
                            vkCmdBindVertexBuffers(cmd, 1, 1, self.scratch_inst_vb_arr, self.scratch_inst_off_arr)

                            # Bind the texture descriptor set for this group
                            # (falls back to the 1x1 white texture when unset).
                            # Skipped in bindless mode: the global table is bound
                            # once and the per-instance index selects the texture.
                            if use_bindless == 0:
                                grp_desc: i64 = self.mesh_descriptor_set(rp, mi)
                                if grp_desc != 0:
                                    if grp_desc != last_desc:
                                        Memory.write_ptr(self.scratch_desc_arr, grp_desc)
                                        vkCmdBindDescriptorSets(cmd, 0, rp.vk_pipeline_layout, 0, 1, self.scratch_desc_arr, 0, 0)
                                        last_desc = grp_desc

                            if ib_handle != 0:
                                if ic > 0:
                                    if ib_handle != last_index_bound:
                                        vkCmdBindIndexBuffer(cmd, ib_handle, 0, 1)
                                        last_index_bound = ib_handle
                                    vkCmdDrawIndexed(cmd, ic, group_count, 0, 0, 0)
                                    frame_draw_calls = frame_draw_calls + 1
                                    frame_indexed_draw_calls = frame_indexed_draw_calls + 1
                                else:
                                    vkCmdDraw(cmd, vc, group_count, 0, 0)
                                    frame_draw_calls = frame_draw_calls + 1
                            else:
                                vkCmdDraw(cmd, vc, group_count, 0, 0)
                                frame_draw_calls = frame_draw_calls + 1
                            frame_visible_instances = frame_visible_instances + group_count

                        mi = gi

                if self.debug_render_stats_enabled == 1:
                    self.debug_draw_calls = self.debug_draw_calls + frame_draw_calls
                    self.debug_indexed_draw_calls = self.debug_indexed_draw_calls + frame_indexed_draw_calls
                    self.debug_visible_instances = self.debug_visible_instances + frame_visible_instances

        debug_vp: i64 = 0
        if self.debug_collisions_enabled == 1:
            if cam_view != 0 and cam_proj != 0:
                debug_vp = self.scratch_vp_matrix
                if debug_vp != 0:
                    _frog_multiply_4x4_into(cam_proj, cam_view, debug_vp)
            self._record_collision_debug(cmd, rp, debug_vp, width, height)

        vkCmdEndRenderPass(cmd)
        # GPU-timer: boundary after the main render pass (sky + scene draws).
        self.profiler.mark(cmd, 2)
        if use_scaled == 1:
            if frog_bloom_pass_ready() != 0:
                self._record_bloom_present(cmd, present_framebuffer, rp, scale_color_image, swap_image, swap_width, swap_height, env.bloom, env.tone_mapping)
        # GPU-timer: boundary after post/bloom present (end of GPU frame work).
        self.profiler.mark(cmd, 3)
        vkEndCommandBuffer(cmd)

        if g_frog_cpu_prof_enabled == 1:
            g_frog_cpu_prof_total_ticks = g_frog_cpu_prof_total_ticks + (frog_time_now_ticks() - cpu_prof_frame_start)
            g_frog_cpu_prof_frames = g_frog_cpu_prof_frames + 1
            if g_frog_cpu_prof_frames >= 120:
                freq: i64 = g_frog_timer_freq
                if freq <= 0:
                    freq = 1000000000
                shadow_us: i64 = (g_frog_cpu_prof_shadow_ticks * 1000000 as i64) / (freq * 120 as i64)
                total_us: i64 = (g_frog_cpu_prof_total_ticks * 1000000 as i64) / (freq * 120 as i64)
                print(@"[frog.cpu_rec] avg/120 shadow_build={shadow_us} us  total_record={total_us} us")
                g_frog_cpu_prof_shadow_ticks = 0
                g_frog_cpu_prof_total_ticks = 0
                g_frog_cpu_prof_frames = 0

    fun cleanup(self) -> void:
        self.cleanup_collision_debug()
        self.destroy_render_scale_target()
        self.profiler.cleanup()
        # Phase 1: destroy the bindless table objects (pool frees its sets).
        if self.bindless_pool != 0:
            vkDestroyDescriptorPool(self.device, self.bindless_pool, 0)
            self.bindless_pool = 0
            self.bindless_set = 0
        if self.bindless_layout != 0:
            vkDestroyDescriptorSetLayout(self.device, self.bindless_layout, 0)
            self.bindless_layout = 0
        if self.ssbo_desc_pool != 0:
            vkDestroyDescriptorPool(self.device, self.ssbo_desc_pool, 0)
            self.ssbo_desc_pool = 0
        self.ssbo_draw_enabled = 0
        self.bindless_enabled = 0
        self.bindless_count = 0
        if self.retire_buffers != 0:
            ri: i32 = 0
            while ri < self.retire_count:
                rb: i64 = Memory.read_ptr(self.retire_buffers + ri * 8)
                rm: i64 = Memory.read_ptr(self.retire_memories + ri * 8)
                if rb != 0:
                    vkDestroyBuffer(self.device, rb, 0)
                if rm != 0:
                    vkFreeMemory(self.device, rm, 0)
                ri = ri + 1
            Memory.free(self.retire_buffers)
            self.retire_buffers = 0
        if self.retire_memories != 0:
            Memory.free(self.retire_memories)
            self.retire_memories = 0
        if self.retire_frames != 0:
            Memory.free(self.retire_frames)
            self.retire_frames = 0
        if self.retire_sizes != 0:
            Memory.free(self.retire_sizes)
            self.retire_sizes = 0
        if self.retire_usages != 0:
            Memory.free(self.retire_usages)
            self.retire_usages = 0
        self.retire_count = 0
        self.retire_capacity = 0
        if self.pooled_buffers != 0:
            pi: i32 = 0
            while pi < self.pooled_count:
                pb: i64 = Memory.read_ptr(self.pooled_buffers + pi * 8)
                pm: i64 = Memory.read_ptr(self.pooled_memories + pi * 8)
                if pb != 0:
                    vkDestroyBuffer(self.device, pb, 0)
                if pm != 0:
                    vkFreeMemory(self.device, pm, 0)
                pi = pi + 1
            Memory.free(self.pooled_buffers)
        if self.pooled_memories != 0:
            Memory.free(self.pooled_memories)
        if self.pooled_sizes != 0:
            Memory.free(self.pooled_sizes)
        if self.pooled_usages != 0:
            Memory.free(self.pooled_usages)
        self.pooled_count = 0
        self.pooled_capacity = 0
        self.pooled_bytes = 0
        self.pooled_byte_limit = 0
        # Only destroy VkBuffers/Memory that are owned (memory != 0)
        # Shared instances have memory = 0
        if self.vb_handles != 0:
            vi: i32 = 0
            while vi < self.vb_count:
                vm: i64 = Memory.read_ptr(self.vb_memories + vi * 8)
                if vm != 0:
                    vb: i64 = Memory.read_ptr(self.vb_handles + vi * 8)
                    if vb != 0:
                        vkDestroyBuffer(self.device, vb, 0)
                    vkFreeMemory(self.device, vm, 0)
                im: i64 = Memory.read_ptr(self.ib_memories + vi * 8)
                if im != 0:
                    ib: i64 = Memory.read_ptr(self.ib_handles + vi * 8)
                    if ib != 0:
                        vkDestroyBuffer(self.device, ib, 0)
                    vkFreeMemory(self.device, im, 0)
                if self.model_matrices != 0:
                    model_ptr: i64 = Memory.read_ptr(self.model_matrices + vi * 8)
                    if model_ptr != 0:
                        Memory.free(model_ptr)
                        Memory.write_ptr(self.model_matrices + vi * 8, 0)
                vi = vi + 1
            Memory.free(self.vb_handles)
        if self.vb_memories != 0:
            Memory.free(self.vb_memories)
        if self.vb_alloc_sizes != 0:
            Memory.free(self.vb_alloc_sizes)
        if self.vb_vert_counts != 0:
            Memory.free(self.vb_vert_counts)
        if self.ib_handles != 0:
            Memory.free(self.ib_handles)
        if self.ib_memories != 0:
            Memory.free(self.ib_memories)
        if self.ib_alloc_sizes != 0:
            Memory.free(self.ib_alloc_sizes)
        if self.ib_index_counts != 0:
            Memory.free(self.ib_index_counts)
        if self.model_matrices != 0:
            Memory.free(self.model_matrices)
        if self.mesh_bound_xs != 0:
            Memory.free(self.mesh_bound_xs)
        if self.mesh_bound_ys != 0:
            Memory.free(self.mesh_bound_ys)
        if self.mesh_bound_zs != 0:
            Memory.free(self.mesh_bound_zs)
        if self.mesh_bound_rs != 0:
            Memory.free(self.mesh_bound_rs)
        # Destroy per-frame instance buffers (slot 0 mirrors the legacy
        # instance_buffer field, so free via the array only to avoid a
        # double free).
        if self.instance_buffers != 0:
            isl: i32 = 0
            while isl < 2:
                ib_buf: i64 = Memory.read_ptr(self.instance_buffers + isl * 8)
                ib_mem: i64 = Memory.read_ptr(self.instance_memories + isl * 8)
                if ib_mem != 0:
                    if self.instance_mapped_ptrs != 0:
                        ib_mapped: i64 = Memory.read_ptr(self.instance_mapped_ptrs + isl * 8)
                        if ib_mapped != 0:
                            vkUnmapMemory(self.device, ib_mem)
                if ib_buf != 0:
                    vkDestroyBuffer(self.device, ib_buf, 0)
                if ib_mem != 0:
                    vkFreeMemory(self.device, ib_mem, 0)
                isl = isl + 1
            Memory.free(self.instance_buffers)
            if self.instance_memories != 0:
                Memory.free(self.instance_memories)
            if self.instance_mapped_ptrs != 0:
                Memory.free(self.instance_mapped_ptrs)
            self.instance_buffer = 0
            self.instance_memory = 0
        else:
            if self.instance_buffer != 0:
                vkDestroyBuffer(self.device, self.instance_buffer, 0)
            if self.instance_memory != 0:
                vkFreeMemory(self.device, self.instance_memory, 0)
        shadow_instance_buffers: i64 = 0
        shadow_instance_memories: i64 = 0
        shadow_instance_mapped_ptrs: i64 = 0
        shadow_global_buffers: i64 = 0
        shadow_global_memories: i64 = 0
        shadow_global_mapped_ptrs: i64 = 0
        if self.render_state != 0:
            shadow_instance_buffers = Memory.read_ptr(self.render_state + 8)
            shadow_instance_memories = Memory.read_ptr(self.render_state + 16)
            shadow_instance_mapped_ptrs = Memory.read_ptr(self.render_state + 24)
            shadow_global_buffers = Memory.read_ptr(self.render_state + 40)
            shadow_global_memories = Memory.read_ptr(self.render_state + 48)
            shadow_global_mapped_ptrs = Memory.read_ptr(self.render_state + 56)
        if shadow_instance_buffers != 0:
            shadow_slot: i32 = 0
            while shadow_slot < 2:
                shadow_buffer: i64 = Memory.read_ptr(shadow_instance_buffers + shadow_slot * 8)
                shadow_memory: i64 = Memory.read_ptr(shadow_instance_memories + shadow_slot * 8)
                shadow_mapped: i64 = 0
                if shadow_instance_mapped_ptrs != 0:
                    shadow_mapped = Memory.read_ptr(shadow_instance_mapped_ptrs + shadow_slot * 8)
                if shadow_memory != 0:
                    if shadow_mapped != 0:
                        vkUnmapMemory(self.device, shadow_memory)
                if shadow_buffer != 0:
                    vkDestroyBuffer(self.device, shadow_buffer, 0)
                if shadow_memory != 0:
                    vkFreeMemory(self.device, shadow_memory, 0)
                shadow_slot = shadow_slot + 1
            Memory.free(shadow_instance_buffers)
            if shadow_instance_memories != 0:
                Memory.free(shadow_instance_memories)
            if shadow_instance_mapped_ptrs != 0:
                Memory.free(shadow_instance_mapped_ptrs)
        if shadow_global_buffers != 0:
            global_slot: i32 = 0
            while global_slot < 2:
                global_buffer: i64 = Memory.read_ptr(shadow_global_buffers + global_slot * 8)
                global_memory: i64 = Memory.read_ptr(shadow_global_memories + global_slot * 8)
                global_mapped: i64 = 0
                if shadow_global_mapped_ptrs != 0:
                    global_mapped = Memory.read_ptr(shadow_global_mapped_ptrs + global_slot * 8)
                if global_memory != 0:
                    if global_mapped != 0:
                        vkUnmapMemory(self.device, global_memory)
                if global_buffer != 0:
                    vkDestroyBuffer(self.device, global_buffer, 0)
                if global_memory != 0:
                    vkFreeMemory(self.device, global_memory, 0)
                global_slot = global_slot + 1
            Memory.free(shadow_global_buffers)
            if shadow_global_memories != 0:
                Memory.free(shadow_global_memories)
            if shadow_global_mapped_ptrs != 0:
                Memory.free(shadow_global_mapped_ptrs)
        if self.point_light_buffers != 0:
            point_slot: i32 = 0
            while point_slot < 2:
                point_buffer: i64 = Memory.read_ptr(self.point_light_buffers + point_slot * 8)
                point_memory: i64 = Memory.read_ptr(self.point_light_memories + point_slot * 8)
                point_mapped: i64 = 0
                if self.point_light_mapped_ptrs != 0:
                    point_mapped = Memory.read_ptr(self.point_light_mapped_ptrs + point_slot * 8)
                if point_memory != 0:
                    if point_mapped != 0:
                        vkUnmapMemory(self.device, point_memory)
                if point_buffer != 0:
                    vkDestroyBuffer(self.device, point_buffer, 0)
                if point_memory != 0:
                    vkFreeMemory(self.device, point_memory, 0)
                point_slot = point_slot + 1
            Memory.free(self.point_light_buffers)
        if self.point_light_memories != 0:
            Memory.free(self.point_light_memories)
        if self.point_light_mapped_ptrs != 0:
            Memory.free(self.point_light_mapped_ptrs)
        if self.point_light_desc_sets != 0:
            Memory.free(self.point_light_desc_sets)
        self.point_light_buffers = 0
        self.point_light_memories = 0
        self.point_light_mapped_ptrs = 0
        self.point_light_desc_sets = 0
        self.point_light_ptrs = 0
        self.point_light_count = 0
        if self.render_state != 0:
            Memory.free(self.render_state)
        if self.scratch_vb_arr != 0:
            Memory.free(self.scratch_vb_arr)
        if self.scratch_off_arr != 0:
            Memory.free(self.scratch_off_arr)
        if self.scratch_inst_vb_arr != 0:
            Memory.free(self.scratch_inst_vb_arr)
        if self.scratch_inst_off_arr != 0:
            Memory.free(self.scratch_inst_off_arr)
        if self.scratch_desc_arr != 0:
            Memory.free(self.scratch_desc_arr)
        if self.scratch_map_pp != 0:
            Memory.free(self.scratch_map_pp)
        if self.scratch_begin_info != 0:
            Memory.free(self.scratch_begin_info)
        if self.scratch_render_info != 0:
            Memory.free(self.scratch_render_info)
        if self.scratch_clear_values != 0:
            Memory.free(self.scratch_clear_values)
        if self.scratch_viewport != 0:
            Memory.free(self.scratch_viewport)
        if self.scratch_scissor != 0:
            Memory.free(self.scratch_scissor)
        if self.scratch_sky_att != 0:
            Memory.free(self.scratch_sky_att)
        if self.scratch_sky_rect != 0:
            Memory.free(self.scratch_sky_rect)
        if self.scratch_vp_matrix != 0:
            Memory.free(self.scratch_vp_matrix)
        if self.scratch_push_data != 0:
            Memory.free(self.scratch_push_data)
        if self.scratch_camera_view != 0:
            Memory.free(self.scratch_camera_view)
        if self.scratch_camera_proj != 0:
            Memory.free(self.scratch_camera_proj)
        # Destroy textures (image view + sampler + image + memory).
        # Descriptor sets are freed with the pool in RenderPass.cleanup.
        if self.tex_views != 0:
            ti: i32 = 0
            while ti < self.tex_count:
                tv: i64 = Memory.read_ptr(self.tex_views + ti * 8)
                if tv != 0:
                    vkDestroyImageView(self.device, tv, 0)
                ts: i64 = Memory.read_ptr(self.tex_samplers + ti * 8)
                if ts != 0:
                    vkDestroySampler(self.device, ts, 0)
                tim: i64 = Memory.read_ptr(self.tex_images + ti * 8)
                if tim != 0:
                    vkDestroyImage(self.device, tim, 0)
                tmem: i64 = Memory.read_ptr(self.tex_memories + ti * 8)
                if tmem != 0:
                    vkFreeMemory(self.device, tmem, 0)
                ti = ti + 1
            Memory.free(self.tex_views)
        if self.tex_samplers != 0:
            Memory.free(self.tex_samplers)
        if self.tex_images != 0:
            Memory.free(self.tex_images)
        if self.tex_memories != 0:
            Memory.free(self.tex_memories)
        if self.tex_desc_sets != 0:
            Memory.free(self.tex_desc_sets)
        if self.mesh_tex_ids != 0:
            Memory.free(self.mesh_tex_ids)
        if self.mesh_emissive_tex_ids != 0:
            Memory.free(self.mesh_emissive_tex_ids)
        if self.mesh_desc_sets != 0:
            Memory.free(self.mesh_desc_sets)
        if self.mesh_material_params != 0:
            Memory.free(self.mesh_material_params)
        if self.mesh_shadow_flags != 0:
            Memory.free(self.mesh_shadow_flags)
        if self.mesh_shadow_distances != 0:
            Memory.free(self.mesh_shadow_distances)
        self.tex_count = 0
        self.vb_count = 0
        self.instance_capacity = 0
        self.initialized = 0

# Pointer-based 4x4 matrix multiply (column-major f32)
fun multiply_4x4_matrices(a: i64, b: i64) -> i64:
    out: i64 = Memory.malloc_zeroed(64)
    if out == 0:
        return 0
    col: i32 = 0
    while col < 4:
        co: i32 = col * 16
        r: i32 = 0
        while r < 4:
            ro: i32 = r * 4
            val: f32 = 0.0
            val = val + Memory.read_f32(a + 0 + ro) * Memory.read_f32(b + co + 0)
            val = val + Memory.read_f32(a + 16 + ro) * Memory.read_f32(b + co + 4)
            val = val + Memory.read_f32(a + 32 + ro) * Memory.read_f32(b + co + 8)
            val = val + Memory.read_f32(a + 48 + ro) * Memory.read_f32(b + co + 12)
            Memory.write_f32(out + co + ro, val)
            r = r + 1
        col = col + 1
    return out

# Zero-alloc version: writes result into pre-allocated out buffer
fun _frog_multiply_4x4_into(a: i64, b: i64, out: i64) -> void:
    col: i32 = 0
    while col < 4:
        co: i32 = col * 16
        r: i32 = 0
        while r < 4:
            ro: i32 = r * 4
            val: f32 = 0.0
            val = val + Memory.read_f32(a + 0 + ro) * Memory.read_f32(b + co + 0)
            val = val + Memory.read_f32(a + 16 + ro) * Memory.read_f32(b + co + 4)
            val = val + Memory.read_f32(a + 32 + ro) * Memory.read_f32(b + co + 8)
            val = val + Memory.read_f32(a + 48 + ro) * Memory.read_f32(b + co + 12)
            Memory.write_f32(out + co + ro, val)
            r = r + 1
        col = col + 1

