    node: GoblinGroupNode = GoblinGroupNode()
    node.id = index
    node.name = "GoblinGroup"
    node.active = 1
    node.parent_ptr = 0
    node.first_child_ptr = 0
    node.next_sibling_ptr = 0
    node.mesh_id = -1
    node.pos_x = 0.0
    node.pos_y = 0.0
    node.pos_z = 0.0
    node.rot_x = 0.0
    node.rot_y = 0.0
    node.rot_z = 0.0
    node.scale_x = 1.0
    node.scale_y = 1.0
    node.scale_z = 1.0
    node.sum_x = 0.0
    node.sum_z = 0.0
    node.member_count = 0
    node.leader_index = -1
    node.leader_x = 0.0
