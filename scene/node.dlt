    node.name = "Flycam"
    node.active = 1
    node.parent_ptr = 0
    node.first_child_ptr = 0
    node.next_sibling_ptr = 0
    node.mesh_id = -1
    node.pos_x = px
    node.pos_y = py
    node.pos_z = pz
    node.rot_x = 0.0
    node.rot_y = 0.0
    node.rot_z = 0.0
    node.scale_x = 1.0
    node.scale_y = 1.0
    node.scale_z = 1.0
    node.move_speed = 5.0
    node.fast_mult = 2.0
    node.yaw = 0.0
    node.pitch = 0.0
    node.captured = 1
    node.look_ready = 0
    node.aim_x = 0
