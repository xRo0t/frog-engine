fun goblin_node_create(index: i32, mesh_id: i32, px: f32, pz: f32, group_id: i32) -> GoblinNode:
    role: i32 = 0
    if group_id >= 0:
        role = 1
    node: GoblinNode = GoblinNode()
    node.id = index
    node.name = "Goblin"
    node.active = 1
    node.parent_ptr = 0
    node.first_child_ptr = 0
    node.next_sibling_ptr = 0
    node.mesh_id = mesh_id
    node.pos_x = px
    node.pos_y = 0.64
    node.pos_z = pz
    node.rot_x = 0.0
    node.rot_y = 0.0
    node.rot_z = 0.0
    node.scale_x = 0.053
    node.scale_y = 0.053
    node.scale_z = 0.053
    node.home_x = px
    node.home_z = pz
    node.yaw = 0.0
    node.phase = 0
    node.timer = 0.0
    node.phase_tick = 0
    node.dir_x = 0.0
    node.dir_z = 0.0
    node.group_id = group_id
    node.role = role
    node.social_timer = 0.0
    return node

